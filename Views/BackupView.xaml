<UserControl x:Class="GroceryPOS.Views.BackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgBrush}" FontFamily="{DynamicResource AppFont}">

    <Grid Margin="30,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="💾 Backup &amp; Restore" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="Manage database backups to protect your data" FontSize="13"
                       Foreground="{DynamicResource SubTextBrush}"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Backup Section -->
            <Border Grid.Column="0" Style="{DynamicResource CardBorder}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="📁 Create Backup" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12"/>
                    <TextBlock Text="Creates a copy of the current database file with a timestamp."
                               FontSize="13" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                    <Button Content="💾  Create Backup Now" Style="{DynamicResource PrimaryButton}"
                            Command="{Binding CreateBackupCommand}" Margin="0,0,0,12" FontSize="15" Padding="0,14"/>

                    <Button Content="📂  Open Backup Folder" Style="{DynamicResource AccentButton}"
                            Command="{Binding OpenBackupFolderCommand}" Margin="0,0,0,20"/>

                    <!-- Status -->
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                               Foreground="{DynamicResource AccentBrush}" TextWrapping="Wrap"/>

                    <!-- Backup History -->
                    <TextBlock Text="📋 Backup History" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,24,0,10"/>
                    <ListBox ItemsSource="{Binding BackupFiles}" SelectedItem="{Binding SelectedBackupFile}"
                             MaxHeight="300" Background="Transparent" BorderThickness="0"
                             FontFamily="{DynamicResource AppFont}" FontSize="12"
                             Foreground="{DynamicResource TextBrush}"/>
                </StackPanel>
            </Border>

            <!-- Restore Section -->
            <Border Grid.Column="1" Style="{DynamicResource CardBorder}" Margin="12,0,0,0">
                <StackPanel>
                    <TextBlock Text="🔄 Restore Database" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12"/>
                    <TextBlock FontSize="13" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap" Margin="0,0,0,20">
                        <Run Text="Restore the database from a previous backup."/>
                        <LineBreak/>
                        <Run Text="⚠️ Warning: This will replace the current database!" Foreground="{DynamicResource DangerBrush}"/>
                    </TextBlock>

                    <TextBlock Text="Selected Backup:" FontSize="12" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,4"/>
                    <TextBox Style="{DynamicResource ModernTextBox}" IsReadOnly="True"
                             Text="{Binding SelectedBackupFile}" Margin="0,0,0,12" FontSize="11"/>

                    <Button Content="📁  Browse Backup File" Style="{DynamicResource AccentButton}"
                            Command="{Binding BrowseRestoreCommand}" Margin="0,0,0,12"/>

                    <Button Content="🔄  Restore Database" Style="{DynamicResource DangerButton}"
                            Command="{Binding RestoreBackupCommand}" FontSize="15" Padding="0,14"/>

                    <Border Background="#FFF3E0" CornerRadius="8" Padding="14" Margin="0,24,0,0">
                        <StackPanel>
                            <TextBlock Text="💡 Tips" FontSize="14" FontWeight="SemiBold" Foreground="#E65100" Margin="0,0,0,8"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#BF360C" FontSize="12">
                                • Take regular backups before updates
                                <LineBreak/>
                                • A safety backup is auto-created before restore
                                <LineBreak/>
                                • App needs restart after restore
                                <LineBreak/>
                                • Store backups on USB/external drive for safety
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
