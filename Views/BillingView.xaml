<UserControl x:Class="GroceryPOS.Views.BillingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:GroceryPOS.Helpers"
             Background="{DynamicResource BgBrush}" FontFamily="{DynamicResource AppFont}">

    <Grid Margin="30,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Cart Area -->
        <DockPanel Grid.Column="0" Margin="0,0,16,0">
            <!-- Header & Tabs -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="💳 Billing" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                    
                    <!-- Billing Tabs Bar -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <ListBox ItemsSource="{Binding Tabs}"
                                 SelectedItem="{Binding SelectedTab}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,4,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="TabBorder" CornerRadius="8,8,0,0" BorderThickness="1,1,1,0" BorderBrush="{DynamicResource BorderBrush}" Background="#F8FAFC" Padding="12,8">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="TabBorder" Property="Background" Value="White"/>
                                                        <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                        <Setter TargetName="TabBorder" Property="BorderThickness" Value="1,1,1,2"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding TabName}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        
                                        <Button Content="✕" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                                Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        
                        <Button Content="➕" Style="{DynamicResource PrimaryButton}" 
                                Command="{Binding AddTabCommand}"
                                Padding="8,4" FontSize="12" VerticalAlignment="Bottom" Margin="4,0,0,0"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                    <TextBlock Text="{Binding InvoiceNumber, StringFormat='Invoice #: {0}'}" 
                               FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                    <TextBlock Text="{Binding CurrentDateTime}" 
                               FontSize="13" Foreground="{DynamicResource SubTextBrush}"/>
                </StackPanel>
            </Grid>

            <!-- Search & Barcode -->
            <Border DockPanel.Dock="Top" Style="{DynamicResource CardBorder}" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <!-- Search Product -->
                    <TextBlock Text="Search Product" FontSize="12" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,4"/>
                    <ComboBox Style="{DynamicResource ModernComboBox}"
                              ItemsSource="{Binding ItemList}"
                              SelectedItem="{Binding SelectedSearchItem}"
                              DisplayMemberPath="Description"
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              TextSearch.TextPath="Description"
                              StaysOpenOnEdit="True"
                              Margin="0,0,0,12">
                        <ComboBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding ScanBarcodeCommand}"/>
                        </ComboBox.InputBindings>
                    </ComboBox>

                    <!-- Barcode Input -->
                    <TextBlock Text="Or Scan Barcode" FontSize="12" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{DynamicResource ModernTextBox}"
                                 Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="18" Margin="0,0,10,0"
                                 helpers:FocusHelper.NumericOnly="True"
                                 x:Name="BarcodeTextBox" Tag="Barcode">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding ScanBarcodeCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1" Content="🔍 Add" Style="{DynamicResource PrimaryButton}"
                                Command="{Binding ScanBarcodeCommand}" Padding="24,12"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Cart Grid -->
            <Border Style="{DynamicResource CardBorder}" Padding="0">
                <DockPanel>
                    <!-- Cart Header -->
                    <Grid DockPanel.Dock="Top" Margin="16,16,16,12">
                        <TextBlock Text="🛒 Shopping Cart" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                             <Button Content="➕" Style="{DynamicResource PrimaryButton}" Padding="10,6"
                                     Command="{Binding IncreaseQuantityCommand}" Margin="0,0,4,0" FontSize="12"/>
                             <Button Content="➖" Style="{DynamicResource AccentButton}" Padding="10,6"
                                     Command="{Binding DecreaseQuantityCommand}" Margin="0,0,4,0" FontSize="12"/>
                             <Button Content="🗑️ Remove" Style="{DynamicResource DangerButton}" Padding="10,6"
                                     Command="{Binding RemoveFromCartCommand}" FontSize="12"/>
                        </StackPanel>
                    </Grid>

                    <DataGrid ItemsSource="{Binding CartItems}"
                              SelectedItem="{Binding SelectedCartItem}"
                              Style="{DynamicResource ModernDataGrid}"
                              ColumnHeaderStyle="{DynamicResource ModernDataGridColumnHeader}"
                              RowStyle="{DynamicResource ModernDataGridRow}"
                              CellStyle="{DynamicResource ModernDataGridCell}"
                              Margin="0,0,0,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding ItemDescription}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Barcode" Binding="{Binding ItemId}" Width="120" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding UnitPrice, StringFormat='Rs.{0:N0}'}" Width="90" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="60" IsReadOnly="False">
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
                                        <Setter Property="helpers:FocusHelper.SelectAllOnFocus" Value="True"/>
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalPrice, StringFormat='Rs.{0:N0}'}" Width="90" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </DockPanel>

        <!-- Right: Payment Panel -->
        <Border Grid.Column="1" Style="{DynamicResource CardBorder}" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <TextBlock Text="💵 Payment Details" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,24"/>

                    <!-- Sub Total -->
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Sub Total" FontSize="15" Foreground="{DynamicResource SubTextBrush}"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}">
                            <TextBlock.Text>
                                <Binding Path="SubTotal" StringFormat="Rs.{0:N2}"/>
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>

                    <Separator Background="#E2E8F0" Margin="0,0,0,16"/>

                    <!-- Discount & Tax Row -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Discount (Rs.)" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,6"/>
                            <TextBox Style="{DynamicResource ModernTextBox}"
                                     helpers:FocusHelper.DecimalOnly="True"
                                     Text="{Binding DiscountText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Tax (Rs.)" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,6"/>
                            <TextBox Style="{DynamicResource ModernTextBox}"
                                     helpers:FocusHelper.DecimalOnly="True"
                                     Text="{Binding TaxText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Grand Total -->
                    <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="12" Padding="20,16" Margin="0,0,0,20">
                        <Grid>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="GRAND TOTAL" FontSize="13" Foreground="#CCFFFFFF" FontWeight="SemiBold"/>
                                <TextBlock Text="PKR" FontSize="11" Foreground="#AAFFFFFF"/>
                            </StackPanel>
                            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="28" FontWeight="Bold" Foreground="White">
                                <TextBlock.Text>
                                    <Binding Path="GrandTotal" StringFormat="{}{0:N0}"/>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Cash Received -->
                    <TextBlock Text="Cash Received (Rs.)" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBox Style="{DynamicResource ModernTextBox}" FontSize="18" FontWeight="Bold"
                             helpers:FocusHelper.DecimalOnly="True"
                             Text="{Binding CashReceivedText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>

                    <!-- Change -->
                    <Border CornerRadius="12" Padding="20,16" Margin="0,0,0,24">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChangeNegative}" Value="True">
                                        <Setter Property="Background" Value="#EF4444"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <TextBlock Text="CHANGE DUE" FontSize="13" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center">
                                <TextBlock.Text>
                                    <Binding Path="ChangeAmount" StringFormat="Rs.{0:N0}"/>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Status -->
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" FontWeight="Medium"
                               Foreground="{DynamicResource DangerBrush}" TextWrapping="Wrap" Margin="0,0,0,16"
                               HorizontalAlignment="Center" TextAlignment="Center"/>

                    <!-- Buttons -->
                    <Button Content="✅  Complete Sale" Style="{DynamicResource PrimaryButton}"
                            Command="{Binding CompleteSaleCommand}" FontSize="16" Padding="0,16" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="🖨️ Print Last" Style="{DynamicResource AccentButton}"
                                Command="{Binding PrintReceiptCommand}" Padding="0,12" FontSize="13"/>
                        <Button Grid.Column="2" Content="🗑️ Clear Cart" Command="{Binding ClearCartCommand}" Padding="0,12" FontSize="13">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                    <Setter Property="Foreground" Value="#EF4444"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
