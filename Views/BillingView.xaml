<UserControl x:Class="GroceryPOS.Views.BillingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GroceryPOS.Converters"
             xmlns:helpers="clr-namespace:GroceryPOS.Helpers"
             Background="{DynamicResource BgBrush}" FontFamily="{DynamicResource AppFont}"
             MinWidth="1050">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <converters:CountToVisibilityConverter x:Key="CountToVis"/>
        <converters:CountToVisibilityConverter x:Key="InverseCountToVis" Inverse="True"/>
        <converters:StringToVisibilityConverter x:Key="StringToVis"/>
    </UserControl.Resources>
    <Grid Margin="20,12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Cart Area -->
        <DockPanel Grid.Column="0" Margin="0,0,16,0">
            <!-- Header & Tabs -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="💳 Billing" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                    
                    <!-- Billing Tabs Bar -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <ListBox ItemsSource="{Binding Tabs}"
                                 SelectedItem="{Binding SelectedTab}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,4,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="TabBorder" CornerRadius="8,8,0,0" BorderThickness="1,1,1,0" BorderBrush="{DynamicResource BorderBrush}" Background="#F8FAFC" Padding="12,8">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="TabBorder" Property="Background" Value="White"/>
                                                        <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                        <Setter TargetName="TabBorder" Property="BorderThickness" Value="1,1,1,2"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding TabName}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        
                                        <Button Content="X" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                                Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        
                        <Button Content="➕" Style="{DynamicResource PrimaryButton}" 
                                Command="{Binding AddTabCommand}"
                                Padding="8,4" FontSize="12" VerticalAlignment="Bottom" Margin="4,0,0,0"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                    <TextBlock Text="{Binding InvoiceNumber, StringFormat='Invoice #: {0}'}" 
                               FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                    <TextBlock Text="{Binding CurrentDateTime}" 
                               FontSize="13" Foreground="{DynamicResource SubTextBrush}"/>
                </StackPanel>
            </Grid>

            <!-- Customer Section -->
            <Border DockPanel.Dock="Top" Style="{DynamicResource CardBorder}" Padding="12,8" Margin="0,0,0,8">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="👤 Customer Information" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                        <Button Content="Add New" HorizontalAlignment="Right" Style="{StaticResource AccentButton}" 
                                Padding="8,2" FontSize="11" Command="{Binding ToggleRegistrationCommand}"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Search Box -->
                        <TextBox Tag="Search by phone..." Style="{DynamicResource ModernTextBox}"
                                 Text="{Binding CustomerSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 helpers:FocusHelper.IsFocused="{Binding IsCustomerSearchFocused, Mode=TwoWay}"
                                 Visibility="{Binding HasSelectedCustomer, Converter={StaticResource InvBoolToVis}}">
                           <TextBox.InputBindings>
                               <KeyBinding Key="Return" Command="{Binding SelectCustomerCommand}"/>
                               <KeyBinding Key="Escape" Command="{Binding ClearCustomerCommand}"/>
                               <KeyBinding Key="Down" Command="{Binding NavigateSearchCommand}" CommandParameter="Down"/>
                               <KeyBinding Key="Up" Command="{Binding NavigateSearchCommand}" CommandParameter="Up"/>
                           </TextBox.InputBindings>
                        </TextBox>

                        <!-- Selected Customer Info -->
                        <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="8" Padding="12,8"
                                Visibility="{Binding HasSelectedCustomer, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="👤" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding SelectedCustomer.Name}" FontWeight="Bold" Foreground="White" FontSize="15" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding SelectedCustomer.PrimaryPhone, StringFormat=' ({0})'}" Foreground="#CCFFFFFF" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </StackPanel>
                                    
                                    <Button Content="✕" FontWeight="Bold" Foreground="White" Background="Transparent" BorderThickness="0"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Command="{Binding ClearCustomerCommand}" Cursor="Hand"/>
                                </Grid>

                                <Separator Background="#33FFFFFF" Margin="0,6"/>

                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="BILL HISTORY:" Foreground="#BBFFFFFF" FontSize="10" FontWeight="Black" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <ComboBox ItemsSource="{Binding CustomerBills}"
                                                      SelectedItem="{Binding SelectedHistoryBill}"
                                                      Background="#1AFFFFFF" BorderThickness="0" Foreground="Black"
                                                      MinWidth="200" Height="28"
                                                      Visibility="{Binding CustomerBills.Count, Converter={StaticResource CountToVis}}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="4">
                                                            <Grid.Resources>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasPendingCredit}" Value="True">
                                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Grid.Resources>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding InvoiceNumber}" FontWeight="Bold" Width="70"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding BillDateTime, StringFormat='{}{0:MMM dd, HH:mm}'}" Margin="10,0" Opacity="0.7"/>
                                                            <TextBlock Grid.Column="2" FontWeight="Black" Text="{Binding GrandTotal, StringFormat='Rs.{0:N0}'}"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <TextBlock Text="No past bills found." 
                                                       Foreground="#99FFFFFF" FontSize="11" FontStyle="Italic"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding CustomerBills.Count, Converter={StaticResource InverseCountToVis}}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="🔍 SEARCH" 
                                                    Style="{StaticResource PrimaryButton}" 
                                                    Padding="8,0" Height="28" Margin="0,0,6,0" FontSize="10"
                                                    Background="#33FFFFFF" BorderThickness="1" BorderBrush="#66FFFFFF"
                                                    Command="{Binding ClearCustomerCommand}"
                                                    ToolTip="Clear selection and search for a different phone number"/>
                                                    
                                            <Button Content="↺ REPEAT" 
                                                    Style="{StaticResource AccentButton}" 
                                                    Padding="8,0" Height="28" FontSize="10"
                                                    Command="{Binding RepeatOrderCommand}"
                                                    ToolTip="Quickly reload the most recent order"/>
                                        </StackPanel>
                                    </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Search Results Popup Sim-alike -->
                    <ListBox ItemsSource="{Binding CustomerSearchResults}" 
                              SelectedItem="{Binding SelectedSearchResult}"
                              MaxHeight="150" Margin="0,4,0,0"
                              Visibility="{Binding CustomerSearchResults.Count, Converter={StaticResource CountToVis}, FallbackValue=Collapsed}"
                              Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Name="Border" Padding="10,8" Background="Transparent" SnapsToDevicePixels="true">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="true">
                                                    <Setter TargetName="Border" Property="Background" Value="#F1F5F9"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="true">
                                                    <Setter TargetName="Border" Property="Background" Value="#F8FAFC"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Background="Transparent">
                                    <Grid.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" 
                                                      Command="{Binding DataContext.SelectCustomerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Grid.InputBindings>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextBrush}"/>
                                        <TextBlock Text="{Binding PrimaryPhone}" FontSize="12" Foreground="{DynamicResource SubTextBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="20,0,0,0">
                                        <TextBlock Text="{Binding TotalAmount, StringFormat='Rs.{0:N0}'}" 
                                                   FontWeight="Black" FontSize="14" Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Right"/>
                                        <TextBlock Text="{Binding BillCount, StringFormat='{}{0} orders'}" 
                                                   FontSize="11" Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Right" Opacity="0.8"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- ═══ Pending Credit Warning Badge ═══ -->
            <Border DockPanel.Dock="Top" CornerRadius="6" Padding="12,6" Margin="0,0,0,8"
                    Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1"
                    Visibility="{Binding HasPendingCredit, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠" FontSize="16" Foreground="#DC2626" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#DC2626">
                            <Run Text="This customer has Rs."/>
                            <Run Text="{Binding PendingCreditAmount, StringFormat='{}{0:N0}', Mode=OneWay}" FontWeight="Bold"/>
                            <Run Text="pending credit."/>
                        </TextBlock>
                        <TextBlock Text="Collect previous dues before extending more credit." FontSize="11" Foreground="#991B1B" Opacity="0.8" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Search & Barcode -->
            <Border DockPanel.Dock="Top" Style="{DynamicResource CardBorder}" Padding="12,10" Margin="0,0,0,8">
                <StackPanel>
                    <!-- Search Product -->
                    <TextBlock Text="Search Product" FontSize="12" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,4"/>
                    <ComboBox Style="{DynamicResource ModernComboBox}"
                              ItemsSource="{Binding FilteredItemList}"
                              SelectedItem="{Binding SelectedSearchItem}"
                              TextSearch.TextPath="Description"
                              IsEditable="True"
                              IsTextSearchEnabled="False"
                              Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}"
                              IsDropDownOpen="{Binding IsProductDropDownOpen}"
                              StaysOpenOnEdit="True"
                              helpers:FocusHelper.FixComboBoxSearch="True"
                              Margin="0,0,0,8">
                        <ComboBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding ScanBarcodeCommand}"/>
                            <KeyBinding Key="Down" Command="{Binding NavigateProductSearchCommand}" CommandParameter="Down"/>
                            <KeyBinding Key="Up" Command="{Binding NavigateProductSearchCommand}" CommandParameter="Up"/>
                        </ComboBox.InputBindings>
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Background="Transparent">
                                    <Grid.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" 
                                                      Command="{Binding DataContext.ScanBarcodeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    </Grid.InputBindings>
                                    <TextBlock Text="{Binding Description}"/>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Barcode Input -->
                    <TextBlock Text="Or Scan Barcode" FontSize="12" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{DynamicResource ModernTextBox}"
                                 Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="18" Margin="0,0,10,0"
                                 helpers:FocusHelper.NumericOnly="True"
                                 helpers:FocusHelper.SelectAllOnFocus="True"
                                 x:Name="BarcodeTextBox" Tag="Barcode">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding ScanBarcodeCommand}"/>
                                <KeyBinding Key="F10" Command="{Binding TogglePreviewCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1" Content="🔍 Add" Style="{DynamicResource PrimaryButton}"
                                Command="{Binding ScanBarcodeCommand}" Padding="16,8"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Cart Grid -->
            <Border Style="{DynamicResource CardBorder}" Padding="0">
                <DockPanel>
                    <!-- Cart Header -->
                    <Grid DockPanel.Dock="Top" Margin="12,10,12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🛒 Shopping Cart" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                             <Button Content="+" Style="{DynamicResource PrimaryButton}" Padding="10,4"
                                     Command="{Binding IncreaseQuantityCommand}" Margin="0,0,4,0" FontSize="12" MinWidth="32"/>
                             <Button Content="-" Style="{DynamicResource AccentButton}" Padding="10,4"
                                     Command="{Binding DecreaseQuantityCommand}" Margin="0,0,4,0" FontSize="12" MinWidth="32"/>
                             <Button Content="Remove" Style="{DynamicResource DangerButton}" Padding="10,4"
                                     Command="{Binding RemoveFromCartCommand}" FontSize="11"/>
                        </StackPanel>
                    </Grid>

                    <DataGrid ItemsSource="{Binding CartItems}"
                              SelectedItem="{Binding SelectedCartItem}"
                              Style="{DynamicResource ModernDataGrid}"
                              ColumnHeaderStyle="{DynamicResource ModernDataGridColumnHeader}"
                              RowStyle="{DynamicResource ModernDataGridRow}"
                              CellStyle="{DynamicResource ModernDataGridCell}"
                              Margin="0,0,0,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding ItemDescription}" Width="*" MinWidth="150" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Barcode" Binding="{Binding ItemId}" Width="120" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding UnitPrice, StringFormat='Rs.{0:N0}'}" Width="90" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="75" IsReadOnly="False">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
                                        <Setter Property="helpers:FocusHelper.SelectAllOnFocus" Value="True"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="2,4"/>
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalPrice, StringFormat='Rs.{0:N0}'}" Width="90" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </DockPanel>

        <!-- Right: Payment Panel -->
        <Border Grid.Column="1" Style="{DynamicResource CardBorder}" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <TextBlock Text="💵 Payment Details" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,24"/>

                    <!-- Sub Total -->
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Sub Total" FontSize="15" Foreground="{DynamicResource SubTextBrush}"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}">
                            <TextBlock.Text>
                                <Binding Path="SubTotal" StringFormat="Rs.{0:N2}"/>
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>

                    <Separator Background="#E2E8F0" Margin="0,0,0,16"/>

                    <!-- Discount & Tax Row -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Discount (Rs.)" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,6"/>
                            <TextBox Style="{DynamicResource ModernTextBox}"
                                     helpers:FocusHelper.DecimalOnly="True"
                                     helpers:FocusHelper.SelectAllOnFocus="True"
                                     Text="{Binding DiscountText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Tax (Rs.)" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,6"/>
                            <TextBox Style="{DynamicResource ModernTextBox}"
                                     helpers:FocusHelper.DecimalOnly="True"
                                     helpers:FocusHelper.SelectAllOnFocus="True"
                                     Text="{Binding TaxText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Grand Total -->
                    <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="12" Padding="20,16" Margin="0,0,0,20">
                        <Grid>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="GRAND TOTAL" FontSize="13" Foreground="#CCFFFFFF" FontWeight="SemiBold"/>
                                <TextBlock Text="PKR" FontSize="11" Foreground="#AAFFFFFF"/>
                            </StackPanel>
                            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="28" FontWeight="Bold" Foreground="White">
                                <TextBlock.Text>
                                    <Binding Path="GrandTotal" StringFormat="{}{0:N0}"/>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Cash Received -->
                    <TextBlock Text="Cash Received (Rs.)" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBox Style="{DynamicResource ModernTextBox}" FontSize="18" FontWeight="Bold"
                             helpers:FocusHelper.DecimalOnly="True"
                             helpers:FocusHelper.SelectAllOnFocus="True"
                             Text="{Binding CashReceivedText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>

                    <!-- Paid Amount (Credit Sales — only for registered customers) -->
                    <StackPanel Visibility="{Binding HasSelectedCustomer, Converter={StaticResource BoolToVis}}" Margin="0,0,0,16">
                        <TextBlock Text="Paid Amount / Credit (Rs.)" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="Leave empty for full payment. Enter 0 for full credit." FontSize="10" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,6"/>
                        <TextBox Style="{DynamicResource ModernTextBox}" FontSize="18" FontWeight="Bold"
                                 helpers:FocusHelper.DecimalOnly="True"
                                 helpers:FocusHelper.SelectAllOnFocus="True"
                                 Text="{Binding PaidAmountText, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Change -->
                    <Border CornerRadius="12" Padding="20,16" Margin="0,0,0,24">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{Binding ChangeDisplayBrush}"/>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <TextBlock Text="{Binding ChangeDisplayLabel}" FontSize="13" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"
                                       Visibility="{Binding IsChangeAmountVisible, Converter={StaticResource BoolToVis}}">
                                <TextBlock.Text>
                                    <Binding Path="ChangeAmountAbs" StringFormat="Rs.{0:N0}"/>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Status -->
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" FontWeight="Medium"
                               Foreground="{DynamicResource DangerBrush}" TextWrapping="Wrap" Margin="0,0,0,16"
                               HorizontalAlignment="Center" TextAlignment="Center"/>

                    <!-- Buttons -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="✅  Complete Sale" Style="{DynamicResource PrimaryButton}"
                                Command="{Binding CompleteSaleCommand}" FontSize="16" Padding="0,16"/>
                        <Button Grid.Column="2" Content="View Preview" Style="{DynamicResource AccentButton}"
                                ToolTip="Toggle Bill Preview (F10)"
                                Command="{Binding TogglePreviewCommand}" Padding="12,0" FontSize="14"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="🖨️ Print Last" Style="{DynamicResource AccentButton}"
                                Command="{Binding PrintReceiptCommand}" Padding="0,12" FontSize="13"/>
                        <Button Grid.Column="2" Content="🗑️ Clear Cart" Command="{Binding ClearCartCommand}" Padding="0,12" FontSize="13">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                    <Setter Property="Foreground" Value="#EF4444"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Right Column 2: Virtual Receipt Preview (Professional Drawer Look) -->
        <Border Grid.Column="2" Width="300" Margin="20,0,0,0" 
                Visibility="{Binding IsPreviewVisible, Converter={StaticResource BoolToVis}}"
                Background="White" CornerRadius="16" UseLayoutRounding="True" SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.12" Color="#000000"/>
            </Border.Effect>
            
            <DockPanel>
                <!-- Preview Header -->
                <Grid DockPanel.Dock="Top" Margin="20,16">
                    <TextBlock Text="Receipt Preview" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}"/>
                    <Button Content="X" HorizontalAlignment="Right" VerticalAlignment="Center" 
                            Background="Transparent" BorderThickness="0" Foreground="{DynamicResource SubTextBrush}"
                            Command="{Binding TogglePreviewCommand}" Cursor="Hand" FontSize="14">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <Separator DockPanel.Dock="Top" Background="#F1F5F9" Margin="0" Height="1"/>

                <!-- The "Paper" Receipt -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel Background="White">
                        <!-- Store Header -->
                        <TextBlock Text="{Binding StoreName}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#1E293B"/>
                        <TextBlock Text="{Binding StoreAddress}" FontSize="10" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Foreground="#64748B" Margin="0,4"/>
                        <TextBlock Text="{Binding StorePhone, StringFormat='Ph: {0}'}" FontSize="11" HorizontalAlignment="Center" Foreground="#64748B"/>
                        
                        <Border BorderThickness="0,0,0,1" BorderBrush="#E2E8F0" Margin="0,12" SnapsToDevicePixels="True"/>
                        
                        <!-- Invoice Info -->
                        <Grid>
                            <TextBlock Text="{Binding InvoiceNumber, StringFormat='No: {0}'}" FontSize="11" Foreground="#475569" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding CurrentTime, StringFormat='{}{0:HH:mm}'}" FontSize="11" HorizontalAlignment="Right" Foreground="#64748B"/>
                        </Grid>
                        <TextBlock Text="{Binding CurrentTime, StringFormat='{}{0:dd MMM yyyy}'}" FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>

                        <Border BorderThickness="0,0,0,1" BorderBrush="#E2E8F0" Margin="0,12" SnapsToDevicePixels="True"/>
                        
                        <!-- Items Header -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Product Details" FontSize="11" FontWeight="Bold" Foreground="#1E293B"/>
                            <TextBlock Grid.Column="1" Text="Total (Rs)" FontSize="11" FontWeight="Bold" Foreground="#1E293B"/>
                        </Grid>
                        
                        <!-- Items List -->
                        <ItemsControl ItemsSource="{Binding CartItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="{Binding ItemDescription}" FontSize="12" Foreground="#334155" FontWeight="Normal" TextWrapping="Wrap"/>
                                            <TextBlock FontSize="10" Foreground="#94A3B8" Margin="0,2,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Quantity}" Value="1">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0:N0} x {1}">
                                                        <Binding Path="UnitPrice"/>
                                                        <Binding Path="Quantity"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Text="{Binding TotalPrice, StringFormat='{}{0:N2}'}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="#1E293B"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <Rectangle Stroke="#E2E8F0" StrokeDashArray="4 2" StrokeThickness="1" Height="1" Margin="0,15" SnapsToDevicePixels="True"/>
                        
                        <!-- Totals Area -->
                        <Grid Margin="0,4">
                            <TextBlock Text="Sub Total" FontSize="12" Foreground="#64748B"/>
                            <TextBlock Text="{Binding SubTotal, StringFormat='Rs.{0:N2}'}" FontSize="12" HorizontalAlignment="Right" Foreground="#1E293B" FontWeight="Bold"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <TextBlock Text="Discount" FontSize="12" Foreground="#64748B"/>
                            <TextBlock Text="{Binding DiscountAmount, StringFormat='-Rs.{0:N2}'}" FontSize="12" HorizontalAlignment="Right" Foreground="#EF4444" FontWeight="Bold"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <TextBlock Text="Tax" FontSize="12" Foreground="#64748B"/>
                            <TextBlock Text="{Binding TaxAmount, StringFormat='Rs.{0:N2}'}" FontSize="12" HorizontalAlignment="Right" Foreground="#1E293B" FontWeight="Bold"/>
                        </Grid>

                        <Border Background="#F8FAFC" CornerRadius="8" Padding="12,10" Margin="0,10">
                            <Grid>
                                <TextBlock Text="NET TOTAL" FontSize="14" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding GrandTotal, StringFormat='Rs.{0:N0}'}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right" Foreground="{DynamicResource PrimaryBrush}"/>
                            </Grid>
                        </Border>

                        <Grid Margin="0,2">
                            <TextBlock Text="Cash Paid" FontSize="11" Foreground="#64748B"/>
                            <TextBlock Text="{Binding CashReceivedText, StringFormat='Rs.{0}'}" FontSize="11" HorizontalAlignment="Right" Foreground="#1E293B"/>
                        </Grid>
                        <Grid Margin="0,2">
                            <TextBlock Text="Change Due" FontSize="11" Foreground="#64748B"/>
                            <TextBlock Text="{Binding ChangeAmount, StringFormat='Rs.{0:N2}'}" FontSize="11" HorizontalAlignment="Right" Foreground="#1E293B" FontWeight="Bold"/>
                        </Grid>

                        <!-- Footer -->
                        <StackPanel Margin="0,30,0,10">
                            <TextBlock Text="Thank you for your business!" FontSize="11" HorizontalAlignment="Center" Foreground="#94A3B8"/>
                            <TextBlock Text="Visit us again soon" FontSize="10" HorizontalAlignment="Center" Foreground="#CBD5E1" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
        
        <!-- Registration Overlay -->
        <Grid Background="#44000000" Grid.ColumnSpan="3" Panel.ZIndex="1000"
              Visibility="{Binding IsRegistrationVisible, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
            <Border Width="400" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Style="{DynamicResource CardBorder}" Padding="24">
                <StackPanel>
                    <TextBlock Text="📝 Register New Customer" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Full Name *" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Style="{DynamicResource ModernTextBox}" Text="{Binding NewCustomerName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <TextBlock Text="Phone Number *" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Style="{DynamicResource ModernTextBox}" Text="{Binding NewCustomerPhone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" helpers:FocusHelper.NumericOnly="True"/>

                    <TextBlock Text="Phone Number 2 (Optional)" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Style="{DynamicResource ModernTextBox}" Text="{Binding NewCustomerSecondaryPhone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" helpers:FocusHelper.NumericOnly="True"/>

                    <TextBlock Text="Address (Optional)" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Style="{DynamicResource ModernTextBox}" Text="{Binding NewCustomerAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <!-- Error Message Display -->
                    <TextBlock Text="{Binding RegistrationErrorMessage}" Foreground="#EF4444" 
                               FontSize="12" FontWeight="Bold" Margin="0,0,0,12"
                               TextWrapping="Wrap"
                               Visibility="{Binding RegistrationErrorMessage, Converter={StaticResource StringToVis}}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Cancel" Style="{StaticResource DangerButton}" Command="{Binding ToggleRegistrationCommand}" Padding="0,12"/>
                        <Button Grid.Column="2" Content="Save Customer" Style="{StaticResource PrimaryButton}" Command="{Binding SaveNewCustomerCommand}" Padding="0,12"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
