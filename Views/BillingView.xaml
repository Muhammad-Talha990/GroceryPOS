<UserControl x:Class="GroceryPOS.Views.BillingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GroceryPOS.Converters"
             xmlns:helpers="clr-namespace:GroceryPOS.Helpers"
             xmlns:controls="clr-namespace:GroceryPOS.Views.Controls"
             Background="{DynamicResource BgBrush}" FontFamily="{DynamicResource AppFont}"
             MinWidth="1050">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <converters:CountToVisibilityConverter x:Key="CountToVis"/>
        <converters:CountToVisibilityConverter x:Key="InverseCountToVis" Inverse="True"/>
        <converters:StringToVisibilityConverter x:Key="StringToVis"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:NumericToVisibilityConverter x:Key="NumToVis"/>
        <converters:StatusColorConverter x:Key="StatusColorConverter"/>
    </UserControl.Resources>
    <Grid Margin="15,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Dashboard Stats Bar -->
        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#1E293B" CornerRadius="10" Padding="16,10" Margin="0,0,0,8">
            <UniformGrid Columns="6">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Total Sales" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center">
                        <TextBlock.Text><Binding Path="StatTotalSales" StringFormat="Rs.{0:N0}"/></TextBlock.Text>
                    </TextBlock>
                </StackPanel>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Returns" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#FF7043" HorizontalAlignment="Center">
                        <TextBlock.Text><Binding Path="StatReturns" StringFormat="Rs.{0:N0}"/></TextBlock.Text>
                    </TextBlock>
                </StackPanel>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Credit (Due)" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#EF4444" HorizontalAlignment="Center">
                        <TextBlock.Text><Binding Path="StatCredit" StringFormat="Rs.{0:N0}"/></TextBlock.Text>
                    </TextBlock>
                </StackPanel>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Recovered Credit" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#8B5CF6" HorizontalAlignment="Center">
                        <TextBlock.Text><Binding Path="StatRecoveredCredit" StringFormat="Rs.{0:N0}"/></TextBlock.Text>
                    </TextBlock>
                </StackPanel>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Cash In Drawer" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#22C55E" HorizontalAlignment="Center">
                        <TextBlock.Text><Binding Path="StatCashInDrawer" StringFormat="Rs.{0:N0}"/></TextBlock.Text>
                    </TextBlock>
                </StackPanel>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Online Payments" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#0EA5E9" HorizontalAlignment="Center">
                        <TextBlock.Text><Binding Path="StatOnlinePayments" StringFormat="Rs.{0:N0}"/></TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </UniformGrid>
        </Border>

        <!-- Left: Cart Area -->
        <DockPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,0">
            <!-- Header & Tabs -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="💳 Billing" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"/>
                    
                    <!-- Billing Tabs Bar -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <ListBox ItemsSource="{Binding Tabs}"
                                 SelectedItem="{Binding SelectedTab}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,4,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="TabBorder" CornerRadius="8,8,0,0" BorderThickness="1,1,1,0" BorderBrush="{DynamicResource BorderBrush}" Background="#F8FAFC" Padding="12,8">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="TabBorder" Property="Background" Value="White"/>
                                                        <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                        <Setter TargetName="TabBorder" Property="BorderThickness" Value="1,1,1,2"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding TabName}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        
                                        <Button Content="X" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                                Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        
                        <Button Content="➕" Style="{DynamicResource PrimaryButton}" 
                                Command="{Binding AddTabCommand}"
                                Padding="8,4" FontSize="12" VerticalAlignment="Bottom" Margin="4,0,0,0"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <TextBlock Text="{Binding InvoiceNumber, StringFormat='Invoice #: {0}', Mode=OneWay}" 
                               FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding CurrentDateTime}" 
                               FontSize="11" Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>

            <!-- Customer Section -->
            <Border DockPanel.Dock="Top" Style="{DynamicResource CardBorder}" Padding="10,4" Margin="0,0,0,4">
                <StackPanel>
                    <Grid Margin="0,0,0,2">
                        <TextBlock Text="👤 Customer Information" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                        <Button Content="Add New" HorizontalAlignment="Right" Style="{StaticResource AccentButton}" 
                                Padding="8,2" FontSize="11" Command="{Binding ToggleRegistrationCommand}"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Search Box -->
                        <TextBox Tag="Search by phone..." Style="{DynamicResource ModernTextBox}"
                                 Text="{Binding CustomerSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 helpers:FocusHelper.IsFocused="{Binding IsCustomerSearchFocused, Mode=TwoWay}"
                                 Visibility="{Binding HasSelectedCustomer, Converter={StaticResource InvBoolToVis}}">
                           <TextBox.InputBindings>
                               <KeyBinding Key="Return" Command="{Binding SelectCustomerCommand}"/>
                               <KeyBinding Key="Escape" Command="{Binding ClearCustomerCommand}"/>
                               <KeyBinding Key="Down" Command="{Binding NavigateSearchCommand}" CommandParameter="Down"/>
                               <KeyBinding Key="Up" Command="{Binding NavigateSearchCommand}" CommandParameter="Up"/>
                           </TextBox.InputBindings>
                        </TextBox>

                        <!-- Selected Customer Info -->
                        <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="8" Padding="8,4"
                                Visibility="{Binding HasSelectedCustomer, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="👤" Foreground="White" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding SelectedCustomer.Name}" FontWeight="Bold" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding SelectedCustomer.PrimaryPhone, StringFormat=' ({0})'}" Foreground="#CCFFFFFF" FontSize="11" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </StackPanel>
                                    
                                    <Button Content="✕" FontWeight="Bold" Foreground="White" Background="Transparent" BorderThickness="0"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Command="{Binding ClearCustomerCommand}" Cursor="Hand"/>
                                </Grid>

                                    <Separator Background="#33FFFFFF" Margin="0,2"/>
                                    <Grid Margin="0,1,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="BILL HISTORY:" Foreground="#BBFFFFFF" FontSize="10" FontWeight="Black" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <ComboBox ItemsSource="{Binding CustomerBills}"
                                                      SelectedItem="{Binding SelectedHistoryBill}"
                                                      Background="#1AFFFFFF" BorderThickness="0" Foreground="Black"
                                                      MinWidth="300" Height="28"
                                                      Visibility="{Binding CustomerBills.Count, Converter={StaticResource CountToVis}}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="2">
                                                            <Grid.Resources>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding PaymentStatus}" Value="PartialPaid">
                                                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Grid.Resources>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding InvoiceNumber, StringFormat='Inv: {0}', Mode=OneWay}" FontWeight="Bold" Margin="0,0,10,0"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding BillDateTime, StringFormat='{}{0:dd MMM, HH:mm}'}" Margin="0,0,10,0" Opacity="0.7"/>
                                                            <TextBlock Grid.Column="2" FontWeight="Black" Text="{Binding GrandTotal, StringFormat='Total: Rs.{0:N0}'}"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <TextBlock Text="No past bills found." 
                                                       Foreground="#99FFFFFF" FontSize="11" FontStyle="Italic"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding CustomerBills.Count, Converter={StaticResource InverseCountToVis}}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="🔍 SEARCH" 
                                                    Style="{StaticResource PrimaryButton}" 
                                                    Padding="8,0" Height="26" FontSize="10"
                                                    Background="#33FFFFFF" BorderThickness="1" BorderBrush="#66FFFFFF"
                                                    Command="{Binding ClearCustomerCommand}"
                                                    ToolTip="Clear selection and search for a different phone number"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Address Selection Dropdown -->
                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="ADDRESS:" Foreground="#BBFFFFFF" FontSize="10" FontWeight="Black" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        
                                        <!-- Normal State (Selecting Address or "No address") -->
                                        <Grid Grid.Column="1" Visibility="{Binding IsAddingAddress, Converter={StaticResource InvBoolToVis}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox ItemsSource="{Binding AvailableAddresses}"
                                                      SelectedItem="{Binding SelectedBillingAddress}"
                                                      Background="#1AFFFFFF" BorderThickness="0" Foreground="Black"
                                                      Height="26" VerticalAlignment="Center"
                                                      Visibility="{Binding AvailableAddresses.Count, Converter={StaticResource CountToVis}}"/>
                                            <TextBlock Text="No address stored." 
                                                       Foreground="#99FFFFFF" FontSize="11" FontStyle="Italic"
                                                       VerticalAlignment="Center" Margin="4,0,0,0"
                                                       Visibility="{Binding AvailableAddresses.Count, Converter={StaticResource InverseCountToVis}}"/>
                                            <!-- Add New Button -->
                                            <Button Grid.Column="1" Content="➕ Add New"
                                                    Command="{Binding AddAddressCommand}"
                                                    Background="#10B981" BorderBrush="#059669" BorderThickness="1"
                                                    Foreground="White" FontSize="10" FontWeight="Bold"
                                                    Padding="8,0" Margin="8,0,0,0" Height="26"/>
                                        </Grid>

                                        <!-- Add New Address State -->
                                        <Grid Grid.Column="1" Visibility="{Binding IsAddingAddress, Converter={StaticResource BoolToVis}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding NewAddressInput, UpdateSourceTrigger=PropertyChanged}" 
                                                     Height="26" VerticalContentAlignment="Center" Background="#1AFFFFFF" Foreground="White" BorderThickness="1" BorderBrush="#3B82F6"/>
                                            <Button Grid.Column="1" Content="Save" 
                                                    Command="{Binding SaveAddressCommand}"
                                                    Background="#3B82F6" BorderBrush="#2563EB" BorderThickness="1"
                                                    Foreground="White" Padding="8,0" Margin="4,0,0,0" Height="26" FontSize="10" FontWeight="Bold"/>
                                            <Button Grid.Column="2" Content="Cancel" 
                                                    Command="{Binding CancelAddAddressCommand}"
                                                    Background="#4B5563" BorderBrush="#374151" BorderThickness="1"
                                                    Foreground="White" Padding="8,0" Margin="4,0,0,0" Height="26" FontSize="10" FontWeight="Bold"/>
                                        </Grid>
                                    </Grid>

                                    <!-- ── Bill Action Strip (shows whenever any bill is selected) ── -->
                                    <Grid Visibility="{Binding PreviewHistoryBill, Converter={StaticResource NullToVis}}" Margin="0,3,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="Bill: " FontSize="10" Foreground="#BBFFFFFF" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding PreviewHistoryBill.InvoiceNumber, Mode=OneWay}" FontSize="11" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding PreviewHistoryBill.GrandTotal, StringFormat=' — Rs.{0:N0}'}" FontSize="11" Foreground="#DDFFFFFF" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="📋 Details" Style="{StaticResource PrimaryButton}"
                                                    Command="{Binding OpenBillDetailCommand}"
                                                    Padding="8,4" FontSize="10" Height="26" Margin="0,0,6,0"
                                                    Background="#3B82F6" BorderBrush="#2563EB"/>
                                            <Button Content="🛒 Copy Items" Style="{StaticResource PrimaryButton}"
                                                    Command="{Binding LoadPreviewToCartCommand}"
                                                    Padding="8,4" FontSize="10" Height="26" Margin="0,0,6,0"
                                                    Background="#0D9488" BorderBrush="#0F766E"/>
                                            <Button Content="💳 Pay Due" Style="{StaticResource AccentButton}"
                                                    Command="{Binding OpenHistoryPaymentCommand}"
                                                    Visibility="{Binding PreviewHistoryBill.HasPendingCredit, Converter={StaticResource BoolToVis}}"
                                                    Padding="8,4" FontSize="10" Height="26"/>
                                        </StackPanel>
                                    </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Search Results Popup Sim-alike -->
                    <ListBox ItemsSource="{Binding CustomerSearchResults}" 
                              SelectedItem="{Binding SelectedSearchResult}"
                              MaxHeight="150" Margin="0,4,0,0"
                              Visibility="{Binding CustomerSearchResults.Count, Converter={StaticResource CountToVis}, FallbackValue=Collapsed}"
                              Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Name="Border" Padding="10,8" Background="Transparent" SnapsToDevicePixels="true">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="true">
                                                    <Setter TargetName="Border" Property="Background" Value="#F1F5F9"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="true">
                                                    <Setter TargetName="Border" Property="Background" Value="#F8FAFC"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Background="Transparent">
                                    <Grid.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" 
                                                      Command="{Binding DataContext.SelectCustomerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Grid.InputBindings>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextBrush}"/>
                                        <TextBlock Text="{Binding PrimaryPhone}" FontSize="12" Foreground="{DynamicResource SubTextBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="20,0,0,0">
                                        <TextBlock Text="{Binding TotalAmount, StringFormat='Rs.{0:N0}'}" 
                                                   FontWeight="Black" FontSize="14" Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Right"/>
                                        <TextBlock Text="{Binding BillCount, StringFormat='{}{0} orders'}" 
                                                   FontSize="11" Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Right" Opacity="0.8"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- ═══ Pending Credit Warning Badge ═══ -->
            <Border DockPanel.Dock="Top" Style="{DynamicResource CardBorder}" Padding="10,4" Margin="0,0,0,4"
                    Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1"
                    Visibility="{Binding HasPendingCredit, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="⚠" FontSize="16" Foreground="#DC2626" VerticalAlignment="Top" Margin="0,1,8,0"/>
                    
                    <StackPanel Grid.Column="1">
                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#DC2626">
                            <Run Text="This customer has Rs."/>
                            <Run Text="{Binding PendingCreditAmount, StringFormat='{}{0:N0}', Mode=OneWay}" FontWeight="Bold"/>
                            <Run Text="pending credit."/>
                        </TextBlock>
                        <TextBlock Text="Collect previous dues before extending more credit." FontSize="10" Foreground="#991B1B" Opacity="0.8" Margin="0,1,0,0"/>

                        <!-- Specific Bill Due info (no buttons - they're in the action strip above) -->
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,0"
                                    Visibility="{Binding PreviewHistoryBill, Converter={StaticResource NullToVis}}">
                            <TextBlock Text="Selected Bill Due: " FontSize="10" Foreground="#DC2626" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding PreviewHistoryBill.RemainingAmount, StringFormat='Rs. {0:N0}', Mode=OneWay}" FontSize="11" Foreground="#DC2626" FontWeight="Black"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>


            <!-- Search & Barcode -->
            <Border DockPanel.Dock="Top" Style="{DynamicResource CardBorder}" Padding="8,3" Margin="0,0,0,4">
                <StackPanel>
                    <!-- Search Product -->
                    <TextBlock Text="Search Product" FontSize="10" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,1"/>
                    <ComboBox Style="{DynamicResource ModernComboBox}"
                              ItemsSource="{Binding FilteredItemList}"
                              SelectedItem="{Binding SelectedSearchItem}"
                              TextSearch.TextPath="Description"
                              IsEditable="True"
                              IsTextSearchEnabled="False"
                              Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}"
                              IsDropDownOpen="{Binding IsProductDropDownOpen}"
                              StaysOpenOnEdit="True"
                              helpers:FocusHelper.FixComboBoxSearch="True"
                              Margin="0,0,0,2">
                        <ComboBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding ScanBarcodeCommand}"/>
                            <KeyBinding Key="Down" Command="{Binding NavigateProductSearchCommand}" CommandParameter="Down"/>
                            <KeyBinding Key="Up" Command="{Binding NavigateProductSearchCommand}" CommandParameter="Up"/>
                        </ComboBox.InputBindings>
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Background="Transparent">
                                    <Grid.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" 
                                                      Command="{Binding DataContext.ScanBarcodeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    </Grid.InputBindings>
                                    <TextBlock Text="{Binding Description}"/>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Barcode Input -->
                    <TextBlock Text="Or Scan Barcode" FontSize="10" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,1"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{DynamicResource ModernTextBox}"
                                 Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" Margin="0,0,4,0"
                                 helpers:FocusHelper.NumericOnly="True"
                                 helpers:FocusHelper.SelectAllOnFocus="True"
                                 helpers:FocusHelper.IsFocused="{Binding IsBarcodeFocused}"
                                 x:Name="BarcodeTextBox" Tag="Barcode">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding ScanBarcodeCommand}"/>
                                <KeyBinding Key="F10" Command="{Binding TogglePreviewCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1" Content="🔍 Add" Style="{DynamicResource PrimaryButton}"
                                Command="{Binding ScanBarcodeCommand}" Padding="10,4"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Cart Grid -->
            <Border Style="{DynamicResource CardBorder}" Padding="0">
                <DockPanel>
                    <!-- Cart Header -->
                    <Grid DockPanel.Dock="Top" Margin="10,4,10,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🛒 Shopping Cart" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                             <Button Content="+" Style="{DynamicResource PrimaryButton}" Padding="10,4"
                                     Command="{Binding IncreaseQuantityCommand}" Margin="0,0,2,0" FontSize="11" MinWidth="32"/>
                             <Button Content="-" Style="{DynamicResource AccentButton}" Padding="10,4"
                                     Command="{Binding DecreaseQuantityCommand}" Margin="0,0,2,0" FontSize="11" MinWidth="32"/>
                             <Button Content="Remove" Style="{DynamicResource DangerButton}" Padding="10,4"
                                     Command="{Binding RemoveFromCartCommand}" FontSize="10"/>
                        </StackPanel>
                    </Grid>

                    <DataGrid ItemsSource="{Binding CartItems}"
                              SelectedItem="{Binding SelectedCartItem}"
                              Style="{DynamicResource ModernDataGrid}"
                              ColumnHeaderStyle="{DynamicResource ModernDataGridColumnHeader}"
                              CellStyle="{DynamicResource ModernDataGridCell}"
                              Margin="0,0,0,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="False">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource ModernDataGridRow}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCopied}" Value="True">
                                        <Setter Property="Background" Value="#DCFCE7"/> <!-- Light Green -->
                                        <Setter Property="BorderBrush" Value="#86EFAC"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding FinishCartEditCommand}"/>
                        </DataGrid.InputBindings>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding ItemDescription}" Width="*" MinWidth="150" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="120" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding UnitPrice, StringFormat='Rs.{0:N0}'}" Width="90" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="75" IsReadOnly="False">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMaxQuantity}" Value="True">
                                                <Setter Property="Foreground" Value="#EF4444"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
                                        <Setter Property="helpers:FocusHelper.SelectAllOnFocus" Value="True"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="2,4"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMaxQuantity}" Value="True">
                                                <Setter Property="Foreground" Value="#EF4444"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalPrice, StringFormat='Rs.{0:N0}'}" Width="90" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </DockPanel>

        <!-- Right: Payment Panel -->
        <Border Grid.Row="1" Grid.Column="1" Style="{DynamicResource CardBorder}" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <DockPanel Margin="14" LastChildFill="False">
                    <TextBlock DockPanel.Dock="Top" Text="💵 Payment Details" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8"/>

                    <!-- Sub Total -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                        <TextBlock Text="Sub Total" FontSize="14" Foreground="{DynamicResource SubTextBrush}"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}">
                            <TextBlock.Text>
                                <Binding Path="SubTotal" StringFormat="Rs.{0:N2}"/>
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>
                    <Separator DockPanel.Dock="Top" Background="#E2E8F0" Margin="0,0,0,6"/>
                    <!-- Discount & Tax Row -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Discount (Rs.)" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,6"/>
                            <TextBox Style="{DynamicResource ModernTextBox}"
                                     helpers:FocusHelper.DecimalOnly="True"
                                     helpers:FocusHelper.SelectAllOnFocus="True"
                                     Text="{Binding DiscountText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Tax (Rs.)" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,6"/>
                            <TextBox Style="{DynamicResource ModernTextBox}"
                                     helpers:FocusHelper.DecimalOnly="True"
                                     helpers:FocusHelper.SelectAllOnFocus="True"
                                     Text="{Binding TaxText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Grand Total -->
                    <Border DockPanel.Dock="Top" Background="{DynamicResource PrimaryBrush}" CornerRadius="10" Padding="16,12" Margin="0,0,0,10">
                        <Grid>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="GRAND TOTAL" FontSize="12" Foreground="#CCFFFFFF" FontWeight="SemiBold"/>
                                <TextBlock Text="PKR" FontSize="10" Foreground="#AAFFFFFF"/>
                            </StackPanel>
                            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="24" FontWeight="Bold" Foreground="White">
                                <TextBlock.Text>
                                    <Binding Path="GrandTotal" StringFormat="{}{0:N0}"/>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Payment Method -->
                    <TextBlock DockPanel.Dock="Top" Text="Payment Method" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                    <ComboBox DockPanel.Dock="Top" ItemsSource="{Binding PaymentMethods}" SelectedItem="{Binding SelectedPaymentMethod}"
                              FontSize="14" Padding="10,8" Margin="0,0,0,6"/>

                    <!-- Online Account Selection (visible only when Online is selected) -->
                    <StackPanel DockPanel.Dock="Top"
                                Visibility="{Binding IsOnlinePayment, Converter={StaticResource BoolToVis}}"
                                Margin="0,0,0,10">
                        <TextBlock Text="🏢 Select Payment Account" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding ActiveAccounts}"
                                  SelectedItem="{Binding SelectedAccount}"
                                  FontSize="14" Padding="10,4"
                                  x:Name="AccountComboBox">
                            <ComboBox.Style>
                                <Style TargetType="ComboBox" BasedOn="{StaticResource ModernComboBox}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedAccount}" Value="{x:Null}">
                                            <Setter Property="BorderBrush" Value="#F59E0B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.Style>
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="2">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13"/>
                                        <StackPanel Orientation="Horizontal" Opacity="0.7">
                                            <TextBlock Text="{Binding AccountType}" FontSize="10" FontWeight="Bold"/>
                                            <TextBlock Text=" • " FontSize="10"/>
                                            <TextBlock Text="{Binding BankName}" FontSize="10" Visibility="{Binding BankName, Converter={StaticResource StringToVis}}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="⚠ Required: Select an account to receive payment"
                                   FontSize="10" Foreground="#F59E0B" Margin="0,3,0,0"
                                   Visibility="{Binding SelectedAccount, Converter={StaticResource NullToVis}}"/>
                    </StackPanel>


                    <!-- Amount Received -->
                    <TextBlock DockPanel.Dock="Top" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Cash Received (Rs.)"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCashPayment}" Value="False">
                                        <Setter Property="Text" Value="Amount Received (Rs.)"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBox DockPanel.Dock="Top" Style="{DynamicResource ModernTextBox}" FontSize="16" FontWeight="Bold"
                             helpers:FocusHelper.DecimalOnly="True"
                             helpers:FocusHelper.SelectAllOnFocus="True"
                             helpers:FocusHelper.FocusTrigger="{Binding FocusCashReceived}"
                             IsEnabled="{Binding IsAmountEditable}"
                             Text="{Binding CashReceivedText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>


                    <!-- Change -->
                    <Border DockPanel.Dock="Top" CornerRadius="10" Padding="16,12" Margin="0,0,0,10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{Binding ChangeDisplayBrush}"/>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{Binding ChangeDisplayLabel}" FontSize="13" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" HorizontalAlignment="Right" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"
                                       Visibility="{Binding IsChangeAmountVisible, Converter={StaticResource BoolToVis}}">
                                <TextBlock.Text>
                                    <Binding Path="ChangeAmountAbs" StringFormat="Rs.{0:N0}"/>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Status -->
                    <TextBlock DockPanel.Dock="Top" Text="{Binding StatusMessage}" FontSize="12" FontWeight="Medium"
                               Foreground="{Binding StatusMessage, Converter={StaticResource StatusColorConverter}}" TextWrapping="Wrap" Margin="0,0,0,4"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               Visibility="{Binding StatusMessage, Converter={StaticResource StringToVis}}"/>

                    <!-- Buttons -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,0">
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{DynamicResource PrimaryButton}"
                                    Command="{Binding CompleteSaleCommand}" Padding="0,16" MinHeight="50"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                <TextBlock Text="Complete Sale"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           TextTrimming="CharacterEllipsis"/>
                            </Button>
                            <Button Grid.Column="2" Content="Preview" Style="{DynamicResource AccentButton}"
                                    ToolTip="Toggle Bill Preview (F10)"
                                    Command="{Binding TogglePreviewCommand}" Padding="14,0" FontSize="14" FontWeight="SemiBold" MinHeight="48"/>
                        </Grid>
                        <Button Content="🗑️ Clear Cart" Command="{Binding ClearCartCommand}" Padding="0,12" FontSize="13" FontWeight="SemiBold" MinHeight="44">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                    <Setter Property="Foreground" Value="#EF4444"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </ScrollViewer>
        </Border>

        <!-- Right Column 2: Virtual Receipt Preview (Professional Drawer Look) -->
        <Border Grid.Row="1" Grid.Column="2" Width="300" Margin="20,0,0,0" 
                Visibility="{Binding IsPreviewVisible, Converter={StaticResource BoolToVis}}"
                Background="White" CornerRadius="16" UseLayoutRounding="True" SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.12" Color="#000000"/>
            </Border.Effect>
            
            <DockPanel>
                <!-- Preview Header -->
                <Grid DockPanel.Dock="Top" Margin="20,16">
                    <TextBlock Text="Receipt Preview" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}"/>
                    <Button Content="X" HorizontalAlignment="Right" VerticalAlignment="Center" 
                            Background="Transparent" BorderThickness="0" Foreground="{DynamicResource SubTextBrush}"
                            Command="{Binding TogglePreviewCommand}" Cursor="Hand" FontSize="14">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <Separator DockPanel.Dock="Top" Background="#F1F5F9" Margin="0" Height="1"/>

                <!-- The "Paper" Receipt — matches PrintService thermal output -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                    <StackPanel Background="White" TextElement.FontFamily="Consolas">

                        <!-- Store Header -->
                        <TextBlock Text="{Binding StoreName}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#1E293B"/>
                        <TextBlock Text="{Binding StoreAddress}" FontSize="9" HorizontalAlignment="Center" Foreground="#64748B" Margin="0,3"/>
                        <TextBlock Text="{Binding StorePhone, StringFormat='Ph: {0}'}" FontSize="9" HorizontalAlignment="Center" Foreground="#64748B"/>

                        <TextBlock Text="--------------------------------------------" FontSize="8" HorizontalAlignment="Center" Foreground="#CBD5E1" Margin="0,8"/>

                        <!-- Bill Info -->
                        <TextBlock FontSize="9" FontWeight="Bold" Foreground="#1E293B">
                            <Run Text="Receipt#: "/><Run Text="{Binding InvoiceNumber, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock FontSize="9" Foreground="#334155" Margin="0,2">
                            <Run Text="Customer: "/><Run Text="{Binding CustomerDisplayName, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock FontSize="9" Foreground="#334155" Margin="0,2"
                                   Visibility="{Binding SelectedBillingAddress, Converter={StaticResource StringToVis}}">
                            <Run Text="Address: "/><Run Text="{Binding SelectedBillingAddress, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock FontSize="9" Foreground="#334155" Margin="0,2">
                            <Run Text="Date: "/><Run Text="{Binding CurrentTime, StringFormat='{}{0:dd MMM yyyy  HH:mm}', Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock FontSize="9" Foreground="#334155" Margin="0,2">
                            <Run Text="Cashier: "/><Run Text="{Binding CashierName, Mode=OneWay}"/>
                        </TextBlock>

                        <!-- Items Header -->
                        <TextBlock Text="--------------------------------------------" FontSize="8" HorizontalAlignment="Center" Foreground="#CBD5E1" Margin="0,8"/>
                        <Grid Margin="0,2,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="45"/>
                                <ColumnDefinition Width="55"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Item" FontSize="9" FontWeight="Bold" Foreground="#64748B"/>
                            <TextBlock Grid.Column="1" Text="Qty" FontSize="9" FontWeight="Bold" Foreground="#64748B" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="Price" FontSize="9" FontWeight="Bold" Foreground="#64748B" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="Total" FontSize="9" FontWeight="Bold" Foreground="#64748B" HorizontalAlignment="Right"/>
                        </Grid>
                        <TextBlock Text="--------------------------------------------" FontSize="8" HorizontalAlignment="Center" Foreground="#CBD5E1" Margin="0,2"/>

                        <!-- Items List -->
                        <ItemsControl ItemsSource="{Binding CartItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="45"/>
                                            <ColumnDefinition Width="55"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding ItemDescription}" FontSize="9" Foreground="#1E293B" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Quantity}" FontSize="9" Foreground="#1E293B" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                        <TextBlock Grid.Column="2" Text="{Binding UnitPrice, StringFormat='{}{0:N0}'}" FontSize="9" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                        <TextBlock Grid.Column="3" Text="{Binding TotalPrice, StringFormat='{}{0:N0}'}" FontSize="9" Foreground="#1E293B" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="SemiBold"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Totals -->
                        <TextBlock Text="--------------------------------------------" FontSize="8" HorizontalAlignment="Center" Foreground="#CBD5E1" Margin="0,8"/>

                        <Grid Margin="0,3">
                            <TextBlock Text="Sub Total:" FontSize="9" FontWeight="Bold" Foreground="#1E293B"/>
                            <TextBlock Text="{Binding SubTotal, StringFormat='Rs.{0:N2}'}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Right" Foreground="#1E293B"/>
                        </Grid>
                        <Grid Margin="0,2">
                            <TextBlock Text="Discount:" FontSize="9" Foreground="#334155"/>
                            <TextBlock Text="{Binding DiscountAmount, StringFormat='-Rs.{0:N2}'}" FontSize="9" HorizontalAlignment="Right" Foreground="#EF4444"/>
                        </Grid>
                        <Grid Margin="0,2" Visibility="{Binding PreviewShowTax, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Tax:" FontSize="9" Foreground="#334155"/>
                            <TextBlock Text="{Binding TaxAmount, StringFormat='Rs.{0:N2}'}" FontSize="9" HorizontalAlignment="Right" Foreground="#1E293B"/>
                        </Grid>

                        <TextBlock Text="===========================================" FontSize="8" HorizontalAlignment="Center" Foreground="#94A3B8" Margin="0,5"/>

                        <Grid Margin="0,3">
                            <TextBlock Text="GRAND TOTAL:" FontSize="11" FontWeight="Bold" Foreground="#1E293B"/>
                            <TextBlock Text="{Binding GrandTotal, StringFormat='Rs.{0:N2}'}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right" Foreground="#1E293B"/>
                        </Grid>

                        <!-- Payment Info -->
                        <Grid Margin="0,8,0,2">
                            <TextBlock Text="Payment:" FontSize="9" Foreground="#334155"/>
                            <TextBlock Text="{Binding SelectedPaymentMethod}" FontSize="9" HorizontalAlignment="Right" Foreground="#1E293B"/>
                        </Grid>
                        <Grid Margin="0,2" Visibility="{Binding PreviewHasCashReceived, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Cash Received:" FontSize="9" Foreground="#334155"/>
                            <TextBlock Text="{Binding PreviewCashReceived, StringFormat='Rs.{0:N2}'}" FontSize="9" HorizontalAlignment="Right" Foreground="#1E293B"/>
                        </Grid>
                        <Grid Margin="0,2" Visibility="{Binding PreviewHasCashReceived, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Change:" FontSize="9" Foreground="#334155"/>
                            <TextBlock Text="{Binding PreviewChange, StringFormat='Rs.{0:N2}'}" FontSize="9" HorizontalAlignment="Right" Foreground="#1E293B"/>
                        </Grid>

                        <!-- Due Amount (credit sales) -->
                        <StackPanel Visibility="{Binding PreviewHasDue, Converter={StaticResource BoolToVis}}" Margin="0,6,0,0">
                            <Grid Margin="0,2">
                                <TextBlock Text="Paid Amount:" FontSize="9" FontWeight="Bold" Foreground="#059669"/>
                                <TextBlock Text="{Binding PreviewPaidAmount, StringFormat='Rs.{0:N2}'}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Right" Foreground="#059669"/>
                            </Grid>
                            <Grid Margin="0,2">
                                <TextBlock Text="DUE AMOUNT:" FontSize="9" FontWeight="Bold" Foreground="#DC2626"/>
                                <TextBlock Text="{Binding PreviewDueAmount, StringFormat='Rs.{0:N2}'}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Right" Foreground="#DC2626"/>
                            </Grid>
                        </StackPanel>

                        <!-- Footer -->
                        <TextBlock Text="--------------------------------------------" FontSize="8" HorizontalAlignment="Center" Foreground="#CBD5E1" Margin="0,12,0,0"/>
                        <TextBlock Text="Thank you for shopping!" FontSize="9" HorizontalAlignment="Center" Foreground="#64748B" Margin="0,6"/>
                        <TextBlock Text="Please come again" FontSize="8" HorizontalAlignment="Center" Foreground="#94A3B8" Margin="0,3,0,10"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
        
        <!-- Registration Overlay -->
        <Grid Background="#44000000" Grid.ColumnSpan="3" Grid.RowSpan="2" Panel.ZIndex="1000"
              Visibility="{Binding IsRegistrationVisible, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
            <Border Width="400" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Style="{DynamicResource CardBorder}" Padding="24">
                <StackPanel>
                    <TextBlock Text="📝 Register New Customer" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Full Name *" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Style="{DynamicResource ModernTextBox}" Text="{Binding NewCustomerName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <TextBlock Text="Phone Number *" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Style="{DynamicResource ModernTextBox}" Text="{Binding NewCustomerPhone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" helpers:FocusHelper.NumericOnly="True"/>

                    <TextBlock Text="Phone Number 2 (Optional)" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Style="{DynamicResource ModernTextBox}" Text="{Binding NewCustomerSecondaryPhone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" helpers:FocusHelper.NumericOnly="True"/>

                    <TextBlock Text="Address 1 (Optional)" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Style="{DynamicResource ModernTextBox}" Text="{Binding NewCustomerAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                    <TextBlock Text="Address 2 (Optional)" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Style="{DynamicResource ModernTextBox}" Text="{Binding NewCustomerAddress2, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                    <TextBlock Text="Address 3 (Optional)" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Style="{DynamicResource ModernTextBox}" Text="{Binding NewCustomerAddress3, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <!-- Error Message Display -->
                    <TextBlock Text="{Binding RegistrationErrorMessage}" Foreground="#EF4444" 
                               FontSize="12" FontWeight="Bold" Margin="0,0,0,12"
                               TextWrapping="Wrap"
                               Visibility="{Binding RegistrationErrorMessage, Converter={StaticResource StringToVis}}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Cancel" Style="{StaticResource DangerButton}" Command="{Binding ToggleRegistrationCommand}" Padding="0,12"/>
                        <Button Grid.Column="2" Content="Save Customer" Style="{StaticResource PrimaryButton}" Command="{Binding SaveNewCustomerCommand}" Padding="0,12"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ FULL SCREEN PAYMENT OVERLAY ═══ -->
        <Border Grid.ColumnSpan="3" Grid.RowSpan="2" Panel.ZIndex="1000" IsHitTestVisible="True"
                Visibility="{Binding IsHistoryPaymentOpen, Converter={StaticResource BoolToVis}}"
                Background="#80000000">
            <Border Background="#1E293B" CornerRadius="16" Padding="28,24"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MinWidth="420" MaxWidth="500"
                    BorderBrush="#334155" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="💳 Record Payment" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                    <TextBlock Foreground="#94A3B8" FontSize="13" Margin="0,0,0,20">
                        <Run Text="Bill #"/><Run Text="{Binding PreviewHistoryBill.InvoiceNumber, FallbackValue='00000', Mode=OneWay}"/>
                        <Run Text="  |  Remaining: Rs."/><Run Text="{Binding PreviewHistoryBill.RemainingAmount, StringFormat='{}{0:N0}', FallbackValue='0', Mode=OneWay}" Foreground="#EF4444" FontWeight="SemiBold"/>
                    </TextBlock>

                    <TextBlock Text="Payment Amount (Rs.)" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding HistoryPaymentAmount, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#0F172A" Foreground="White" FontSize="22" FontWeight="Bold"
                                 Padding="12,10" BorderBrush="#334155" BorderThickness="1" CaretBrush="White"
                                 helpers:FocusHelper.DecimalOnly="True"
                                 helpers:FocusHelper.IsFocused="{Binding IsHistoryPaymentOpen}"/>
                        <Button Grid.Column="1" Content="Pay Full" Command="{Binding PayFullHistoryCommand}"
                                Foreground="#60A5FA" Background="#334155" Padding="12,10" Margin="8,0,0,0"
                                BorderThickness="1" BorderBrush="#475569" FontSize="12" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}"
                                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Payment Method Selection -->
                    <TextBlock Text="Payment Method" Foreground="#1E293B" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding PaymentMethods}" SelectedItem="{Binding SelectedHistoryPaymentMethod}"
                              FontSize="13" Padding="10,8" Margin="0,0,0,12" Foreground="#1E293B" Background="#F1F5F9" BorderBrush="#CBD5E1"/>

                    <!-- Online Account Selection (visible only when Online is selected) -->
                    <StackPanel Visibility="{Binding IsHistoryOnlinePayment, Converter={StaticResource BoolToVis}}" Margin="0,0,0,10">
                        <TextBlock Text="🏢 Select Payment Account" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#1E293B" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding HistoryActiveAccounts}"
                                  SelectedItem="{Binding SelectedHistoryAccount}"
                                  FontSize="13" Padding="10,8" Margin="0,0,0,8"
                                  Foreground="#1E293B" Background="#F1F5F9" BorderBrush="#CBD5E1">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="12" Foreground="#1E293B"/>
                                        <TextBlock Text="{Binding AccountType}" FontSize="10" Foreground="#64748B" Opacity="0.9"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="⚠ Required: Select an account to receive payment"
                                   FontSize="10" Foreground="#DC2626" FontWeight="SemiBold" Margin="0,3,0,8"
                                   Visibility="{Binding SelectedHistoryAccount, Converter={StaticResource NullToVis}}"/>
                    </StackPanel>

                    <TextBlock Text="Note (Optional)" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding HistoryPaymentNote, UpdateSourceTrigger=PropertyChanged}"
                             Background="#0F172A" Foreground="White" FontSize="14"
                             Padding="12,10" Margin="0,0,0,20"
                             BorderBrush="#334155" BorderThickness="1" CaretBrush="White"/>

                    <!-- Error -->
                    <TextBlock Text="{Binding HistoryPaymentError}" Foreground="#F87171" FontSize="12"
                               Margin="0,0,0,16" TextWrapping="Wrap"
                               Visibility="{Binding HistoryPaymentError, Converter={StaticResource StringToVis}}"/>

                    <!-- Buttons -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Cancel" Command="{Binding CloseHistoryPaymentCommand}"
                                Foreground="#94A3B8" Background="#334155" Padding="0,12"
                                BorderBrush="#475569" BorderThickness="1" FontSize="14" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}"
                                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Grid.Column="2" Content="✓ Record Payment" Command="{Binding RecordHistoryPaymentCommand}"
                                Foreground="White" Background="#22C55E" Padding="0,12"
                                BorderThickness="0" FontSize="14" FontWeight="Bold" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- ═══ FULL SCREEN BILL DETAIL OVERLAY ═══ -->
        <Border Grid.ColumnSpan="3" Grid.RowSpan="2" Panel.ZIndex="2000" IsHitTestVisible="True"
                Visibility="{Binding IsBillDetailOpen, Converter={StaticResource BoolToVis}}"
                Background="#80000000">
            <Border Background="White" CornerRadius="16" Padding="0"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Width="400" MaxHeight="800"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <DockPanel>
                    <!-- Header with Close -->
                    <Border DockPanel.Dock="Top" Background="#F8FAFC" Padding="20,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Bill Details" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}"/>
                            <Button Grid.Column="1" Content="🖨️ Reprint" Style="{DynamicResource PrimaryButton}"
                                    Command="{Binding PrintBillCommand}" Padding="12,6" FontSize="12" Margin="0,0,10,0"/>
                            <Button Grid.Column="2" Content="X" VerticalAlignment="Center" 
                                    Background="Transparent" BorderThickness="0" Foreground="#64748B"
                                    Command="{Binding CloseBillDetailCommand}" Cursor="Hand" FontSize="18"/>
                        </Grid>
                    </Border>

                    <!-- Shared Receipt Control -->
                    <controls:BillReceiptControl Bill="{Binding PreviewHistoryBill}"/>
                </DockPanel>
            </Border>
        </Border>

        <!-- ═══ SYSTEM ERROR OVERLAY (OUT OF STOCK) ═══ -->
        <Border Grid.ColumnSpan="3" Grid.RowSpan="2" Panel.ZIndex="3000" IsHitTestVisible="False"
                VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,40,0,0"
                Visibility="{Binding SystemErrorVisible, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
            <Border Background="White" CornerRadius="8" Padding="20,12"
                    BorderBrush="#EF4444" BorderThickness="2">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.15" Color="Black"/>
                </Border.Effect>
                <TextBlock Text="{Binding SystemErrorMessage}" 
                           Foreground="#EF4444" FontSize="20" FontWeight="Bold" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
        </Border>

        <!-- ═══ POPUP ERROR OVERLAY ═══ -->
        <Border Grid.ColumnSpan="3" Grid.RowSpan="2" Panel.ZIndex="3001" IsHitTestVisible="False"
                VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,40,0,0"
                Visibility="{Binding PopupErrorVisible, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
            <Border Background="White" CornerRadius="8" Padding="20,12"
                    BorderBrush="#EF4444" BorderThickness="2">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.15" Color="Black"/>
                </Border.Effect>
                <TextBlock Text="{Binding PopupErrorMessage}" 
                           Foreground="#EF4444" FontSize="20" FontWeight="Bold" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
        </Border>

    </Grid>
</UserControl>
