<UserControl x:Class="GroceryPOS.Views.Controls.BarChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Canvas x:Name="ChartCanvas" ClipToBounds="True"/>
        <!-- Empty state -->
        <TextBlock x:Name="EmptyLabel" Text="No data for selected period"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="13" Foreground="#94A3B8" Visibility="Collapsed"/>
    </Grid>
</UserControl>
