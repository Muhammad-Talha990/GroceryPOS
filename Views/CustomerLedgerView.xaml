<UserControl x:Class="GroceryPOS.Views.CustomerLedgerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GroceryPOS.Converters"
             xmlns:controls="clr-namespace:GroceryPOS.Views.Controls"
             xmlns:helpers="clr-namespace:GroceryPOS.Helpers"
             Background="{DynamicResource BgBrush}" FontFamily="{DynamicResource AppFont}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <BooleanToVisibilityConverter x:Key="WpfBoolToVis"/>
        <converters:StringToVisibilityConverter x:Key="StringToVis"/>
        <converters:PaymentStatusColorConverter x:Key="PayStatusColor"/>
        <converters:NumericToVisibilityConverter x:Key="NumericToVisibilityConverter"/>
        <converters:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter"/>
        <converters:CountToVisibilityConverter x:Key="InverseCountToVis" Inverse="True"/>
    </UserControl.Resources>

    <Grid Margin="28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="← Back" Command="{Binding GoBackCommand}"
                    Foreground="{DynamicResource PrimaryBrush}" Background="Transparent" BorderThickness="0"
                    FontSize="14" Cursor="Hand" VerticalAlignment="Center" Margin="0,0,16,0"/>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextBrush}">
                    <Run Text="📒 Customer Ledger —"/>
                    <Run Text="{Binding Customer.FullName, FallbackValue='—'}" Foreground="{DynamicResource PrimaryBrush}"/>
                </TextBlock>
                <TextBlock FontSize="12" Foreground="{DynamicResource SubTextBrush}" Margin="0,3,0,0">
                    <Run Text="Phone:"/><Run Text=" "/><Run Text="{Binding Customer.PrimaryPhone, FallbackValue='—'}"/>
                    <Run Text="  |  Since:"/><Run Text=" "/><Run Text="{Binding Customer.CreatedAt, StringFormat=yyyy-MM-dd, FallbackValue='—'}"/>
                </TextBlock>
            </StackPanel>

            <Button Grid.Column="2" Content="🔄 Refresh" Command="{Binding RefreshCommand}"
                    Style="{DynamicResource ModernButton}"
                    Background="{DynamicResource SidebarBgBrush}" Foreground="White" FontSize="13"
                    Padding="14,8" Cursor="Hand" BorderThickness="0" VerticalAlignment="Center">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- ═══ SUMMARY CARDS ═══ -->
        <Border Grid.Row="1" Style="{DynamicResource CardBorder}" Padding="20,16" Margin="0,0,0,16" Background="{DynamicResource SidebarBgBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Credit Given -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="Total Credit Given" Foreground="White" Opacity="0.8" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalCredit, StringFormat='Rs. {0:N0}'}" Foreground="White"
                               FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Total Paid -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="Total Paid" Foreground="White" Opacity="0.8" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalPaid, StringFormat='Rs. {0:N0}'}" Foreground="{DynamicResource SuccessBrush}"
                               FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Total Pending -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="Total Pending" Foreground="White" Opacity="0.8" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBlock Foreground="{DynamicResource DangerBrush}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0">
                        <TextBlock.Text>
                            <Binding Path="TotalPending" StringFormat="Rs. {0:N0}"/>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ LEDGER TABLE ═══ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Main Ledger Table -->
            <Border Style="{DynamicResource CardBorder}" Padding="0" Margin="0,0,12,0">
                <DataGrid ItemsSource="{Binding LedgerEntries}"
                          SelectedItem="{Binding SelectedBill}"
                          Style="{DynamicResource ModernDataGrid}">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ModernDataGridColumnHeader}">
                            <Setter Property="Background" Value="{DynamicResource SidebarBgBrush}"/>
                            <Setter Property="Foreground" Value="#94A3B8"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource ModernDataGridRow}">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource ModernDataGridCell}">
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding CreatedAt, StringFormat='dd/MM/yy HH:mm'}" Width="150" IsReadOnly="True"/>

                        <DataGridTextColumn Header="Invoice" Binding="{Binding InvoiceNumber}" Width="100" IsReadOnly="True">
                             <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Total Amount" Binding="{Binding GrandTotal, StringFormat='Rs. {0:N0}'}" Width="120" IsReadOnly="True">
                             <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#3B82F6"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Paid" Binding="{Binding PaidAmount, StringFormat='Rs. {0:N0}'}" Width="100" IsReadOnly="True">
                             <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#22C55E"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Returned" Binding="{Binding ReturnedAmount, StringFormat='Rs. {0:N0}'}" Width="100" IsReadOnly="True">
                             <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#F59E0B"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Balance" Binding="{Binding RemainingAmount, StringFormat='Rs. {0:N0}'}" Width="120" IsReadOnly="True">
                             <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RemainingAmount, Converter={StaticResource GreaterThanZeroConverter}}" Value="True">
                                             <Setter Property="Foreground" Value="#EF4444"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RemainingAmount, Converter={StaticResource GreaterThanZeroConverter}}" Value="False">
                                             <Setter Property="Foreground" Value="#22C55E"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Width="240" Header="Actions">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="8,4">
                                        <!-- PAY BUTTON -->
                                        <Button Content="💳 Pay" 
                                                Command="{Binding DataContext.OpenPaymentPanelCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Record a payment for this bill"
                                                Background="Transparent" Foreground="#22C55E" BorderThickness="0" 
                                                Cursor="Hand" Padding="4,2" Margin="0,0,12,0"
                                                Visibility="{Binding HasPendingCredit, Converter={StaticResource WpfBoolToVis}}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontSize="12"/>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <!-- PRINT BUTTON -->
                                        <Button Content="🖨 Print" 
                                                Command="{Binding DataContext.PrintBillCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Reprint this bill"
                                                Background="Transparent" Foreground="#94A3B8" BorderThickness="0" 
                                                Cursor="Hand" Padding="4,2" Margin="0,0,12,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontSize="12"/>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <!-- VIEW DETAIL BUTTON -->
                                        <Button Content="View Detail" 
                                                Command="{Binding DataContext.ViewBillCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" Foreground="#3B82F6" BorderThickness="0" 
                                                Cursor="Hand" Padding="4,2">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontSize="12"/>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Payment History Breakdown Panel (Right) -->
            <Border Grid.Column="1" Width="300" Style="{DynamicResource CardBorder}" Padding="16" Background="{DynamicResource SidebarBgBrush}"
                    Visibility="{Binding HasSelectedBill, Converter={StaticResource WpfBoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,4">
                        <TextBlock Text="💳 History — Bill Details" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        <Button Content="X" Command="{Binding CloseSidebarCommand}" 
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="Transparent" Foreground="#64748B" FontSize="16"
                                BorderThickness="0" Cursor="Hand" Padding="5"/>
                    </Grid>
                    <TextBlock Grid.Row="1" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,16">
                        <Run Text="Invoice #"/><Run Text="{Binding SelectedBill.InvoiceNumber, Mode=OneWay}" Foreground="White" FontWeight="SemiBold"/>
                    </TextBlock>

                    <!-- Bill Quick Summary -->
                    <Border Grid.Row="2" Background="#0F172A" CornerRadius="8" Padding="12" Margin="0,0,0,16" BorderBrush="#334155" BorderThickness="1">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Total Invoice" Foreground="#94A3B8" FontSize="11"/>
                                <TextBlock Text="{Binding SelectedBill.GrandTotal, StringFormat='Rs. {0:N0}'}" HorizontalAlignment="Right" Foreground="#60A5FA" FontSize="11" FontWeight="SemiBold"/>
                            </Grid>
                            <Grid Margin="0,0,0,6" Visibility="{Binding SelectedBill.ReturnedAmount, Converter={StaticResource NumericToVisibilityConverter}}">
                                <TextBlock Text="(-) Returns" Foreground="#94A3B8" FontSize="11"/>
                                <TextBlock Text="{Binding SelectedBill.ReturnedAmount, StringFormat='Rs. {0:N0}'}" HorizontalAlignment="Right" Foreground="#F59E0B" FontSize="11" FontWeight="SemiBold"/>
                            </Grid>
                            <Border BorderBrush="#334155" BorderThickness="0,1,0,0" Margin="0,4" 
                                    Visibility="{Binding SelectedBill.ReturnedAmount, Converter={StaticResource NumericToVisibilityConverter}}"/>
                            <Grid Margin="0,0,0,6" Visibility="{Binding SelectedBill.ReturnedAmount, Converter={StaticResource NumericToVisibilityConverter}}">
                                <TextBlock Text="Net Payable" Foreground="#94A3B8" FontSize="11"/>
                                <TextBlock Text="{Binding SelectedBill.NetTotal, StringFormat='Rs. {0:N0}'}" HorizontalAlignment="Right" Foreground="White" FontSize="11" FontWeight="Bold"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="(-) Total Paid" Foreground="#94A3B8" FontSize="11"/>
                                <TextBlock Text="{Binding SelectedBill.PaidAmount, StringFormat='Rs. {0:N0}'}" HorizontalAlignment="Right" Foreground="#22C55E" FontSize="11" FontWeight="SemiBold"/>
                            </Grid>
                            <Border BorderBrush="#334155" BorderThickness="0,1,0,0" Margin="0,4"/>
                            <Grid>
                                <TextBlock Text="Final Balance" Foreground="#94A3B8" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Text="{Binding SelectedBill.RemainingAmount, StringFormat='Rs. {0:N0}'}" HorizontalAlignment="Right" Foreground="#EF4444" FontSize="14" FontWeight="Black"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Row="3" Text="Bill Timeline" Foreground="#94A3B8" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <DataGrid Grid.Row="3" ItemsSource="{Binding Timeline}"
                               AutoGenerateColumns="False" IsReadOnly="True"
                               Background="Transparent" BorderThickness="0"
                               RowBackground="Transparent"
                               Foreground="White" FontSize="11" HeadersVisibility="Column"
                               VerticalScrollBarVisibility="Auto" Margin="0,25,0,0">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                                <Setter Property="FontSize" Value="10"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="0,0,0,8"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#334155"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1E293B"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="TYPE" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding TypeColor}" CornerRadius="3" Padding="4,1" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Type}" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                            <DataGridTextColumn Header="DETAILS" Binding="{Binding Description}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="AMOUNT" Binding="{Binding Amount, StringFormat='N0'}" Width="70">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty State -->
                    <TextBlock Grid.Row="3" Text="No events found." 
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#475569" FontSize="12" FontStyle="Italic"
                               Visibility="{Binding Timeline.Count, Converter={StaticResource InverseCountToVis}}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ STATUS ═══ -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="#94A3B8" FontSize="13" Margin="0,10,0,0"/>

        <!-- ═══ PAYMENT PANEL OVERLAY ═══ -->
        <Border Grid.RowSpan="5"
                Visibility="{Binding IsPaymentPanelOpen, Converter={StaticResource WpfBoolToVis}}"
                Background="#80000000" IsHitTestVisible="True">
            <Border Background="#1E293B" CornerRadius="16" Padding="28,24"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MinWidth="400" MaxWidth="480"
                    BorderBrush="#334155" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="💳 Record Payment" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                    <TextBlock Foreground="#94A3B8" FontSize="13" Margin="0,0,0,16">
                        <Run Text="Bill #"/><Run Text="{Binding SelectedBill.InvoiceNumber, FallbackValue='-', Mode=OneWay}"/>
                        <Run Text="  |  Remaining: Rs."/><Run Text="{Binding SelectedBillRemaining, StringFormat='{}{0:N0}', FallbackValue='0', Mode=OneWay}" Foreground="#EF4444" FontWeight="SemiBold"/>
                    </TextBlock>

                    <TextBlock Text="Payment Amount" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Auto-focused textbox that only accepts decimals to prevent bad inputs during ledger payment -->
                        <TextBox Grid.Column="0" Text="{Binding PaymentAmountText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#0F172A" Foreground="White" FontSize="16" FontWeight="SemiBold"
                                 Padding="10,8" BorderBrush="#334155" BorderThickness="1" CaretBrush="White"
                                 helpers:FocusHelper.IsFocused="{Binding IsPaymentPanelOpen}"
                                 helpers:FocusHelper.DecimalOnly="True"/>
                        <Button Grid.Column="1" Content="Pay Full" Command="{Binding PayFullRemainingCommand}"
                                Foreground="#60A5FA" Background="#334155" Padding="10,8" Margin="8,0,0,0"
                                BorderThickness="0" FontSize="12" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <TextBlock Text="Note (Optional)" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PaymentNote, UpdateSourceTrigger=PropertyChanged}"
                             Background="#0F172A" Foreground="White" FontSize="13"
                             Padding="10,8" Margin="0,0,0,14"
                             BorderBrush="#334155" BorderThickness="1" CaretBrush="White"/>

                    <!-- Error -->
                    <TextBlock Text="{Binding PaymentError}" Foreground="#F87171" FontSize="12"
                               Margin="0,0,0,10" TextWrapping="Wrap"
                               Visibility="{Binding PaymentError, Converter={StaticResource StringToVis}}"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                        <Button Content="Cancel" Command="{Binding ClosePaymentPanelCommand}"
                                Foreground="#94A3B8" Background="#334155" Padding="16,8" Margin="0,0,10,0"
                                BorderThickness="0" FontSize="13" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="✓ Record Payment" Command="{Binding RecordPaymentCommand}"
                                Foreground="White" Background="#22C55E" Padding="16,8"
                                BorderThickness="0" FontSize="13" FontWeight="SemiBold" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.RowSpan="5" Visibility="{Binding IsBillDetailOpen, Converter={StaticResource WpfBoolToVis}}" 
                Background="#CC0F172A" IsHitTestVisible="True" Panel.ZIndex="2000">
            <Border Background="#F1F5F9" CornerRadius="12" Padding="0"
                    VerticalAlignment="Center" HorizontalAlignment="Center" 
                    Width="850" MaxHeight="850"
                    BorderBrush="#CBD5E1" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="50" ShadowDepth="0" Opacity="0.4" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="White" CornerRadius="12,12,0,0" Padding="25,20" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Invoice Audit History" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <TextBlock Text="Invoice #: " Foreground="#64748B" FontSize="13"/>
                                    <TextBlock Text="{Binding SelectedBill.InvoiceNumber}" Foreground="#1E293B" FontSize="13" FontWeight="Bold" Margin="0,0,20,0"/>
                                    <TextBlock Text="Date: " Foreground="#64748B" FontSize="13"/>
                                    <TextBlock Text="{Binding SelectedBill.CreatedAt, StringFormat='dd MMM yyyy, HH:mm'}" Foreground="#1E293B" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" VerticalAlignment="Top" Content="✕" 
                                    Background="Transparent" Foreground="#64748B" FontSize="20"
                                    BorderThickness="0" Cursor="Hand" Padding="10"
                                    Command="{Binding CloseBillDetailCommand}"/>
                        </Grid>
                    </Border>

                    <!-- Content (Scrollable for large audit trails) -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="25">
                        <StackPanel>
                            <!-- Section 1: 🛒 Items Sold -->
                            <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,20" BorderBrush="#E2E8F0" BorderThickness="1">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <TextBlock Text="🛒 Original Items Sold" FontSize="15" FontWeight="Bold" Foreground="#0F172A"/>
                                        <TextBlock Text="{Binding SelectedBill.GrandTotal, StringFormat='Total Sale Value: Rs.{0:N0}'}" 
                                                   HorizontalAlignment="Right" Foreground="#1E293B" FontWeight="Bold"/>
                                    </Grid>
                                    <DataGrid ItemsSource="{Binding SelectedBill.Items}" AutoGenerateColumns="False" 
                                              HeadersVisibility="Column" IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Product Description" Binding="{Binding ItemDescription}" Width="*"/>
                                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="60"/>
                                            <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat='N0'}" Width="80"/>
                                            <DataGridTextColumn Header="Total" Binding="{Binding TotalPrice, StringFormat='N0'}" Width="80">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <!-- Section 2: 💵 Payment History -->
                            <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,20" BorderBrush="#E2E8F0" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="💵 Payment &amp; Installment History" FontSize="15" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,10"/>
                                    <DataGrid ItemsSource="{Binding SelectedBill.PaymentLogs}" AutoGenerateColumns="False" 
                                              HeadersVisibility="Column" IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Date" Binding="{Binding PaidAt, StringFormat='dd/MM/yy HH:mm'}" Width="120"/>
                                            <DataGridTextColumn Header="Type" Binding="{Binding TransactionType}" Width="100"/>
                                            <DataGridTextColumn Header="Method" Binding="{Binding PaymentMethod}" Width="80"/>
                                            <DataGridTextColumn Header="Amount" Binding="{Binding AmountPaid, StringFormat='Rs. {0:N0}'}" Width="100">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#22C55E"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Note" Binding="{Binding DisplayNote}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <TextBlock Text="No payments recorded." FontStyle="Italic" Foreground="#94A3B8" Margin="0,10,0,0"
                                               Visibility="{Binding SelectedBill.PaymentLogs.Count, Converter={StaticResource NumericToVisibilityConverter}, ConverterParameter=Inverted}"/>
                                </StackPanel>
                            </Border>

                            <!-- Section 3: 🔙 Returns Processed -->
                            <Border Background="White" CornerRadius="8" Padding="15" Margin="0" BorderBrush="#E2E8F0" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="🔙 Returns Progressed" FontSize="15" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding SelectedBill.ReturnLogs}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,0,15">
                                                    <Border Background="#F8FAFC" Padding="10,5">
                                                        <TextBlock FontSize="12" FontWeight="Bold" Foreground="#475569">
                                                            <Run Text="Return Date: "/><Run Text="{Binding ReturnedAt, StringFormat='dd MMM yyyy, HH:mm'}"/>
                                                            <Run Text=" (Refund: Rs."/><Run Text="{Binding RefundAmount, StringFormat='N0'}"/><Run Text=")"/>
                                                        </TextBlock>
                                                    </Border>
                                                    <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" 
                                                              HeadersVisibility="Column" IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                                              Margin="10,5,0,0" Height="Auto">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="Returned Product" Binding="{Binding ItemDescription}" Width="*"/>
                                                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="60"/>
                                                            <DataGridTextColumn Header="Price" Binding="{Binding UnitPrice, StringFormat='N0'}" Width="80"/>
                                                            <DataGridTextColumn Header="Value" Binding="{Binding TotalPrice, StringFormat='N0'}" Width="80">
                                                                <DataGridTextColumn.ElementStyle>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                                                    </Style>
                                                                </DataGridTextColumn.ElementStyle>
                                                            </DataGridTextColumn>
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="No items returned for this invoice." FontStyle="Italic" Foreground="#94A3B8" Margin="0,10,0,0"
                                               Visibility="{Binding SelectedBill.ReturnLogs.Count, Converter={StaticResource NumericToVisibilityConverter}, ConverterParameter=Inverted}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Financial Summary Section -->
                    <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="25,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel>
                                <UniformGrid Columns="3" HorizontalAlignment="Left" Width="500">
                                    <!-- Original Composition -->
                                    <StackPanel Margin="0,0,20,10">
                                        <TextBlock Text="Sub-Total" FontSize="11" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding SelectedBill.SubTotal, StringFormat='Rs. {0:N0}'}" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,20,10">
                                        <TextBlock Text="Discount" FontSize="11" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding SelectedBill.DiscountAmount, StringFormat='Rs. -{0:N0}'}" FontSize="14" FontWeight="SemiBold" Foreground="#EF4444"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="Tax" FontSize="11" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding SelectedBill.TaxAmount, StringFormat='Rs. +{0:N0}'}" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    </StackPanel>

                                    <!-- Final Values & Tracking -->
                                    <StackPanel Margin="0,0,20,0">
                                        <TextBlock Text="Total Invoice" FontSize="11" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding SelectedBill.GrandTotal, StringFormat='Rs. {0:N0}'}" FontSize="14" FontWeight="Bold" Foreground="#3B82F6"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,20,0">
                                        <TextBlock Text="(-) Total Returns" FontSize="11" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding SelectedBill.ReturnedAmount, StringFormat='Rs. {0:N0}'}" FontSize="14" FontWeight="Bold" Foreground="#EF4444"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,0">
                                        <TextBlock Text="Total Payments" FontSize="11" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding SelectedBill.PaidAmount, StringFormat='Rs. {0:N0}'}" FontSize="14" FontWeight="Bold" Foreground="#22C55E"/>
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="Final Balance Due" FontSize="12" Foreground="#64748B" HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding SelectedBill.RemainingAmount, StringFormat='Rs. {0:N0}'}" FontSize="24" FontWeight="Black" Foreground="#EF4444" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Bottom Bar -->
                    <Border Grid.Row="3" Background="White" CornerRadius="0,0,12,12" Padding="25,15" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                        <Grid>
                            <Button Content="🖨 Re-Print Bill" Command="{Binding PrintBillCommand}" CommandParameter="{Binding SelectedBill}"
                                    Style="{DynamicResource PrimaryButton}" Background="#3B82F6" Padding="20,8" HorizontalAlignment="Right" Height="40"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Border>

        <!-- ═══ POPUP ERROR OVERLAY ═══ -->
        <Border Grid.RowSpan="5" Panel.ZIndex="3000" IsHitTestVisible="False"
                VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,40,0,0"
                Visibility="{Binding PopupErrorVisible, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
            <Border Background="White" CornerRadius="8" Padding="20,12"
                    BorderBrush="#EF4444" BorderThickness="2">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.15" Color="Black"/>
                </Border.Effect>
                <TextBlock Text="{Binding PopupErrorMessage}" 
                           Foreground="#EF4444" FontSize="20" FontWeight="Bold" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
        </Border>
    </Grid>
</UserControl>
