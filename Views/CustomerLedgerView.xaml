<UserControl x:Class="GroceryPOS.Views.CustomerLedgerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GroceryPOS.Converters"
             xmlns:controls="clr-namespace:GroceryPOS.Views.Controls"
             xmlns:helpers="clr-namespace:GroceryPOS.Helpers"
             Background="{DynamicResource BgBrush}" FontFamily="{DynamicResource AppFont}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <BooleanToVisibilityConverter x:Key="WpfBoolToVis"/>
        <converters:StringToVisibilityConverter x:Key="StringToVis"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:PaymentStatusColorConverter x:Key="PayStatusColor"/>
        <converters:NumericToVisibilityConverter x:Key="NumericToVisibilityConverter"/>
        <converters:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter"/>
        <converters:CountToVisibilityConverter x:Key="InverseCountToVis" Inverse="True"/>
    </UserControl.Resources>

    <Grid Margin="28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="← Back" Command="{Binding GoBackCommand}"
                    Foreground="{DynamicResource PrimaryBrush}" Background="Transparent" BorderThickness="0"
                    FontSize="14" Cursor="Hand" VerticalAlignment="Center" Margin="0,0,16,0"/>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextBrush}">
                    <Run Text="📒 Customer Ledger —"/>
                    <Run Text="{Binding Customer.FullName, FallbackValue='—'}" Foreground="{DynamicResource PrimaryBrush}"/>
                </TextBlock>
                <TextBlock FontSize="12" Foreground="{DynamicResource SubTextBrush}" Margin="0,3,0,0">
                    <Run Text="Phone:"/><Run Text=" "/><Run Text="{Binding Customer.PrimaryPhone, FallbackValue='—'}"/>
                    <Run Text="  |  Since:"/><Run Text=" "/><Run Text="{Binding Customer.CreatedAt, StringFormat=yyyy-MM-dd, FallbackValue='—'}"/>
                </TextBlock>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="🖨 Print Ledger" Command="{Binding PrintLedgerCommand}"
                        Style="{DynamicResource ModernButton}"
                        Background="{DynamicResource PrimaryBrush}" Foreground="White" FontSize="13"
                        Padding="14,8" Cursor="Hand" BorderThickness="0" Margin="0,0,8,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="🔄 Refresh" Command="{Binding RefreshCommand}"
                        Style="{DynamicResource ModernButton}"
                        Background="{DynamicResource SidebarBgBrush}" Foreground="White" FontSize="13"
                        Padding="14,8" Cursor="Hand" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ═══ SUMMARY CARDS ═══ -->
        <Border Grid.Row="1" Style="{DynamicResource CardBorder}" Padding="20,16" Margin="0,0,0,16" Background="{DynamicResource SidebarBgBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Credit Given -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="Total Credit Given" Foreground="White" Opacity="0.8" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalCredit, StringFormat='Rs. {0:N0}'}" Foreground="White"
                               FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Total Paid -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="Total Paid" Foreground="White" Opacity="0.8" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalPaid, StringFormat='Rs. {0:N0}'}" Foreground="{DynamicResource SuccessBrush}"
                               FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Total Pending -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="Total Pending" Foreground="White" Opacity="0.8" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBlock Foreground="{DynamicResource DangerBrush}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0">
                        <TextBlock.Text>
                            <Binding Path="TotalPending" StringFormat="Rs. {0:N0}"/>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ LEDGER TABLE ═══ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Main Ledger Table -->
            <Border Style="{DynamicResource CardBorder}" Padding="0">
                <DataGrid ItemsSource="{Binding LedgerEntries}"
                          SelectedItem="{Binding SelectedBill}"
                          Style="{DynamicResource ModernDataGrid}">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ModernDataGridColumnHeader}">
                            <Setter Property="Background" Value="{DynamicResource SidebarBgBrush}"/>
                            <Setter Property="Foreground" Value="#94A3B8"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource ModernDataGridRow}">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource ModernDataGridCell}">
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding CreatedAt, StringFormat='dd/MM/yy HH:mm'}" Width="150" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Invoice" Binding="{Binding InvoiceNumber}" Width="100" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Debit" Binding="{Binding GrandTotal, StringFormat='Rs. {0:N0}'}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Credit" Binding="{Binding PaidAmount, StringFormat='Rs. {0:N0}'}" Width="120" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="#22C55E"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Running Balance" Binding="{Binding RemainingAmount, StringFormat='Rs. {0:N0}'}" Width="130" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Width="190" Header="Actions">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="8,4">
                                        <Button Content="View Detail"
                                                Command="{Binding DataContext.ViewBillCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" Foreground="#3B82F6" BorderThickness="0"
                                                Cursor="Hand" Padding="4,2" Margin="0,0,12,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontSize="12"/>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <Button Content="Pay"
                                                Command="{Binding DataContext.OpenPaymentPanelCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" Foreground="#22C55E" BorderThickness="0"
                                                Cursor="Hand" Padding="4,2" Margin="0,0,12,0"
                                                Visibility="{Binding HasPendingCredit, Converter={StaticResource WpfBoolToVis}}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontSize="12"/>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <Button Content="Print"
                                                Command="{Binding DataContext.PrintBillCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" Foreground="#94A3B8" BorderThickness="0"
                                                Cursor="Hand" Padding="4,2">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontSize="12"/>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- ═══ STATUS ═══ -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="#94A3B8" FontSize="13" Margin="0,10,0,0"/>

        <!-- ═══ PAYMENT PANEL OVERLAY ═══ -->
        <Border Grid.RowSpan="5"
                Visibility="{Binding IsPaymentPanelOpen, Converter={StaticResource WpfBoolToVis}}"
                Background="#80000000" IsHitTestVisible="True">
            <Border Background="#1E293B" CornerRadius="16" Padding="28,24"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MinWidth="400" MaxWidth="480"
                    BorderBrush="#334155" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="💳 Record Payment" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                    <TextBlock Foreground="#94A3B8" FontSize="13" Margin="0,0,0,16">
                        <Run Text="Bill #"/><Run Text="{Binding SelectedBill.InvoiceNumber, FallbackValue='-', Mode=OneWay}"/>
                        <Run Text="  |  Remaining: Rs."/><Run Text="{Binding SelectedBillRemaining, StringFormat='{}{0:N0}', FallbackValue='0', Mode=OneWay}" Foreground="#EF4444" FontWeight="SemiBold"/>
                    </TextBlock>

                    <TextBlock Text="Payment Amount" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Auto-focused textbox that only accepts decimals to prevent bad inputs during ledger payment -->
                        <TextBox Grid.Column="0" Text="{Binding PaymentAmountText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#0F172A" Foreground="White" FontSize="16" FontWeight="SemiBold"
                                 Padding="10,8" BorderBrush="#334155" BorderThickness="1" CaretBrush="White"
                                 helpers:FocusHelper.IsFocused="{Binding IsPaymentPanelOpen}"
                                 helpers:FocusHelper.DecimalOnly="True"/>
                        <Button Grid.Column="1" Content="Pay Full" Command="{Binding PayFullRemainingCommand}"
                                Foreground="#60A5FA" Background="#334155" Padding="10,8" Margin="8,0,0,0"
                                BorderThickness="0" FontSize="12" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Payment Method Selection -->
                    <TextBlock Text="Payment Method" Foreground="#1E293B" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding PaymentMethods}" SelectedItem="{Binding SelectedPaymentMethod}"
                              FontSize="13" Padding="10,8" Margin="0,0,0,12" Foreground="#1E293B" Background="#F1F5F9" BorderBrush="#CBD5E1"/>

                    <!-- Online Account Selection (visible only when Online is selected) -->
                    <StackPanel Visibility="{Binding IsOnlinePayment, Converter={StaticResource BoolToVis}}" Margin="0,0,0,10">
                        <TextBlock Text="🏢 Select Payment Account" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#1E293B" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding ActiveAccounts}"
                                  SelectedItem="{Binding SelectedAccount}"
                                  FontSize="13" Padding="10,8" Margin="0,0,0,8"
                                  Foreground="#1E293B" Background="#F1F5F9" BorderBrush="#CBD5E1">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="12" Foreground="#1E293B"/>
                                        <TextBlock Text="{Binding AccountType}" FontSize="10" Foreground="#64748B" Opacity="0.9"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="⚠ Required: Select an account to receive payment"
                                   FontSize="10" Foreground="#DC2626" FontWeight="SemiBold" Margin="0,3,0,8"
                                   Visibility="{Binding SelectedAccount, Converter={StaticResource NullToVis}}"/>
                    </StackPanel>

                    <TextBlock Text="Note (Optional)" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PaymentNote, UpdateSourceTrigger=PropertyChanged}"
                             Background="#0F172A" Foreground="White" FontSize="13"
                             Padding="10,8" Margin="0,0,0,14"
                             BorderBrush="#334155" BorderThickness="1" CaretBrush="White"/>

                    <!-- Error -->
                    <TextBlock Text="{Binding PaymentError}" Foreground="#F87171" FontSize="12"
                               Margin="0,0,0,10" TextWrapping="Wrap"
                               Visibility="{Binding PaymentError, Converter={StaticResource StringToVis}}"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                        <Button Content="Cancel" Command="{Binding ClosePaymentPanelCommand}"
                                Foreground="#94A3B8" Background="#334155" Padding="16,8" Margin="0,0,10,0"
                                BorderThickness="0" FontSize="13" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="✓ Record Payment" Command="{Binding RecordPaymentCommand}"
                                Foreground="White" Background="#22C55E" Padding="16,8"
                                BorderThickness="0" FontSize="13" FontWeight="SemiBold" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.RowSpan="5" Visibility="{Binding IsBillDetailOpen, Converter={StaticResource WpfBoolToVis}}" 
                Background="#CC0F172A" IsHitTestVisible="True" Panel.ZIndex="2000">
            <Border Background="#F1F5F9" CornerRadius="12" Padding="0"
                    VerticalAlignment="Center" HorizontalAlignment="Center" 
                    Width="850" MaxHeight="850"
                    BorderBrush="#CBD5E1" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="50" ShadowDepth="0" Opacity="0.4" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="#1E2F46" CornerRadius="12,12,0,0" Padding="25,20" BorderBrush="#2F425B" BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Invoice Audit History" FontSize="20" FontWeight="Bold" Foreground="White"/>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <TextBlock Text="Invoice #: " Foreground="#CBD5E1" FontSize="13"/>
                                    <TextBlock Text="{Binding SelectedBill.InvoiceNumber}" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,20,0"/>
                                    <TextBlock Text="Date: " Foreground="#CBD5E1" FontSize="13"/>
                                    <TextBlock Text="{Binding SelectedBill.CreatedAt, StringFormat='dd MMM yyyy, HH:mm'}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" VerticalAlignment="Top" Content="✕" 
                                    Background="Transparent" Foreground="#CBD5E1" FontSize="20"
                                    BorderThickness="0" Cursor="Hand" Padding="10"
                                    Command="{Binding CloseBillDetailCommand}"/>
                        </Grid>
                    </Border>

                    <!-- Content (Scrollable for large audit trails) -->
                    <ScrollViewer x:Name="AuditScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="25">
                        <StackPanel>
                            <!-- Section 1: 🛒 Items Sold -->
                            <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,20" BorderBrush="#E2E8F0" BorderThickness="1">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <TextBlock Text="🛒 Original Items Sold" FontSize="15" FontWeight="Bold" Foreground="#0F172A"/>
                                        <TextBlock Text="{Binding SelectedBill.GrandTotal, StringFormat='Total Sale Value: Rs.{0:N0}'}" 
                                                   HorizontalAlignment="Right" Foreground="#1E293B" FontWeight="Bold"/>
                                    </Grid>
                                    <DataGrid ItemsSource="{Binding SelectedBill.Items}" AutoGenerateColumns="False" 
                                              HeadersVisibility="Column" IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9">
                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#1E2F46"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Padding" Value="8,6"/>
                                                <Setter Property="BorderBrush" Value="#2F425B"/>
                                                <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Product Description" Binding="{Binding ItemDescription}" Width="*"/>
                                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="60"/>
                                            <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat='N0'}" Width="80"/>
                                            <DataGridTextColumn Header="Total" Binding="{Binding TotalPrice, StringFormat='N0'}" Width="80">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <!-- Section 2: 💵 Payment History -->
                            <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,20" BorderBrush="#E2E8F0" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="💵 Payment &amp; Installment History" FontSize="15" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,10"/>
                                    <DataGrid ItemsSource="{Binding BillAuditTimeline}" AutoGenerateColumns="False" 
                                              HeadersVisibility="Column" IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                                              SelectionMode="Single" SelectionUnit="FullRow">
                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#1E2F46"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Padding" Value="8,6"/>
                                                <Setter Property="BorderBrush" Value="#2F425B"/>
                                                <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>
                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Setter Property="Background" Value="White"/>
                                                <Setter Property="Foreground" Value="#1E293B"/>
                                                <Setter Property="FontSize" Value="14"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#F8FAFC"/>
                                                        <Setter Property="Foreground" Value="#1E293B"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>
                                        <DataGrid.CellStyle>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="Padding" Value="8,8"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="#1E293B"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Foreground" Value="#1E293B"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.CellStyle>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat='dd/MM/yy HH:mm'}" Width="120"/>
                                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="110"/>
                                            <DataGridTextColumn Header="Method" Binding="{Binding Method}" Width="85"/>
                                            <DataGridTemplateColumn Header="Amount" Width="120">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <Button Content="{Binding DisplayAmount}"
                                                                    Command="{Binding DataContext.OpenReturnDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Background="Transparent"
                                                                    BorderThickness="0"
                                                                    FontWeight="Bold"
                                                                    HorizontalAlignment="Right"
                                                                    Margin="0,0,10,0"
                                                                    Cursor="Hand"
                                                                    Visibility="{Binding IsReturn, Converter={StaticResource WpfBoolToVis}}">
                                                                <Button.ToolTip>
                                                                    <ToolTip Background="Transparent" BorderThickness="0" Padding="0" HasDropShadow="False">
                                                                        <Border Background="#0F172A"
                                                                                BorderBrush="#334155"
                                                                                BorderThickness="1"
                                                                                CornerRadius="8"
                                                                                Padding="10"
                                                                                MaxWidth="320">
                                                                            <TextBlock Text="{Binding ReturnHoverDetail}"
                                                                                       Foreground="#E2E8F0"
                                                                                       FontSize="13"
                                                                                       LineHeight="20"
                                                                                       TextWrapping="Wrap"/>
                                                                        </Border>
                                                                    </ToolTip>
                                                                </Button.ToolTip>
                                                                <Button.Style>
                                                                    <Style TargetType="Button">
                                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                                    </Style>
                                                                </Button.Style>
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontWeight="Bold" TextDecorations="Underline"/>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>
                                                            <TextBlock Text="{Binding DisplayAmount}"
                                                                       Foreground="#22C55E"
                                                                       FontWeight="Bold"
                                                                       HorizontalAlignment="Right"
                                                                       Margin="0,0,10,0"
                                                                       VerticalAlignment="Center"
                                                                       Visibility="{Binding ShowRegularAmount, Converter={StaticResource WpfBoolToVis}}"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Audit Detail" Binding="{Binding Note}" Width="*">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                                        <Setter Property="LineHeight" Value="20"/>
                                                        <Setter Property="Margin" Value="10,0,0,0"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTemplateColumn Header="Remaining Balance" Width="145">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding RemainingBalanceLabel}"
                                                                   Foreground="#B91C1C"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Right"
                                                                   VerticalAlignment="Center"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <TextBlock Text="No payments recorded." FontStyle="Italic" Foreground="#94A3B8" Margin="0,10,0,0"
                                               Visibility="{Binding BillAuditTimeline.Count, Converter={StaticResource NumericToVisibilityConverter}, ConverterParameter=Inverted}"/>
                                </StackPanel>
                            </Border>

                            <!-- Section 3: Return Detail (opened from clickable red amount) -->
                            <Border x:Name="ReturnDetailSection" Background="White" CornerRadius="8" Padding="15" Margin="0"
                                    BorderBrush="#E2E8F0" BorderThickness="1"
                                    Visibility="{Binding IsReturnDetailOpen, Converter={StaticResource WpfBoolToVis}}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <TextBlock Text="↩ Return Detail" FontSize="15" FontWeight="Bold" Foreground="#0F172A"/>
                                        <Button Content="✕"
                                                Command="{Binding CloseReturnDetailCommand}"
                                                HorizontalAlignment="Right"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="#64748B"
                                                FontSize="16"
                                                Cursor="Hand"/>
                                    </Grid>
                                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,8">
                                        <Run Text="Return Date: "/><Run Text="{Binding SelectedReturnDetail.ReturnedAt, StringFormat='dd MMM yyyy, HH:mm'}"/>
                                        <Run Text="  (Refund: Rs. "/><Run Text="{Binding SelectedReturnDetail.RefundAmount, StringFormat='N0'}"/><Run Text=")"/>
                                    </TextBlock>
                                    <DataGrid ItemsSource="{Binding SelectedReturnDetail.Items}" AutoGenerateColumns="False"
                                              HeadersVisibility="Column" IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Returned Product" Binding="{Binding ItemDescription}" Width="*"/>
                                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="60"/>
                                            <DataGridTextColumn Header="Price" Binding="{Binding UnitPrice, StringFormat='N0'}" Width="80"/>
                                            <DataGridTextColumn Header="Value" Binding="{Binding TotalPrice, StringFormat='N0'}" Width="90">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Financial Summary Section -->
                    <Border Grid.Row="2" Background="#1E2F46" BorderBrush="#2F425B" BorderThickness="0,1,0,0" Padding="25,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel>
                                <UniformGrid Columns="3" HorizontalAlignment="Left" Width="500">
                                    <!-- Original Composition -->
                                    <StackPanel Margin="0,0,20,10">
                                        <TextBlock Text="Sub-Total" FontSize="11" Foreground="#CBD5E1"/>
                                        <TextBlock Text="{Binding SelectedBill.SubTotal, StringFormat='Rs. {0:N0}'}" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,20,10">
                                        <TextBlock Text="Discount" FontSize="11" Foreground="#CBD5E1"/>
                                        <TextBlock Text="{Binding SelectedBill.DiscountAmount, StringFormat='Rs. -{0:N0}'}" FontSize="14" FontWeight="SemiBold" Foreground="#EF4444"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="Tax" FontSize="11" Foreground="#CBD5E1"/>
                                        <TextBlock Text="{Binding SelectedBill.TaxAmount, StringFormat='Rs. +{0:N0}'}" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                    </StackPanel>

                                    <!-- Final Values & Tracking -->
                                    <StackPanel Margin="0,0,20,0">
                                        <TextBlock Text="Total Invoice" FontSize="11" Foreground="#CBD5E1"/>
                                        <TextBlock Text="{Binding SelectedBill.GrandTotal, StringFormat='Rs. {0:N0}'}" FontSize="14" FontWeight="Bold" Foreground="#3B82F6"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,20,0">
                                        <TextBlock Text="(-) Total Returns" FontSize="11" Foreground="#CBD5E1"/>
                                        <TextBlock Text="{Binding SelectedBill.ReturnedAmount, StringFormat='Rs. {0:N0}'}" FontSize="14" FontWeight="Bold" Foreground="#EF4444"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,0">
                                        <TextBlock Text="Total Payments" FontSize="11" Foreground="#CBD5E1"/>
                                        <TextBlock Text="{Binding SelectedBill.PaidAmount, StringFormat='Rs. {0:N0}'}" FontSize="14" FontWeight="Bold" Foreground="#22C55E"/>
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="Final Balance Due" FontSize="12" Foreground="#CBD5E1" HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding SelectedBill.RemainingAmount, StringFormat='Rs. {0:N0}'}" FontSize="24" FontWeight="Black" Foreground="#EF4444" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Bottom Bar -->
                    <Border Grid.Row="3" Background="White" CornerRadius="0,0,12,12" Padding="25,15" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                        <Grid>
                            <Button Content="🖨 Re-Print Bill" Command="{Binding PrintBillCommand}" CommandParameter="{Binding SelectedBill}"
                                    Style="{DynamicResource PrimaryButton}" Background="#3B82F6" Padding="20,8" HorizontalAlignment="Right" Height="40"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Border>

        <!-- ═══ POPUP ERROR OVERLAY ═══ -->
        <Border Grid.RowSpan="5" Panel.ZIndex="3000" IsHitTestVisible="False"
                VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,40,0,0"
                Visibility="{Binding PopupErrorVisible, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
            <Border Background="White" CornerRadius="8" Padding="20,12"
                    BorderBrush="#EF4444" BorderThickness="2">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.15" Color="Black"/>
                </Border.Effect>
                <TextBlock Text="{Binding PopupErrorMessage}" 
                           Foreground="#EF4444" FontSize="20" FontWeight="Bold" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
        </Border>
    </Grid>
</UserControl>
