<UserControl x:Class="GroceryPOS.Views.CustomerLedgerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GroceryPOS.Converters"
             xmlns:controls="clr-namespace:GroceryPOS.Views.Controls"
             xmlns:helpers="clr-namespace:GroceryPOS.Helpers"
             Background="{DynamicResource BgBrush}" FontFamily="{DynamicResource AppFont}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <BooleanToVisibilityConverter x:Key="WpfBoolToVis"/>
        <converters:StringToVisibilityConverter x:Key="StringToVis"/>
        <converters:PaymentStatusColorConverter x:Key="PayStatusColor"/>
        <converters:NumericToVisibilityConverter x:Key="NumericToVis"/>
        <converters:GreaterThanZeroConverter x:Key="GreaterThanZero"/>
        <converters:CountToVisibilityConverter x:Key="InverseCountToVis" Inverse="True"/>
    </UserControl.Resources>

    <Grid Margin="28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="← Back" Command="{Binding GoBackCommand}"
                    Foreground="{DynamicResource PrimaryBrush}" Background="Transparent" BorderThickness="0"
                    FontSize="14" Cursor="Hand" VerticalAlignment="Center" Margin="0,0,16,0"/>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextBrush}">
                    <Run Text="📒 Customer Ledger —"/>
                    <Run Text="{Binding Customer.FullName, FallbackValue='—'}" Foreground="{DynamicResource PrimaryBrush}"/>
                </TextBlock>
                <TextBlock FontSize="12" Foreground="{DynamicResource SubTextBrush}" Margin="0,3,0,0">
                    <Run Text="Phone:"/><Run Text=" "/><Run Text="{Binding Customer.PrimaryPhone, FallbackValue='—'}"/>
                    <Run Text="  |  Since:"/><Run Text=" "/><Run Text="{Binding Customer.CreatedAt, StringFormat=yyyy-MM-dd, FallbackValue='—'}"/>
                </TextBlock>
            </StackPanel>

            <Button Grid.Column="2" Content="🔄 Refresh" Command="{Binding RefreshCommand}"
                    Style="{DynamicResource ModernButton}"
                    Background="{DynamicResource SidebarBgBrush}" Foreground="White" FontSize="13"
                    Padding="14,8" Cursor="Hand" BorderThickness="0" VerticalAlignment="Center">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- ═══ SUMMARY CARDS ═══ -->
        <Border Grid.Row="1" Style="{DynamicResource CardBorder}" Padding="20,16" Margin="0,0,0,16" Background="{DynamicResource SidebarBgBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Credit Given -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="Total Credit Given" Foreground="White" Opacity="0.8" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalCredit, StringFormat='Rs. {0:N0}'}" Foreground="White"
                               FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Total Paid -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="Total Paid" Foreground="White" Opacity="0.8" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalPaid, StringFormat='Rs. {0:N0}'}" Foreground="{DynamicResource SuccessBrush}"
                               FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Total Pending -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="Total Pending" Foreground="White" Opacity="0.8" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBlock Foreground="{DynamicResource DangerBrush}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0">
                        <TextBlock.Text>
                            <Binding Path="TotalPending" StringFormat="Rs. {0:N0}"/>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ LEDGER TABLE ═══ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Main Ledger Table -->
            <Border Style="{DynamicResource CardBorder}" Padding="0" Margin="0,0,12,0">
                <DataGrid ItemsSource="{Binding LedgerEntries}"
                          SelectedItem="{Binding SelectedBill}"
                          Style="{DynamicResource ModernDataGrid}">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ModernDataGridColumnHeader}">
                            <Setter Property="Background" Value="{DynamicResource SidebarBgBrush}"/>
                            <Setter Property="Foreground" Value="#94A3B8"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource ModernDataGridRow}">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource ModernDataGridCell}">
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding BillDateTime, StringFormat='yyyy-MM-dd HH:mm'}" Width="150"/>
                        <DataGridTextColumn Header="Invoice #" Binding="{Binding InvoiceNumber, Mode=OneWay}" Width="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Paid" Binding="{Binding PaidAmount, StringFormat='Rs. {0:N0}'}" Width="100"/>
                        <!-- Remaining Amount — hidden for fully paid bills -->
                        <DataGridTemplateColumn Header="Remaining" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Padding="4,0" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding RemainingAmount, StringFormat='Rs. {0:N0}'}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Style.Triggers>
                                                    <!-- Hide "Rs. 0" for fully paid bills — show muted dash -->
                                                    <DataTrigger Binding="{Binding HasPendingCredit}" Value="False">
                                                        <Setter Property="Text" Value="—"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                                                        <Setter Property="FontWeight" Value="Normal"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Payment Status badge -->
                        <DataGridTemplateColumn Header="Status" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left"
                                            Background="{Binding PaymentStatus, Converter={StaticResource PayStatusColor}}">
                                        <TextBlock Text="{Binding PaymentStatus}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Pay Button -->
                        <DataGridTemplateColumn Header="Action" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="📂 View" Cursor="Hand"
                                                Command="{Binding DataContext.ViewBillCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Foreground="{DynamicResource AccentBrush}" Background="Transparent" BorderThickness="0" FontSize="12" Padding="6,4"
                                                Margin="0,0,8,0"/>
                                        <Button Content="🖨️ Print" Cursor="Hand"
                                                Command="{Binding DataContext.PrintBillCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Foreground="{DynamicResource SuccessBrush}" Background="Transparent" BorderThickness="0" FontSize="12" Padding="6,4"
                                                Margin="0,0,8,0"/>
                                        <Button Content="💳 Pay" Cursor="Hand"
                                                Command="{Binding DataContext.OpenPaymentPanelCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Foreground="{DynamicResource PrimaryBrush}" Background="Transparent" BorderThickness="0" FontSize="12" Padding="6,4"
                                                Visibility="{Binding HasPendingCredit, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Payment History Breakdown Panel (Right) -->
            <Border Grid.Column="1" Width="300" Style="{DynamicResource CardBorder}" Padding="16" Background="{DynamicResource SidebarBgBrush}"
                    Visibility="{Binding HasSelectedBill, Converter={StaticResource WpfBoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,4">
                        <TextBlock Text="💳 History — Bill Details" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        <Button Content="X" Command="{Binding CloseSidebarCommand}" 
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="Transparent" Foreground="#64748B" FontSize="16"
                                BorderThickness="0" Cursor="Hand" Padding="5"/>
                    </Grid>
                    <TextBlock Grid.Row="1" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,16">
                        <Run Text="Invoice #"/><Run Text="{Binding SelectedBill.InvoiceNumber, Mode=OneWay}" Foreground="White" FontWeight="SemiBold"/>
                    </TextBlock>

                    <!-- Bill Quick Summary -->
                    <Border Grid.Row="2" Background="#0F172A" CornerRadius="8" Padding="12" Margin="0,0,0,16" BorderBrush="#334155" BorderThickness="1">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Bill Date" Foreground="#94A3B8" FontSize="11"/>
                                <TextBlock Text="{Binding SelectedBill.BillDateTime, StringFormat='yyyy-MM-dd HH:mm'}" HorizontalAlignment="Right" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Grand Total" Foreground="#94A3B8" FontSize="11"/>
                                <TextBlock Text="{Binding SelectedBill.GrandTotal, StringFormat='Rs. {0:N0}'}" HorizontalAlignment="Right" Foreground="#60A5FA" FontSize="11" FontWeight="Bold"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Total Paid" Foreground="#94A3B8" FontSize="11"/>
                                <TextBlock Text="{Binding SelectedBill.PaidAmount, StringFormat='Rs. {0:N0}'}" HorizontalAlignment="Right" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontWeight="Bold"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="Balance Due" Foreground="#94A3B8" FontSize="11"/>
                                <TextBlock Text="{Binding SelectedBill.RemainingAmount, StringFormat='Rs. {0:N0}'}" HorizontalAlignment="Right" Foreground="#EF4444" FontSize="11" FontWeight="Bold"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Row="3" Text="Payment Logs" Foreground="#94A3B8" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <DataGrid Grid.Row="3" ItemsSource="{Binding PaymentHistory}"
                               AutoGenerateColumns="False" IsReadOnly="True"
                               Background="Transparent" BorderThickness="0"
                               RowBackground="Transparent"
                               Foreground="White" FontSize="12" HeadersVisibility="Column"
                               VerticalScrollBarVisibility="Auto" Margin="0,25,0,0">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                                <Setter Property="FontSize" Value="10"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="0,0,0,8"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#334155"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1E293B"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="DATE" Binding="{Binding PaidAt, StringFormat='dd/MM/yy'}" Width="70"/>
                            <DataGridTextColumn Header="AMOUNT" Binding="{Binding AmountPaid, StringFormat='N0'}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="NOTE" Binding="{Binding Note}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                        <Setter Property="FontStyle" Value="Italic"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty State for Payment History -->
                    <TextBlock Grid.Row="3" Text="No payments recorded yet." 
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#475569" FontSize="12" FontStyle="Italic"
                               Visibility="{Binding PaymentHistory.Count, Converter={StaticResource InverseCountToVis}}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ STATUS ═══ -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="#94A3B8" FontSize="13" Margin="0,10,0,0"/>

        <!-- ═══ PAYMENT PANEL OVERLAY ═══ -->
        <Border Grid.RowSpan="5"
                Visibility="{Binding IsPaymentPanelOpen, Converter={StaticResource WpfBoolToVis}}"
                Background="#80000000" IsHitTestVisible="True">
            <Border Background="#1E293B" CornerRadius="16" Padding="28,24"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MinWidth="400" MaxWidth="480"
                    BorderBrush="#334155" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="💳 Record Payment" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                    <TextBlock Foreground="#94A3B8" FontSize="13" Margin="0,0,0,16">
                        <Run Text="Bill #"/><Run Text="{Binding SelectedBill.InvoiceNumber, FallbackValue='-', Mode=OneWay}"/>
                        <Run Text="  |  Remaining: Rs."/><Run Text="{Binding SelectedBillRemaining, StringFormat='{}{0:N0}', FallbackValue='0', Mode=OneWay}" Foreground="#EF4444" FontWeight="SemiBold"/>
                    </TextBlock>

                    <TextBlock Text="Payment Amount" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Auto-focused textbox that only accepts decimals to prevent bad inputs during ledger payment -->
                        <TextBox Grid.Column="0" Text="{Binding PaymentAmountText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#0F172A" Foreground="White" FontSize="16" FontWeight="SemiBold"
                                 Padding="10,8" BorderBrush="#334155" BorderThickness="1" CaretBrush="White"
                                 helpers:FocusHelper.IsFocused="{Binding IsPaymentPanelOpen}"
                                 helpers:FocusHelper.DecimalOnly="True"/>
                        <Button Grid.Column="1" Content="Pay Full" Command="{Binding PayFullRemainingCommand}"
                                Foreground="#60A5FA" Background="#334155" Padding="10,8" Margin="8,0,0,0"
                                BorderThickness="0" FontSize="12" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <TextBlock Text="Note (Optional)" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PaymentNote, UpdateSourceTrigger=PropertyChanged}"
                             Background="#0F172A" Foreground="White" FontSize="13"
                             Padding="10,8" Margin="0,0,0,14"
                             BorderBrush="#334155" BorderThickness="1" CaretBrush="White"/>

                    <!-- Error -->
                    <TextBlock Text="{Binding PaymentError}" Foreground="#F87171" FontSize="12"
                               Margin="0,0,0,10" TextWrapping="Wrap"
                               Visibility="{Binding PaymentError, Converter={StaticResource StringToVis}}"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                        <Button Content="Cancel" Command="{Binding ClosePaymentPanelCommand}"
                                Foreground="#94A3B8" Background="#334155" Padding="16,8" Margin="0,0,10,0"
                                BorderThickness="0" FontSize="13" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="✓ Record Payment" Command="{Binding RecordPaymentCommand}"
                                Foreground="White" Background="#22C55E" Padding="16,8"
                                BorderThickness="0" FontSize="13" FontWeight="SemiBold" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.RowSpan="5" Visibility="{Binding IsBillDetailOpen, Converter={StaticResource WpfBoolToVis}}" 
                Background="#CC000000" IsHitTestVisible="True">
            <Border Background="White" CornerRadius="4" Padding="0"
                    VerticalAlignment="Center" HorizontalAlignment="Center" 
                    Width="400" MaxHeight="750"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.3" Color="Black"/>
                </Border.Effect>
                <DockPanel>
                    <!-- Modal Header (Close Button) -->
                    <Grid DockPanel.Dock="Top" Background="#F8FAFC" Height="40">
                         <Button HorizontalAlignment="Right" Content="X" 
                                Background="Transparent" Foreground="#64748B" FontSize="16"
                                Padding="15,0" BorderThickness="0" Cursor="Hand"
                                Command="{Binding CloseBillDetailCommand}"/>
                    </Grid>

                    <!-- Print Button at Bottom -->
                    <Border DockPanel.Dock="Bottom" Background="#F8FAFC" Padding="20,15" BorderThickness="0,1,0,0" BorderBrush="#E2E8F0">
                        <Button Content="Re-Print Receipt" Command="{Binding PrintBillCommand}" CommandParameter="{Binding SelectedBill}"
                                Style="{DynamicResource PrimaryButton}" Background="#22C55E" Padding="20,10" HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Shared Receipt Control -->
                    <controls:BillReceiptControl Bill="{Binding SelectedBill}"/>
                </DockPanel>
            </Border>
        </Border>

        <!-- ═══ POPUP ERROR OVERLAY ═══ -->
        <Border Grid.RowSpan="5" Panel.ZIndex="3000" IsHitTestVisible="False"
                VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,40,0,0"
                Visibility="{Binding PopupErrorVisible, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
            <Border Background="White" CornerRadius="8" Padding="20,12"
                    BorderBrush="#EF4444" BorderThickness="2">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.15" Color="Black"/>
                </Border.Effect>
                <TextBlock Text="{Binding PopupErrorMessage}" 
                           Foreground="#EF4444" FontSize="20" FontWeight="Bold" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
        </Border>
    </Grid>
</UserControl>
