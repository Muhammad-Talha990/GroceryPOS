<UserControl x:Class="GroceryPOS.Views.CustomerLedgerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GroceryPOS.Converters"
             Background="{DynamicResource BgBrush}" FontFamily="{DynamicResource AppFont}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <BooleanToVisibilityConverter x:Key="WpfBoolToVis"/>
        <converters:StringToVisibilityConverter x:Key="StringToVis"/>
        <converters:PaymentStatusColorConverter x:Key="PayStatusColor"/>
        <converters:GreaterThanZeroConverter x:Key="GreaterThanZero"/>
    </UserControl.Resources>

    <Grid Margin="28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="← Back" Command="{Binding GoBackCommand}"
                    Foreground="{DynamicResource PrimaryBrush}" Background="Transparent" BorderThickness="0"
                    FontSize="14" Cursor="Hand" VerticalAlignment="Center" Margin="0,0,16,0"/>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextBrush}">
                    <Run Text="📒 Customer Ledger —"/>
                    <Run Text="{Binding Customer.FullName, FallbackValue='—'}" Foreground="{DynamicResource PrimaryBrush}"/>
                </TextBlock>
                <TextBlock FontSize="12" Foreground="{DynamicResource SubTextBrush}" Margin="0,3,0,0">
                    <Run Text="Phone:"/><Run Text=" "/><Run Text="{Binding Customer.PrimaryPhone, FallbackValue='—'}"/>
                    <Run Text="  |  Since:"/><Run Text=" "/><Run Text="{Binding Customer.CreatedAt, StringFormat=yyyy-MM-dd, FallbackValue='—'}"/>
                </TextBlock>
            </StackPanel>

            <Button Grid.Column="2" Content="🔄 Refresh" Command="{Binding RefreshCommand}"
                    Style="{DynamicResource ModernButton}"
                    Background="{DynamicResource SidebarBgBrush}" Foreground="White" FontSize="13"
                    Padding="14,8" Cursor="Hand" BorderThickness="0" VerticalAlignment="Center">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- ═══ SUMMARY CARDS ═══ -->
        <Border Grid.Row="1" Style="{DynamicResource CardBorder}" Padding="20,16" Margin="0,0,0,16" Background="{DynamicResource SidebarBgBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Credit Given -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="Total Credit Given" Foreground="White" Opacity="0.8" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalCredit, StringFormat='Rs. {0:N0}'}" Foreground="White"
                               FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Total Paid -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="Total Paid" Foreground="White" Opacity="0.8" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalPaid, StringFormat='Rs. {0:N0}'}" Foreground="{DynamicResource SuccessBrush}"
                               FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Total Pending -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="Total Pending" Foreground="White" Opacity="0.8" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBlock Foreground="{DynamicResource DangerBrush}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0">
                        <TextBlock.Text>
                            <Binding Path="TotalPending" StringFormat="Rs. {0:N0}"/>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ LEDGER TABLE ═══ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Main Ledger Table -->
            <Border Style="{DynamicResource CardBorder}" Padding="0" Margin="0,0,12,0">
                <DataGrid ItemsSource="{Binding LedgerEntries}"
                          SelectedItem="{Binding SelectedBill}"
                          Style="{DynamicResource ModernDataGrid}">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ModernDataGridColumnHeader}">
                            <Setter Property="Background" Value="{DynamicResource SidebarBgBrush}"/>
                            <Setter Property="Foreground" Value="#94A3B8"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource ModernDataGridRow}">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource ModernDataGridCell}">
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding BillDateTime, StringFormat='yyyy-MM-dd HH:mm'}" Width="150"/>
                        <DataGridTextColumn Header="Invoice #" Binding="{Binding InvoiceNumber}" Width="100"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding GrandTotal, StringFormat='Rs. {0:N0}'}" Width="100"/>
                        <DataGridTextColumn Header="Paid" Binding="{Binding PaidAmount, StringFormat='Rs. {0:N0}'}" Width="100"/>
                        <DataGridTextColumn Header="Remaining" Binding="{Binding RemainingAmount, StringFormat='Rs. {0:N0}'}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RemainingAmount, Converter={StaticResource GreaterThanZero}}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Payment Status badge -->
                        <DataGridTemplateColumn Header="Status" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left"
                                            Background="{Binding PaymentStatus, Converter={StaticResource PayStatusColor}}">
                                        <TextBlock Text="{Binding PaymentStatus}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Pay Button -->
                        <DataGridTemplateColumn Header="Action" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="💳 Pay" Cursor="Hand"
                                            Command="{Binding DataContext.OpenPaymentPanelCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Foreground="{DynamicResource SuccessBrush}" Background="Transparent" BorderThickness="0" FontSize="12" Padding="6,4"
                                            Visibility="{Binding HasPendingCredit, Converter={StaticResource BoolToVis}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Payment History Breakdown Panel (Right) -->
            <Border Grid.Column="1" Width="300" Style="{DynamicResource CardBorder}" Padding="16" Background="{DynamicResource SidebarBgBrush}"
                    Visibility="{Binding HasSelectedBill, Converter={StaticResource WpfBoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="💳 History — Bill Details" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="1" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,16">
                        <Run Text="Invoice #"/><Run Text="{Binding SelectedBill.InvoiceNumber}" Foreground="White" FontWeight="SemiBold"/>
                    </TextBlock>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding PaymentHistory}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Background="Transparent" BorderThickness="0"
                              RowBackground="Transparent"
                              Foreground="White" FontSize="12" HeadersVisibility="Column">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Padding" Value="0,0,0,8"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Paid Date" Binding="{Binding PaymentDate, StringFormat='yyyy-MM-dd'}" Width="100"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding AmountPaid, StringFormat='Rs. {0:N0}'}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ STATUS ═══ -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="#94A3B8" FontSize="13" Margin="0,10,0,0"/>

        <!-- ═══ PAYMENT PANEL OVERLAY ═══ -->
        <Border Grid.RowSpan="5"
                Visibility="{Binding IsPaymentPanelOpen, Converter={StaticResource WpfBoolToVis}}"
                Background="#80000000" IsHitTestVisible="True">
            <Border Background="#1E293B" CornerRadius="16" Padding="28,24"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MinWidth="400" MaxWidth="480"
                    BorderBrush="#334155" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="💳 Record Payment" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                    <TextBlock Foreground="#94A3B8" FontSize="13" Margin="0,0,0,16">
                        <Run Text="Bill #"/><Run Text="{Binding SelectedBill.InvoiceNumber, FallbackValue='-'}"/>
                        <Run Text="  |  Remaining: Rs."/><Run Text="{Binding SelectedBillRemaining, StringFormat='{}{0:N0}', FallbackValue='0', Mode=OneWay}" Foreground="#EF4444" FontWeight="SemiBold"/>
                    </TextBlock>

                    <TextBlock Text="Payment Amount" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding PaymentAmountText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#0F172A" Foreground="White" FontSize="16" FontWeight="SemiBold"
                                 Padding="10,8" BorderBrush="#334155" BorderThickness="1" CaretBrush="White"/>
                        <Button Grid.Column="1" Content="Pay Full" Command="{Binding PayFullRemainingCommand}"
                                Foreground="#60A5FA" Background="#334155" Padding="10,8" Margin="8,0,0,0"
                                BorderThickness="0" FontSize="12" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <TextBlock Text="Note (Optional)" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PaymentNote, UpdateSourceTrigger=PropertyChanged}"
                             Background="#0F172A" Foreground="White" FontSize="13"
                             Padding="10,8" Margin="0,0,0,14"
                             BorderBrush="#334155" BorderThickness="1" CaretBrush="White"/>

                    <!-- Error -->
                    <TextBlock Text="{Binding PaymentError}" Foreground="#F87171" FontSize="12"
                               Margin="0,0,0,10" TextWrapping="Wrap"
                               Visibility="{Binding PaymentError, Converter={StaticResource StringToVis}}"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                        <Button Content="Cancel" Command="{Binding ClosePaymentPanelCommand}"
                                Foreground="#94A3B8" Background="#334155" Padding="16,8" Margin="0,0,10,0"
                                BorderThickness="0" FontSize="13" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="✓ Record Payment" Command="{Binding RecordPaymentCommand}"
                                Foreground="White" Background="#22C55E" Padding="16,8"
                                BorderThickness="0" FontSize="13" FontWeight="SemiBold" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
