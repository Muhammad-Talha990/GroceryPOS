<UserControl x:Class="GroceryPOS.Views.CustomerManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GroceryPOS.Converters"
             Background="{DynamicResource BgBrush}" FontFamily="{DynamicResource AppFont}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <BooleanToVisibilityConverter x:Key="WpfBoolToVis"/>
        <converters:GreaterThanZeroConverter x:Key="GreaterThanZero"/>
    </UserControl.Resources>

    <Grid Margin="28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ PAGE HEADER ═══ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="👥 Customer Management" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="12" Padding="8,2" Margin="0,0,12,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Total:" Foreground="White" FontSize="12" Opacity="0.9"/>
                        <TextBlock Text="{Binding TotalCustomers}" Foreground="White" FontSize="12" FontWeight="Bold" Margin="4,0,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource SuccessBrush}" CornerRadius="12" Padding="8,2" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Active:" Foreground="White" FontSize="12" Opacity="0.9"/>
                        <TextBlock Text="{Binding ActiveCustomers}" Foreground="White" FontSize="12" FontWeight="Bold" Margin="4,0,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>

        <!-- ═══ TOOLBAR ═══ -->
        <Border Grid.Row="1" Style="{DynamicResource CardBorder}" Padding="16,12" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Border Grid.Column="0" Background="{DynamicResource InputBgBrush}" CornerRadius="10" 
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1.5"
                        Padding="12,4" Margin="0,0,16,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" Opacity="0.5"/>
                        <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" Foreground="{DynamicResource TextBrush}" BorderThickness="0"
                                 FontSize="15" VerticalAlignment="Center" Padding="0,6"
                                 CaretBrush="{DynamicResource PrimaryBrush}"/>
                    </Grid>
                </Border>

                <!-- Show Inactive toggle -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <CheckBox IsChecked="{Binding ShowInactive}" VerticalAlignment="Center" Style="{StaticResource {x:Type CheckBox}}"/>
                    <TextBlock Text="Show Inactive" Foreground="{DynamicResource SubTextBrush}" FontSize="14" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Add & Refresh buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="➕ Add Customer" Command="{Binding AddCommand}"
                            Style="{DynamicResource PrimaryButton}" Margin="0,0,12,0"/>

                    <Button Content="🔄 Refresh" Command="{Binding RefreshCommand}"
                            Style="{DynamicResource SecondaryButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ CUSTOMER GRID ═══ -->
        <Border Grid.Row="2" Style="{DynamicResource CardBorder}" Padding="0">
            <DataGrid ItemsSource="{Binding FilteredCustomers}"
                      SelectedItem="{Binding SelectedCustomer}"
                      Style="{DynamicResource ModernDataGrid}">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ModernDataGridColumnHeader}">
                        <Setter Property="Background" Value="{DynamicResource SidebarBgBrush}"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource ModernDataGridRow}"/>
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell" BasedOn="{StaticResource ModernDataGridCell}"/>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="S.No" Binding="{Binding SerialNumber}" Width="60"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="*" MinWidth="180"/>
                    <DataGridTextColumn Header="Phone" Binding="{Binding PrimaryPhone}" Width="120"/>
                    <DataGridTextColumn Header="Phone 2" Binding="{Binding SecondaryPhone}" Width="120"/>
                    <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="200"/>

                    <!-- Pending Credit -->
                    <DataGridTemplateColumn Header="Pending Credit" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding PendingCreditDisplay}" FontWeight="Bold" VerticalAlignment="Center" Margin="14,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                            <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PendingCredit, Converter={StaticResource GreaterThanZero}}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Status badge -->
                    <DataGridTemplateColumn Header="Status" Width="85">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12" Padding="8,4" HorizontalAlignment="Center" Margin="0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#16A34A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                    <Setter Property="Background" Value="#94A3B8"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding StatusLabel}" FontSize="12" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Action Buttons -->
                    <DataGridTemplateColumn Header="Actions" Width="320">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="8,0">
                                    <!-- Edit Button -->
                                    <Button Cursor="Hand" Margin="0,0,16,0"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" Background="Transparent" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" Padding="6,4" CornerRadius="4">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" 
                                                              Fill="#0D9488" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Edit" Foreground="#0D9488" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#CCFBF1"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Ledger Button -->
                                    <Button Cursor="Hand" Margin="0,0,16,0"
                                            Command="{Binding DataContext.ViewLedgerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" Background="Transparent" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" Padding="6,4" CornerRadius="4">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="M18 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM6 4h5v8l-2.5-1.5L6 12V4z" 
                                                              Fill="#F59E0B" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Ledger" Foreground="#F59E0B" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FEF3C7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Deactivate Button -->
                                    <Button Cursor="Hand"
                                            Command="{Binding DataContext.DeactivateCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" Background="Transparent" BorderThickness="0"
                                            Visibility="{Binding IsActive, Converter={StaticResource WpfBoolToVis}}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" Padding="6,4" CornerRadius="4">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" 
                                                              Fill="#DC2626" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Deactivate" Foreground="#DC2626" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Reactivate Button -->
                                    <Button Cursor="Hand"
                                            Command="{Binding DataContext.ReactivateCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" Background="Transparent" BorderThickness="0"
                                            Visibility="{Binding IsActive, Converter={StaticResource InverseBoolToVis}}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" Padding="6,4" CornerRadius="4">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4L9 16.2z" 
                                                              Fill="#16A34A" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Reactivate" Foreground="#16A34A" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#DCFCE7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ═══ STATUS BAR ═══ -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="#94A3B8" FontSize="13" Margin="0,10,0,0"/>

        <!-- ═══ EDIT DIALOG OVERLAY ═══ -->
        <Border Grid.RowSpan="4"
                Visibility="{Binding IsEditDialogOpen, Converter={StaticResource WpfBoolToVis}}"
                Background="#80000000" IsHitTestVisible="True">
            <Border Background="#1E293B" CornerRadius="16" Padding="28,24"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MinWidth="440" MaxWidth="520"
                    BorderBrush="#334155" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{Binding DialogTitle}" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,18"/>

                    <TextBlock Text="Full Name" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding EditFullName, UpdateSourceTrigger=PropertyChanged}"
                             Background="#0F172A" Foreground="White" FontSize="14"
                             Padding="10,8" Margin="0,0,0,12"
                             BorderBrush="#334155" BorderThickness="1" CaretBrush="White"/>

                    <TextBlock Text="Primary Phone" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding EditPhone, UpdateSourceTrigger=PropertyChanged}"
                             Background="#0F172A" Foreground="White" FontSize="14"
                             Padding="10,8" Margin="0,0,0,2"
                             BorderBrush="#334155" BorderThickness="1" CaretBrush="White"/>
                    
                    <TextBlock Text="⚠ Invalid format (e.g. 03001234567)" 
                               Foreground="#EF4444" FontSize="11" Margin="2,0,0,10"
                               Visibility="{Binding IsPhoneValid, Converter={StaticResource InverseBoolToVis}}"/>

                    <TextBlock Text="Secondary Phone (Optional)" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding EditPhone2, UpdateSourceTrigger=PropertyChanged}"
                             Background="#0F172A" Foreground="White" FontSize="14"
                             Padding="10,8" Margin="0,0,0,12"
                             BorderBrush="#334155" BorderThickness="1" CaretBrush="White"/>

                    <TextBlock Text="Address 1 (Optional)" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding EditAddress, UpdateSourceTrigger=PropertyChanged}"
                             Background="#0F172A" Foreground="White" FontSize="14"
                             Padding="10,8" Margin="0,0,0,12"
                             BorderBrush="#334155" BorderThickness="1" CaretBrush="White"/>

                    <TextBlock Text="Address 2 (Optional)" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding EditAddress2, UpdateSourceTrigger=PropertyChanged}"
                             Background="#0F172A" Foreground="White" FontSize="14"
                             Padding="10,8" Margin="0,0,0,12"
                             BorderBrush="#334155" BorderThickness="1" CaretBrush="White"/>

                    <TextBlock Text="Address 3 (Optional)" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding EditAddress3, UpdateSourceTrigger=PropertyChanged}"
                             Background="#0F172A" Foreground="White" FontSize="14"
                             Padding="10,8" Margin="0,0,0,14"
                             BorderBrush="#334155" BorderThickness="1" CaretBrush="White"/>

                    <!-- Error -->
                    <TextBlock Text="{Binding EditError}" Foreground="#F87171" FontSize="12"
                               Margin="0,0,0,10" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EditError}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <Trigger Property="Text" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </Trigger>
                                </Style.Triggers>
                                <Style.Resources>
                                    <!-- Use a converter or just rely on the fact that any non-empty string should be visible -->
                                </Style.Resources>
                            </Style>
                        </TextBlock.Style>
                        <TextBlock.Resources>
                            <converters:StringToVisibilityConverter x:Key="StringToVis"/>
                        </TextBlock.Resources>
                        <TextBlock.Visibility>
                            <Binding Path="EditError" Converter="{StaticResource StringToVis}"/>
                        </TextBlock.Visibility>
                    </TextBlock>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                        <Button Content="Cancel" Command="{Binding CancelEditCommand}"
                                Foreground="#94A3B8" Background="#334155" Padding="16,8" Margin="0,0,10,0"
                                BorderThickness="0" FontSize="13" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="💾 Save Changes" Command="{Binding SaveEditCommand}"
                                Foreground="White" Background="#3B82F6" Padding="16,8"
                                BorderThickness="0" FontSize="13" FontWeight="SemiBold" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- ═══ POPUP ERROR OVERLAY ═══ -->
        <Border Grid.RowSpan="4" Panel.ZIndex="3000" IsHitTestVisible="False"
                VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,40,0,0"
                Visibility="{Binding PopupErrorVisible, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
            <Border Background="White" CornerRadius="8" Padding="20,12"
                    BorderBrush="#EF4444" BorderThickness="2">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.15" Color="Black"/>
                </Border.Effect>
                <TextBlock Text="{Binding PopupErrorMessage}" 
                           Foreground="#EF4444" FontSize="20" FontWeight="Bold" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
        </Border>
    </Grid>
</UserControl>
