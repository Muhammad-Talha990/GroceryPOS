<UserControl x:Class="GroceryPOS.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgBrush}" FontFamily="{DynamicResource AppFont}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="30,24">
        <StackPanel>

            <!-- Greeting -->
            <TextBlock Text="{Binding Greeting}" FontSize="26" FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}" Margin="0,0,0,6"/>
            <TextBlock FontSize="13" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,28">
                <Run Text="Today is "/>
                <Run Text="{Binding Source={x:Static System:DateTime.Now}, StringFormat='dddd, dd MMMM yyyy', Mode=OneWay}"
                     xmlns:System="clr-namespace:System;assembly=mscorlib"/>
            </TextBlock>

            <!-- Stats Cards -->
            <UniformGrid Columns="5" Margin="0,0,0,28">
                <!-- Total Sales Today -->
                <Border Style="{DynamicResource CardBorder}" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="💰" FontSize="32" Margin="0,0,0,12"/>
                        <TextBlock Text="Total Sales Today" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource SubTextBrush}"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,6,0,0">
                            <TextBlock.Text>
                                <Binding Path="TodaySales" StringFormat="Rs.{0:N0}"/>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Foreground="{DynamicResource SubTextBrush}" FontSize="13" Margin="0,4,0,0">
                            <Run Text="{Binding TodaySaleCount, Mode=OneWay}" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                            <Run Text=" transactions"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Returns Today -->
                <Border Style="{DynamicResource CardBorder}" Margin="6,0">
                    <StackPanel>
                        <TextBlock Text="↩️" FontSize="32" Margin="0,0,0,12"/>
                        <TextBlock Text="Returns Today" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource SubTextBrush}"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Foreground="#FF7043" Margin="0,6,0,0">
                            <TextBlock.Text>
                                <Binding Path="TodayReturns" StringFormat="Rs.{0:N0}"/>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Text="items returned today" Foreground="{DynamicResource SubTextBrush}" FontSize="13" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Customer Credit (Due) -->
                <Border Style="{DynamicResource CardBorder}" Margin="6,0">
                    <StackPanel>
                        <TextBlock Text="💳" FontSize="32" Margin="0,0,0,12"/>
                        <TextBlock Text="Customer Credit (Due)" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource SubTextBrush}"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Foreground="{DynamicResource DangerBrush}" Margin="0,6,0,0">
                            <TextBlock.Text>
                                <Binding Path="TodayCredit" StringFormat="Rs.{0:N0}"/>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Text="unpaid amount today" Foreground="{DynamicResource SubTextBrush}" FontSize="13" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Cash in Hand -->
                <Border Style="{DynamicResource CardBorder}" Margin="6,0">
                    <StackPanel>
                        <TextBlock Text="🏦" FontSize="32" Margin="0,0,0,12"/>
                        <TextBlock Text="Cash in Hand" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource SubTextBrush}"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" Margin="0,6,0,0">
                            <TextBlock.Text>
                                <Binding Path="TodayCashInHand" StringFormat="Rs.{0:N0}"/>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Foreground="{DynamicResource SubTextBrush}" FontSize="11" Margin="0,4,0,0" TextWrapping="WrapWithOverflow">
                            <Run Text="In: "/>
                            <Run Text="{Binding TodayCash, StringFormat=Rs.{0:N0}, Mode=OneWay}" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                            <Run Text=" | Out: "/>
                            <Run Text="{Binding TodayCashRefunds, StringFormat=Rs.{0:N0}, Mode=OneWay}" FontWeight="SemiBold" Foreground="{DynamicResource DangerBrush}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Recovered Credit (Previous Bills) -->
                <Border Style="{DynamicResource CardBorder}" Margin="6,0,0,0">
                    <StackPanel>
                        <TextBlock Text="💼" FontSize="32" Margin="0,0,0,12"/>
                        <TextBlock Text="Recovered Credit Today" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource SubTextBrush}"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Foreground="#8B5CF6" Margin="0,6,0,0">
                            <TextBlock.Text>
                                <Binding Path="TodayRecoveredCredit" StringFormat="Rs.{0:N0}"/>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Text="(from previous invoices)" Foreground="{DynamicResource SubTextBrush}" FontSize="13" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Two Column Layout -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Sales -->
                <Border Grid.Column="0" Style="{DynamicResource CardBorder}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="📋 Recent Sales" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,14"/>

                        <DataGrid ItemsSource="{Binding RecentSales}" Style="{DynamicResource ModernDataGrid}"
                                  ColumnHeaderStyle="{DynamicResource ModernDataGridColumnHeader}"
                                  RowStyle="{DynamicResource ModernDataGridRow}"
                                  CellStyle="{DynamicResource ModernDataGridCell}"
                                  MaxHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Invoice" Binding="{Binding InvoiceNumber}" Width="70"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding" Value="10,0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="*** RETURN BILL ***">
                                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="Total" Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding GrandTotal, StringFormat='Rs.{0:N0}'}" VerticalAlignment="Center" Padding="10,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <!-- Color-code returns based on Status -->
                                                            <DataTrigger Binding="{Binding Status}" Value="*** RETURN BILL ***">
                                                                <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Time" Binding="{Binding SaleDate, StringFormat='dd/MM HH:mm'}" Width="Auto"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>


                <!-- Low Stock List -->
                <Border Grid.Column="1" Style="{DynamicResource CardBorder}" Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="⚠️ Low Stock Alert" FontSize="16" FontWeight="SemiBold"
                                   Foreground="#F44336" Margin="0,0,0,14"/>
                        <DataGrid ItemsSource="{Binding LowStockItems}" Style="{DynamicResource ModernDataGrid}"
                                  ColumnHeaderStyle="{DynamicResource ModernDataGridColumnHeader}"
                                  RowStyle="{DynamicResource ModernDataGridRow}"
                                  CellStyle="{DynamicResource ModernDataGridCell}"
                                  MaxHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Item" Binding="{Binding Description}" Width="*"/>
                                <DataGridTextColumn Header="Stock" Binding="{Binding StockQuantity}" Width="Auto"/>
                                <DataGridTextColumn Header="Min" Binding="{Binding MinStockThreshold}" Width="Auto"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
