<Window x:Class="GroceryPOS.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:GroceryPOS.Helpers"
        Title="GroceryPOS — Login" Height="550" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Border CornerRadius="16" Background="{DynamicResource BgBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" CornerRadius="16,16,0,0"
                    Padding="16,12" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="🛒 GroceryPOS" FontSize="18" FontWeight="Bold"
                               Foreground="White" FontFamily="{DynamicResource AppFont}"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="Transparent" Foreground="White" BorderThickness="0"
                            FontSize="16" Cursor="Hand" Click="CloseButton_Click"
                            Padding="8,2"/>
                </Grid>
            </Border>

            <!-- Login Form -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="48,0">

                <!-- Logo Icon -->
                <TextBlock Text="🏪" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="Welcome Back!" FontSize="26" FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"
                           FontFamily="{DynamicResource AppFont}"/>
                <TextBlock Text="Sign in to your account" FontSize="14"
                           Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center"
                           FontFamily="{DynamicResource AppFont}" Margin="0,6,0,32"/>

                <!-- Username -->
                <TextBlock Text="Username" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8"
                           FontFamily="{DynamicResource AppFont}"/>
                <TextBox Style="{DynamicResource ModernTextBox}"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Padding="14,12" Margin="0,0,0,20"/>

                <!-- Password -->
                <TextBlock Text="Password" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8"
                           FontFamily="{DynamicResource AppFont}"/>
                <PasswordBox Style="{DynamicResource ModernPasswordBox}"
                             helpers:PasswordHelper.BindPassword="True"
                             helpers:PasswordHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Padding="14,12" Margin="0,0,0,8"/>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}"
                           FontSize="12" Margin="0,0,0,16" TextWrapping="Wrap"
                           FontFamily="{DynamicResource AppFont}"/>

                <!-- Login Button -->
                <Button Content="🔐  Sign In" Style="{DynamicResource PrimaryButton}"
                        Command="{Binding LoginCommand}" FontSize="16"
                        Padding="0,14" Margin="0,0,0,20"
                        IsDefault="True"/>

                <!-- Footer -->
                <TextBlock Text="Default: admin / admin123" FontSize="11"
                           Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center"
                           FontFamily="{DynamicResource AppFont}" Opacity="0.6"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
