<Window x:Class="GroceryPOS.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:GroceryPOS.Views"
        xmlns:vm="clr-namespace:GroceryPOS.ViewModels"
        xmlns:converters="clr-namespace:GroceryPOS.Converters"
        Title="GroceryPOS — Point of Sale" Height="780" Width="1280"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Icon="/Assets/logo.png"
        Background="{DynamicResource BgBrush}" FontFamily="{DynamicResource AppFont}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <local:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductsViewModel}">
            <local:ProductsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BillingViewModel}">
            <local:BillingView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
            <local:ReportsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SupplierBillsViewModel}">
            <local:SupplierBillsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReturnViewModel}">
            <local:ReturnView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CustomerManagementViewModel}">
            <local:CustomerManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CustomerLedgerViewModel}">
            <local:CustomerLedgerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SupplierManagementViewModel}">
            <local:SupplierManagementView/>
        </DataTemplate>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBgBrush}"
                Width="240"
                Visibility="{Binding IsSidebarVisible, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <!-- Sidebar Header -->
                <StackPanel DockPanel.Dock="Top" Margin="0,20,0,20">
                    <Image Source="/Assets/logo.png" Height="60" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="GroceryPOS" FontSize="20" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" FontFamily="{DynamicResource AppFont}"/>
                    <TextBlock Text="Enterprise Edition" FontSize="11" Foreground="#3B82F6" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,2,0,0" FontFamily="{DynamicResource AppFont}"/>
                </StackPanel>

                <!-- User Info + Logout at Bottom -->
                <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,15">
                    <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="{Binding CurrentUserName}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="White" FontFamily="{DynamicResource AppFont}"/>
                            <TextBlock Text="{Binding CurrentUserRole}" FontSize="11" Foreground="#94A3B8"
                                       FontFamily="{DynamicResource AppFont}" Margin="0,1,0,0"/>
                        </StackPanel>
                    </Border>
                    <Button Content="🚪  Logout" Style="{DynamicResource SidebarButton}"
                            Command="{Binding LogoutCommand}" Foreground="#F87171" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Navigation Menu -->
                <StackPanel Margin="0,0,0,0">
                    <Button Content="📊  Dashboard" Command="{Binding NavigateCommand}" CommandParameter="Dashboard">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedMenu}" Value="Dashboard">
                                        <Setter Property="Background" Value="#334155"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="📦  Products" Command="{Binding NavigateCommand}" CommandParameter="Products"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedMenu}" Value="Products">
                                        <Setter Property="Background" Value="#334155"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="💳  Billing" Command="{Binding NavigateCommand}" CommandParameter="Billing">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedMenu}" Value="Billing">
                                        <Setter Property="Background" Value="#334155"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="👥  Customers" Command="{Binding NavigateCommand}" CommandParameter="Customers">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedMenu}" Value="Customers">
                                        <Setter Property="Background" Value="#334155"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="🤝  Suppliers" Command="{Binding NavigateCommand}" CommandParameter="Suppliers"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedMenu}" Value="Suppliers">
                                        <Setter Property="Background" Value="#334155"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="📈  Reports" Command="{Binding NavigateCommand}" CommandParameter="Reports"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedMenu}" Value="Reports">
                                        <Setter Property="Background" Value="#334155"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="🧾  Stock" Command="{Binding NavigateCommand}" CommandParameter="SupplierBills"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedMenu}" Value="SupplierBills">
                                        <Setter Property="Background" Value="#334155"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="🔄  Returns" Command="{Binding NavigateCommand}" CommandParameter="Returns">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedMenu}" Value="Returns">
                                        <Setter Property="Background" Value="#334155"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Current Content -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentView}" Margin="0"/>
        </Grid>
    </Grid>
</Window>
