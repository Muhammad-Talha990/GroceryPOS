<Window x:Class="GroceryPOS.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:GroceryPOS.Views"
        xmlns:vm="clr-namespace:GroceryPOS.ViewModels"
        xmlns:converters="clr-namespace:GroceryPOS.Converters"
        Title="GroceryPOS — Point of Sale" Height="780" Width="1280"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Background="{DynamicResource BgBrush}" FontFamily="{DynamicResource AppFont}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <local:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductsViewModel}">
            <local:ProductsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BillingViewModel}">
            <local:BillingView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
            <local:ReportsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BackupViewModel}">
            <local:BackupView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SupplierBillsViewModel}">
            <local:SupplierBillsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReturnViewModel}">
            <local:ReturnView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBgBrush}">
            <DockPanel>
                <!-- Sidebar Header -->
                <StackPanel DockPanel.Dock="Top" Margin="0,24,0,30">
                    <TextBlock Text="🛒" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="GroceryPOS" FontSize="20" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" FontFamily="{DynamicResource AppFont}"/>
                    <TextBlock Text="Point of Sale System" FontSize="12" Foreground="#94A3B8"
                               HorizontalAlignment="Center" Margin="0,4,0,0" FontFamily="{DynamicResource AppFont}"/>
                </StackPanel>

                <!-- User Info + Logout at Bottom -->
                <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,24">
                    <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{Binding CurrentUserName}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="White" FontFamily="{DynamicResource AppFont}"/>
                            <TextBlock Text="{Binding CurrentUserRole}" FontSize="12" Foreground="#94A3B8"
                                       FontFamily="{DynamicResource AppFont}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Button Content="🚪  Logout" Style="{DynamicResource SidebarButton}"
                            Command="{Binding LogoutCommand}" Foreground="#F87171" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Navigation Menu -->
                <StackPanel Margin="0,0,0,0">
                    <Button Content="📊  Dashboard" Style="{DynamicResource SidebarButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Dashboard"/>

                    <Button Content="📦  Products" Style="{DynamicResource SidebarButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Products"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"/>

                    <Button Content="💳  Billing" Style="{DynamicResource SidebarButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Billing"/>

                    <Button Content="📈  Reports" Style="{DynamicResource SidebarButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Reports"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"/>

                    <Button Content="💾  Backup" Style="{DynamicResource SidebarButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Backup"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"/>

                    <Button Content="🧾  Supplier Bills" Style="{DynamicResource SidebarButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="SupplierBills"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"/>

                    <Button Content="🔄  Returns" Style="{DynamicResource SidebarButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Returns"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}" Margin="0"/>
    </Grid>
</Window>
