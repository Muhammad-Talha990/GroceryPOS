<UserControl x:Class="GroceryPOS.Views.PendingPrintsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GroceryPOS.Converters"
             Background="{DynamicResource BgBrush}" FontFamily="{DynamicResource AppFont}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:CountToVisibilityConverter x:Key="InverseCountToVis" Inverse="True"/>
    </UserControl.Resources>

    <Grid Margin="30,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🖨️ Pending Prints" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="Bills that could not be printed or are waiting for a printer" FontSize="13"
                       Foreground="{DynamicResource SubTextBrush}"/>
        </StackPanel>

        <!-- Actions Bar -->
        <Border Grid.Row="1" Style="{DynamicResource CardBorder}" Margin="0,0,0,16" Padding="12">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="🔄 Refresh" Style="{DynamicResource SecondaryButton}"
                            Command="{Binding RefreshCommand}" Margin="0,0,8,0"/>
                    <Button Content="🖨️ Print Selected" Style="{DynamicResource PrimaryButton}"
                            Command="{Binding PrintSelectedCommand}" Margin="0,0,8,0"/>
                    <Button Content="✅ Mark as Printed" Style="{DynamicResource SecondaryButton}"
                            Command="{Binding MarkAsPrintedCommand}" Margin="0,0,8,0"/>
                    <Button Content="❌ Cancel Print" Style="{DynamicResource SidebarButton}"
                            Command="{Binding CancelPrintCommand}" Foreground="#F87171" Background="Transparent"/>
                </StackPanel>

                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" HorizontalAlignment="Right"
                           Foreground="{DynamicResource SubTextBrush}" FontSize="13" Margin="0,0,8,0"
                           DockPanel.Dock="Right" TextWrapping="Wrap"/>
            </DockPanel>
        </Border>

        <!-- Pending Bills Grid -->
        <Grid Grid.Row="2">
            <Border Style="{DynamicResource CardBorder}" Padding="0">
                <DataGrid ItemsSource="{Binding PendingBills}"
                          SelectedItem="{Binding SelectedBill}"
                          Style="{DynamicResource ModernDataGrid}"
                          ColumnHeaderStyle="{DynamicResource ModernDataGridColumnHeader}"
                          RowStyle="{DynamicResource ModernDataGridRow}"
                          CellStyle="{DynamicResource ModernDataGridCell}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Invoice #" Binding="{Binding InvoiceNumber}" Width="90"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="70"/>
                        <DataGridTextColumn Header="Date" Binding="{Binding BillDateTime, StringFormat='dd/MM/yyyy HH:mm'}" Width="140"/>
                        <DataGridTextColumn Header="Customer" Binding="{Binding Customer.Name}" Width="130"/>
                        <DataGridTextColumn Header="Cashier" Binding="{Binding User.FullName}" Width="130"/>
                        <DataGridTextColumn Header="Attempts" Binding="{Binding PrintAttempts}" Width="75"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Empty State -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding PendingBills.Count, Converter={StaticResource InverseCountToVis}}">
                <TextBlock Text="🖨️" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.5"/>
                <TextBlock Text="No pending prints" FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="All bills have been successfully printed or cancelled."
                           FontSize="13" Foreground="{DynamicResource SubTextBrush}"
                           Margin="0,8,0,0" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Loading Overlay -->
            <Border Background="#80000000" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Loading..." Foreground="White" HorizontalAlignment="Center"
                           VerticalAlignment="Center" FontSize="18"/>
            </Border>
        </Grid>

        <!-- Footer Tip -->
        <Border Grid.Row="3" Margin="0,16,0,0" Padding="12,10" CornerRadius="8"
                Background="#FFF1F2" BorderBrush="#FECACA" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="💡 Tip: " FontWeight="Bold" Foreground="#B91C1C" Margin="0,0,6,0"/>
                <TextBlock TextWrapping="Wrap" Foreground="#B91C1C"
                           Text="If a printer was disconnected, reconnect it and ensure it is 'Online' in Windows before clicking 'Print Selected'. Use 'Mark as Printed' if the bill was printed manually."/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
