<UserControl x:Class="GroceryPOS.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GroceryPOS.Converters"
             xmlns:controls="clr-namespace:GroceryPOS.Views.Controls"
             Background="{DynamicResource BgBrush}" FontFamily="{DynamicResource AppFont}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:CountToVisibilityConverter x:Key="CountToVis"/>
        <converters:CountToVisibilityConverter x:Key="InverseCountToVis" Inverse="True"/>
        <converters:NumericToVisibilityConverter x:Key="NumericToVis"/>
    </UserControl.Resources>

    <Grid Margin="30,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="📈 Sales Reports" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="View and analyze your sales data" FontSize="13"
                       Foreground="{DynamicResource SubTextBrush}"/>
        </StackPanel>

        <!-- Filters -->
        <Border Grid.Row="1" Style="{DynamicResource CardBorder}" Margin="0,0,0,16" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="Report Type" FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,4"/>
                    <ComboBox Style="{DynamicResource ModernComboBox}" 
                              SelectedValuePath="Content"
                              SelectedValue="{Binding SelectedReportType}" Width="140">
                        <ComboBoxItem Content="Daily"/>
                        <ComboBoxItem Content="Weekly"/>
                        <ComboBoxItem Content="Monthly"/>
                        <ComboBoxItem Content="Custom Range"/>
                        <ComboBoxItem Content="Product-wise"/>
                        <ComboBoxItem Content="Low Stock"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,16,0"
                            Visibility="{Binding IsFromDateVisible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding FromDateLabel}" FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,4"/>
                    <DatePicker SelectedDate="{Binding FromDate}" Width="150" FontSize="13"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,16,0"
                            Visibility="{Binding IsToDateVisible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="To Date" FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,4"/>
                    <DatePicker SelectedDate="{Binding ToDate}" Width="150" FontSize="13"/>
                </StackPanel>

                <Button Grid.Column="4" Content="📥 Export CSV" Style="{DynamicResource PrimaryButton}"
                        Command="{Binding ExportReportCommand}" VerticalAlignment="Bottom" Padding="20,10"
                        Margin="0,0,16,0"/>

                <!-- Summary -->
                <StackPanel Grid.Column="5" HorizontalAlignment="Right" Margin="0,0,12,0"
                            Visibility="{Binding IsRevenueVisible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Total Revenue" FontSize="11" Foreground="{DynamicResource SubTextBrush}"/>
                    <TextBlock FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}">
                        <TextBlock.Text>
                            <Binding Path="TotalRevenue" StringFormat="Rs.{0:N0}"/>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="6" HorizontalAlignment="Right">
                    <TextBlock Text="Total Count" FontSize="11" Foreground="{DynamicResource SubTextBrush}"/>
                    <TextBlock Text="{Binding TotalSalesCount}" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sales Report Grid -->
        <Border Grid.Row="2" Style="{DynamicResource CardBorder}" Padding="0"
                Visibility="{Binding ShowSalesGrid, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <!-- Legend -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="16,10" HorizontalAlignment="Right">
                    <Border Background="#FEE2E2" Width="12" Height="12" CornerRadius="2" Margin="0,0,6,0" BorderBrush="#FECACA" BorderThickness="1"/>
                    <TextBlock Text="Return" FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                    
                    <Border Background="#FEF9C3" Width="12" Height="12" CornerRadius="2" Margin="0,0,6,0" BorderBrush="#FEF08A" BorderThickness="1"/>
                    <TextBlock Text="Credit Sale" FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                    
                    <Border Background="Transparent" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Width="12" Height="12" CornerRadius="2" Margin="0,0,6,0"/>
                    <TextBlock Text="Normal Sale" FontSize="11" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <DataGrid ItemsSource="{Binding SalesReport}"
                          Style="{DynamicResource ModernDataGrid}"
                          ColumnHeaderStyle="{DynamicResource ModernDataGridColumnHeader}"
                          CellStyle="{DynamicResource ModernDataGridCell}">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource ModernDataGridRow}">
                        <Style.Triggers>
                            <!-- Return Report: Light Red -->
                            <DataTrigger Binding="{Binding IsReturn}" Value="True">
                                <Setter Property="Background" Value="#FEE2E2"/>
                            </DataTrigger>
                            <!-- Credit Report: Light Yellow -->
                            <DataTrigger Binding="{Binding HasPendingCredit}" Value="True">
                                <Setter Property="Background" Value="#FEF9C3"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Invoice #" Binding="{Binding InvoiceNumber}" Width="110"/>
                    <DataGridTextColumn Header="Customer" Binding="{Binding Customer.Name}" Width="150"/>
                    <DataGridTextColumn Header="Cashier" Binding="{Binding User.FullName}" Width="140"/>
                    <DataGridTextColumn Header="Date/Time" Binding="{Binding SaleDate, StringFormat='dd/MM/yyyy HH:mm'}" Width="*"/>
                    
                    <DataGridTemplateColumn Header="Actions" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="📂 View" Style="{DynamicResource AccentButton}" 
                                            Command="{Binding DataContext.ViewBillCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" Margin="0,0,8,0" Padding="8,4" FontSize="11"/>
                                    <Button Content="🖨️ Print" Style="{DynamicResource PrimaryButton}" 
                                            Command="{Binding DataContext.PrintBillCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" Padding="8,4" FontSize="11" Background="{DynamicResource SuccessBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
            </DockPanel>
        </Border>

        <!-- Product-wise Report Grid -->
        <Border Grid.Row="2" Style="{DynamicResource CardBorder}" Padding="0"
                Visibility="{Binding ShowProductGrid, Converter={StaticResource BoolToVis}}">
            <DataGrid ItemsSource="{Binding ProductReport}"
                      Style="{DynamicResource ModernDataGrid}"
                      ColumnHeaderStyle="{DynamicResource ModernDataGridColumnHeader}"
                      RowStyle="{DynamicResource ModernDataGridRow}"
                      CellStyle="{DynamicResource ModernDataGridCell}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Product Name" Binding="{Binding ItemDescription}" Width="*"/>
                    <DataGridTextColumn Header="Quantity Sold" Binding="{Binding QuantitySold}" Width="120"/>
                    <DataGridTextColumn Header="Total Revenue" Binding="{Binding TotalRevenue, StringFormat='Rs.{0:N0}'}" Width="140"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Low Stock Report Grid -->
        <Grid Grid.Row="2" Visibility="{Binding ShowLowStockGrid, Converter={StaticResource BoolToVis}}">
            <Border Style="{DynamicResource CardBorder}" Padding="0">
                <DataGrid ItemsSource="{Binding LowStockReport}"
                          Style="{DynamicResource ModernDataGrid}"
                          ColumnHeaderStyle="{DynamicResource ModernDataGridColumnHeader}"
                          RowStyle="{DynamicResource ModernDataGridRow}"
                          CellStyle="{DynamicResource ModernDataGridCell}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Barcode" Binding="{Binding ItemId}" Width="150"/>
                        <DataGridTextColumn Header="Product Name" Binding="{Binding Description}" Width="*"/>
                        <DataGridTextColumn Header="Category" Binding="{Binding ItemCategory}" Width="150"/>
                        <DataGridTextColumn Header="Current Stock" Binding="{Binding StockQuantity}" Width="120"/>
                        <DataGridTextColumn Header="Min. Threshold" Binding="{Binding MinStockThreshold}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
            
            <!-- Empty State Message -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding LowStockReport.Count, Converter={StaticResource InverseCountToVis}}">
                <TextBlock Text="✅ All stock levels are healthy" FontSize="18" FontWeight="SemiBold" 
                           Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="No items are currently below their minimum threshold." FontSize="13" 
                           Foreground="{DynamicResource SubTextBrush}" Margin="0,8,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
        <Border Grid.RowSpan="3" Visibility="{Binding IsBillDetailOpen, Converter={StaticResource BoolToVis}}" 
                Background="#CC000000" IsHitTestVisible="True">
            <Border Background="White" CornerRadius="4" Padding="0"
                    VerticalAlignment="Center" HorizontalAlignment="Center" 
                    Width="400" MaxHeight="750"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.3" Color="Black"/>
                </Border.Effect>
                <DockPanel>
                    <!-- Modal Header (Close Button) -->
                    <Grid DockPanel.Dock="Top" Background="#F8FAFC" Height="40">
                         <Button HorizontalAlignment="Right" Content="X" 
                                Background="Transparent" Foreground="#64748B" FontSize="16"
                                Padding="15,0" BorderThickness="0" Cursor="Hand"
                                Command="{Binding CloseBillDetailCommand}"/>
                    </Grid>

                    <!-- Print Button at Bottom -->
                    <Border DockPanel.Dock="Bottom" Background="#F8FAFC" Padding="20,15" BorderThickness="0,1,0,0" BorderBrush="#E2E8F0">
                        <Button Content="🖨️  Re-Print Receipt" Command="{Binding PrintBillCommand}" CommandParameter="{Binding SelectedHistoryBill}"
                                Style="{DynamicResource PrimaryButton}" Background="#22C55E" Padding="20,10" HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Shared Receipt Control -->
                    <controls:BillReceiptControl Bill="{Binding SelectedHistoryBill}"/>
                </DockPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
