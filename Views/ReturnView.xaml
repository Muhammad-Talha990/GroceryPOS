<UserControl x:Class="GroceryPOS.Views.ReturnView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:GroceryPOS.Converters"
             xmlns:helpers="clr-namespace:GroceryPOS.Helpers"
             mc:Ignorable="d" 
             Background="{DynamicResource BgBrush}" FontFamily="{DynamicResource AppFont}">
    <UserControl.Resources>
        <converters:StatusColorConverter x:Key="StatusColorConverter"/>
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        
        <Style x:Key="CustomerBillComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#1E293B"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EEF2FF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid Margin="20,12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        
        <!-- Main Content (Column 0) -->
        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- 0: Header -->
                <RowDefinition Height="Auto"/> <!-- 1: Search Bar & Status -->
                <RowDefinition Height="Auto"/> <!-- 2: Top Bill Details Banner -->
                <RowDefinition Height="*" MinHeight="150"/> <!-- 3: Items available for return (Cart) -->
                <RowDefinition Height="Auto"/> <!-- 4: Bottom Return Summary & Total Amount -->
                <RowDefinition Height="Auto"/> <!-- 5: History Title -->
                <RowDefinition Height="Auto"/> <!-- 6: Return History Table -->
                <RowDefinition Height="Auto"/> <!-- 7: Action Buttons -->
            </Grid.RowDefinitions>

        <!-- Header (Row 0) -->
        <StackPanel Grid.Row="0" Margin="0,0,0,4">
            <TextBlock Text="🔄 Bill Item Return" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
            <TextBlock Text="Process product returns from previous bills" FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="0,1,0,0"/>
        </StackPanel>

        <!-- Search Bar (Row 1) -->
        <Border Grid.Row="1" Style="{DynamicResource CardBorder}" Padding="8,6" Margin="0,0,0,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="380"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Enter Bill ID:" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold" FontSize="11"/>
                <TextBox Grid.Row="0" Grid.Column="1" Style="{DynamicResource ModernTextBox}" Text="{Binding BillIdInput, UpdateSourceTrigger=PropertyChanged}" FontSize="12" Height="28" Padding="6,2">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <Button Grid.Row="0" Grid.Column="2" Content="🔍 Search Bill" Style="{DynamicResource PrimaryButton}" Command="{Binding SearchCommand}" Margin="6,0,0,0" Padding="12,0" Height="28" FontSize="11"/>

                <TextBlock Grid.Row="0" Grid.Column="4" Text="Customer Phone:" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold" FontSize="11"/>
                <TextBox Grid.Row="0" Grid.Column="5" Style="{DynamicResource ModernTextBox}" Text="{Binding CustomerPhoneInput, UpdateSourceTrigger=PropertyChanged}" FontSize="12" MaxLength="11" Height="28" Padding="6,2">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchByPhoneCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <Button Grid.Row="0" Grid.Column="6" Content="📱 Search Bills" Style="{DynamicResource SecondaryButton}" Command="{Binding SearchByPhoneCommand}" Margin="6,0,0,0" Padding="8,0" MinWidth="90" Height="28" FontSize="11"/>

                <ComboBox Grid.Row="0" Grid.Column="7"
                          Margin="12,0,0,0"
                          Style="{StaticResource CustomerBillComboBoxStyle}"
                          ItemsSource="{Binding CustomerBills}"
                          SelectedItem="{Binding SelectedCustomerBill}"
                          IsEnabled="{Binding HasCustomerBills}"
                          HorizontalContentAlignment="Stretch"
                          MinWidth="380"
                          ToolTip="Select bill found by customer phone">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="6,4" CornerRadius="4" Margin="0,2" x:Name="ItemBorder">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <!-- Highlight style for bills with pending amount -->
                                        <Setter Property="Background" Value="#FEF9C3"/>
                                        <Setter Property="BorderBrush" Value="#FEF08A"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RemainingAmount}" Value="0">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RemainingAmount}" Value="0.0">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Text="{Binding InvoiceNumber, StringFormat='Bill #{0}'}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#0F172A"/>
                                        <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:dd MMM yyyy, hh:mm tt}'}"
                                                   FontSize="11"
                                                   Foreground="#64748B"
                                                   x:Name="DateText"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" x:Name="RightPanel">
                                        <TextBlock Text="{Binding GrandTotal, StringFormat='Total: Rs. {0:N0}'}"
                                                   FontSize="11"
                                                   Foreground="#1E293B"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Text="{Binding RemainingAmount, StringFormat='Pending: Rs. {0:N0}'}"
                                                   FontSize="11"
                                                   HorizontalAlignment="Right">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <!-- Highlight text style -->
                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RemainingAmount}" Value="0">
                                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                                            <Setter Property="FontWeight" Value="Normal"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding RemainingAmount}" Value="0.0">
                                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                                            <Setter Property="FontWeight" Value="Normal"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ComboBoxItem}}" Value="{x:Null}">
                                    <Setter TargetName="RightPanel" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="DateText" Property="Visibility" Value="Collapsed"/>
                                    <!-- Also remove border and background highlight when in the selection box to keep it clean -->
                                    <Setter TargetName="ItemBorder" Property="Background" Value="Transparent"/>
                                    <Setter TargetName="ItemBorder" Property="BorderThickness" Value="0"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Row="0" Grid.Column="8"
                        Content="Load"
                        Style="{DynamicResource AccentButton}"
                        Command="{Binding LoadSelectedBillCommand}"
                        Margin="8,0,0,0"
                        Padding="12,0"
                        Height="28" FontSize="11"
                        IsEnabled="{Binding HasCustomerBills}"/>

                <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="10" Margin="0,2,0,0">
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                               Foreground="{Binding StatusMessage, Converter={StaticResource StatusColorConverter}}"
                               FontWeight="Medium" TextWrapping="Wrap"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Top Bill & Customer Details Banner (Row 2) -->
        <Border Grid.Row="2" Style="{DynamicResource CardBorder}" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="8,6" Margin="0,0,0,4"
                Visibility="{Binding OriginalBill, Converter={StaticResource NullToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.5*"/> <!-- Customer Info -->
                    <ColumnDefinition Width="1"/>    <!-- Separator -->
                    <ColumnDefinition Width="2*"/>   <!-- Bill Info -->
                    <ColumnDefinition Width="1"/>    <!-- Separator -->
                    <ColumnDefinition Width="2.5*"/> <!-- Financial Summary -->
                </Grid.ColumnDefinitions>

                <!-- Left Column: Customer Details -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                        <TextBlock Text="👤 CUSTOMER DETAILS" FontSize="10" FontWeight="Black" Foreground="{DynamicResource PrimaryBrush}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding DisplayCustomerName}" FontSize="12" FontWeight="Bold" Foreground="#0F172A" TextTrimming="CharacterEllipsis"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="📱 Phone:" FontSize="12" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding DisplayCustomerPhone}" FontSize="12" Foreground="#334155" FontWeight="Medium"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="📍 Address:" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding DisplayCustomerAddress}" FontSize="11" Foreground="#334155" FontWeight="Medium" TextWrapping="Wrap" MaxHeight="30" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </StackPanel>

                <!-- Vertical Separator -->
                <Rectangle Grid.Column="1" Fill="#E2E8F0" Width="1" Margin="0,2"/>

                <!-- Middle Column: Bill Details -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="16,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                        <TextBlock Text="📄 BILL INFORMATION" FontSize="10" FontWeight="Black" Foreground="{DynamicResource PrimaryBrush}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding DisplayInvoiceNumber}" FontSize="12" FontWeight="Bold" Foreground="#0F172A"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="🕒 Date:" FontSize="12" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding DisplayBillDate}" FontSize="12" Foreground="#334155" FontWeight="Medium"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="💳 Payment:" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding DisplayPaymentMethod}" FontSize="11" Foreground="#334155" FontWeight="Medium"/>
                    </StackPanel>
                </StackPanel>

                <!-- Vertical Separator -->
                <Rectangle Grid.Column="3" Fill="#E2E8F0" Width="1" Margin="0,2"/>

                <!-- Right Column: Financial Overview -->
                <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="16,0,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                        <TextBlock Text="💰 BILL FINANCIALS" FontSize="10" FontWeight="Black" Foreground="{DynamicResource PrimaryBrush}"/>
                    </StackPanel>
                    <Grid Margin="0,1">
                        <TextBlock Text="Original Total:" FontSize="11" Foreground="#64748B" FontWeight="Medium"/>
                        <TextBlock Text="{Binding DisplayOriginalTotal, StringFormat='Rs. {0:N0}'}" FontSize="12" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,1">
                        <TextBlock Text="Paid Amount:" FontSize="11" Foreground="#64748B" FontWeight="Medium"/>
                        <TextBlock Text="{Binding DisplayPaidAmount, StringFormat='Rs. {0:N0}'}" FontSize="12" FontWeight="Bold" Foreground="#16A34A" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,1">
                        <TextBlock Text="Remaining Due / Credit:" FontSize="11" Foreground="#64748B" FontWeight="Medium"/>
                        <TextBlock Text="{Binding DisplayRemainingDue, StringFormat='Rs. {0:N0}'}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#DC2626"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DisplayRemainingDue}" Value="0">
                                            <Setter Property="Foreground" Value="#16A34A"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <Grid Margin="0,1">
                        <TextBlock Text="Returned Amount:" FontSize="11" Foreground="#64748B" FontWeight="Medium"/>
                        <TextBlock Text="{Binding DisplayReturnedAmount, StringFormat='Rs. {0:N0}'}" FontSize="12" FontWeight="Bold" Foreground="#EF4444" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Items available for return (Cart) (Row 3) -->
        <GroupBox Grid.Row="3" Header="Items available for return" Foreground="{DynamicResource SubTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" VerticalAlignment="Stretch">
            <Border Style="{DynamicResource CardBorder}" Padding="0">
                <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" CanUserAddRows="False" Style="{DynamicResource ModernDataGrid}"
                          ColumnHeaderStyle="{DynamicResource ModernDataGridColumnHeader}" CellStyle="{DynamicResource ModernDataGridCell}"
                          VerticalAlignment="Stretch" MinHeight="150" RowHeight="26">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource ModernDataGridRow}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RemainingQuantity}" Value="0">
                                    <Setter Property="Background" Value="#1AEE4444"/> <!-- Very subtle red tint -->
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Product Description" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Padding="4,2" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat='Rs. {0:N2}'}" Width="100" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="0,0,10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Sold" Binding="{Binding OriginalQuantity}" Width="65" IsReadOnly="True">
                             <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Ret" Binding="{Binding AlreadyReturned}" Width="60" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Rem" Binding="{Binding RemainingQuantity}" Width="60" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RemainingQuantity}" Value="0">
                                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="Return Qty" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding ReturnQuantity, UpdateSourceTrigger=PropertyChanged}" 
                                             helpers:FocusHelper.SelectAllOnFocus="True"
                                             helpers:FocusHelper.DecimalOnly="True"
                                             HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                             FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"
                                             Background="Transparent" BorderThickness="1" 
                                             BorderBrush="{DynamicResource PrimaryBrush}"
                                             Padding="4,2" Margin="4,2"
                                             VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Return Amount" Binding="{Binding TotalPrice, StringFormat='Rs. {0:N2}'}" Width="120" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="0,0,10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </GroupBox>

        <!-- Bottom Return Summary & Total Amount (Row 4) -->
        <Border Grid.Row="4" Style="{DynamicResource CardBorder}" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="12,8" Margin="0,0,0,6"
                Visibility="{Binding OriginalBill, Converter={StaticResource NullToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/> <!-- Breakdown Details -->
                    <ColumnDefinition Width="Auto"/> <!-- Total Return Amount -->
                </Grid.ColumnDefinitions>

                <!-- Left Side: Credit Recovery & Cash Refund Breakdown -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                    <!-- When there is credit recovery -->
                    <StackPanel Orientation="Horizontal" Visibility="{Binding ShowLiveCreditRecovery, Converter={StaticResource BoolToVis}}" Margin="0,0,0,4">
                        <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔁 Credits Recovered: " FontSize="12" FontWeight="Bold" Foreground="#1E40AF"/>
                                <TextBlock Text="{Binding LiveCreditRecovery, StringFormat='Rs. {0:N2}'}" FontSize="12" FontWeight="Black" Foreground="#1D4ED8"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="(Adjusted against customer pending due)" FontSize="11" Foreground="#64748B" VerticalAlignment="Center" FontStyle="Italic"/>
                    </StackPanel>

                    <!-- When there is cash refund -->
                    <StackPanel Orientation="Horizontal" Visibility="{Binding ShowLiveCashRefund, Converter={StaticResource BoolToVis}}">
                        <Border Background="#FEF3C7" BorderBrush="#FDE68A" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💵 CASH REFUND DUE: " FontSize="12" FontWeight="Bold" Foreground="#92400E"/>
                                <TextBlock Text="{Binding LiveCashRefund, StringFormat='Rs. {0:N2}'}" FontSize="12" FontWeight="Black" Foreground="#B45309"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="(Remaining amount returned to customer)" FontSize="11" Foreground="#64748B" VerticalAlignment="Center" FontStyle="Italic"
                                   Visibility="{Binding ShowLiveCreditRecovery, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="(Full return amount paid in cash)" FontSize="11" Foreground="#64748B" VerticalAlignment="Center" FontStyle="Italic"
                                   Visibility="{Binding ShowLiveCreditRecovery, Converter={StaticResource InvBoolToVis}}"/>
                    </StackPanel>

                    <!-- When 0 return amount entered -->
                    <TextBlock Text="ℹ Enter return quantity in table above to calculate refund &amp; credit adjustment." 
                               FontSize="12" Foreground="#94A3B8" FontStyle="Italic"
                               Visibility="{Binding HasLiveReturn, Converter={StaticResource InvBoolToVis}}"/>
                </StackPanel>

                <!-- Right Side: Total Return Amount -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="TOTAL RETURN AMOUNT" FontSize="11" FontWeight="Black" Foreground="#64748B" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding CurrentReturnGrandTotal, StringFormat='Rs. {0:N2}'}" FontSize="22" FontWeight="Black" Foreground="#15803D" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- History Title (Row 5) -->
        <TextBlock Grid.Row="5" Text="📜 Previous Returns for this Bill" FontSize="16" FontWeight="Bold" Margin="0,15,0,8"
                   Visibility="{Binding ReturnHistory.Count, Converter={StaticResource CountToVisibilityConverter}}"
                   xmlns:conv="clr-namespace:GroceryPOS.Converters"/>

        <!-- Return History (Row 6) -->
        <Border Grid.Row="6" Style="{DynamicResource CardBorder}" Padding="0" Margin="0,0,0,10"
                Visibility="{Binding ReturnHistory.Count, Converter={StaticResource CountToVisibilityConverter}}">
            <DataGrid ItemsSource="{Binding ReturnHistory}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                      Style="{DynamicResource ModernDataGrid}" MaxHeight="110"
                      ColumnHeaderStyle="{DynamicResource ModernDataGridColumnHeader}" RowStyle="{DynamicResource ModernDataGridRow}" CellStyle="{DynamicResource ModernDataGridCell}">
                 <DataGrid.Columns>
                    <DataGridTextColumn Header="Return #" Binding="{Binding ReturnBillId}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Date/Time" Binding="{Binding ReturnedAt, StringFormat='{}{0:dd-MMM-yyyy hh:mm tt}'}" Width="165"/>
                    <DataGridTemplateColumn Header="Product" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ProductDescription}" TextWrapping="Wrap" Padding="4,2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Barcode" Binding="{Binding ProductId}" Width="120"/>
                    <DataGridTextColumn Header="Qty" Binding="{Binding ReturnQuantity}" Width="55">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat='{}{0:N2}'}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Total Amount" Binding="{Binding TotalAmount, StringFormat='{}{0:N2}'}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer Actions (Row 7) -->
        <Border Grid.Row="7" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="✖ Clear" Style="{DynamicResource SecondaryButton}" Width="110" Margin="0,0,15,0" Command="{Binding ClearFormCommand}"/>
                <Button Content="View Preview" Style="{DynamicResource AccentButton}" Width="150" Margin="0,0,15,0" 
                        Command="{Binding TogglePreviewCommand}"
                        Visibility="{Binding OriginalBill, Converter={StaticResource NullToVisibilityConverter}}"/>
                <Button Content="🔄 Process Return" Style="{DynamicResource PrimaryButton}" Width="190" Height="48" Command="{Binding ProcessReturnCommand}" FontSize="15" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>

    <!-- Right Column: Receipt Preview (Professional Drawer Look) -->
    <Border Grid.Column="1" Width="300" Margin="20,0,0,0" 
            Visibility="{Binding IsPreviewVisible, Converter={StaticResource BoolToVis}}"
            Background="White" CornerRadius="16" UseLayoutRounding="True" SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.12" Color="#000000"/>
        </Border.Effect>
        
        <DockPanel>
            <!-- Preview Header -->
            <Grid DockPanel.Dock="Top" Margin="20,16">
                <TextBlock Text="Return Journey Preview" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}"/>
                <Button Content="X" HorizontalAlignment="Right" VerticalAlignment="Center" 
                        Background="Transparent" BorderThickness="0" Foreground="{DynamicResource SubTextBrush}"
                        Command="{Binding TogglePreviewCommand}" Cursor="Hand" FontSize="14">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <Separator DockPanel.Dock="Top" Background="#F1F5F9" Margin="0" Height="1"/>

            <!-- The "Paper" Receipt -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                <StackPanel Background="White">
                    <!-- Store Header -->
                    <TextBlock Text="{Binding StoreName}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#1E293B"/>
                    <TextBlock Text="{Binding StoreAddress}" FontSize="10" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Foreground="#64748B" Margin="0,4"/>
                    <TextBlock Text="{Binding StorePhone, StringFormat='Ph: {0}'}" FontSize="11" HorizontalAlignment="Center" Foreground="#64748B"/>
                    
                    <Border BorderThickness="0,0,0,1" BorderBrush="#E2E8F0" Margin="0,12" SnapsToDevicePixels="True"/>
                    
                    <!-- ─── ORIGINAL BILL SECTION ─── -->
                    <TextBlock Text="━ ORIGINAL PURCHASE ━" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,5"/>
                    <Grid>
                        <TextBlock Text="{Binding OriginalBill.InvoiceNumber, StringFormat='No: {0}'}" FontSize="10" Foreground="#475569" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding OriginalBill.BillDateTime, StringFormat='{}{0:dd MMM HH:mm}'}" FontSize="10" HorizontalAlignment="Right" Foreground="#64748B"/>
                    </Grid>
                    
                    <ItemsControl ItemsSource="{Binding OriginalBill.Items}" Margin="0,5,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <TextBlock Text="{Binding ItemDescription}" FontSize="11" Foreground="#475569" MaxWidth="180" TextWrapping="NoWrap"/>
                                    <TextBlock Text="{Binding Quantity, StringFormat='x{0}'}" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Right" Margin="0,0,60,0"/>
                                    <TextBlock Text="{Binding TotalPrice, StringFormat='{}{0:N2}'}" FontSize="11" HorizontalAlignment="Right" Foreground="#1E293B"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{Binding OriginalBill.GrandTotal, StringFormat='Original Total: Rs.{0:N0}'}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" Foreground="#64748B" Margin="0,4,0,0"/>

                    <Border BorderThickness="0,0,0,1" BorderBrush="#E2E8F0" Margin="0,12" SnapsToDevicePixels="True"/>

                    <!-- ─── PREVIOUS RETURNS SECTION ─── -->
                    <ItemsControl ItemsSource="{Binding ReturnHistory}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock FontSize="10" FontWeight="Bold" Foreground="#EF4444" HorizontalAlignment="Center" Margin="0,0,0,4">
                                        <Run Text="━ "/><Run Text="{Binding ReturnBillId, Mode=OneWay}"/><Run Text=" (Past) ━"/>
                                    </TextBlock>
                                    <Grid>
                                        <TextBlock Text="{Binding ProductDescription}" FontSize="11" Foreground="#475569" MaxWidth="180"/>
                                        <TextBlock Text="{Binding ReturnQuantity, StringFormat='x{0}'}" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding ReturnDate}" FontSize="9" Foreground="#94A3B8" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,-12"/>
                                    </Grid>
                                    <Separator Background="#F1F5F9" Margin="0,15,0,2"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ─── NEW RETURN PREVIEW ─── -->
                    <StackPanel Visibility="{Binding CurrentReturnPreviewItems.Count, Converter={StaticResource CountToVisibilityConverter}}">
                        <TextBlock Text="━━━ NEW RETURN (NOW) ━━━" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center" Margin="0,10,0,10"/>
                        
                        <ItemsControl ItemsSource="{Binding CurrentReturnPreviewItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#334155" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding ReturnQuantity, StringFormat='Qty to return: {0}'}" FontSize="10" Foreground="#64748B"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding TotalPrice, StringFormat='{}{0:N2}'}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#1E293B"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Rectangle Stroke="#E2E8F0" StrokeDashArray="4 2" StrokeThickness="1" Height="1" Margin="0,15" SnapsToDevicePixels="True"/>
                        
                        <Border Background="#F0FDF4" CornerRadius="8" Padding="12,10" Margin="0,10">
                            <Grid>
                                <TextBlock Text="RETURN TOTAL" FontSize="14" FontWeight="Bold" Foreground="#166534" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CurrentReturnGrandTotal, StringFormat='Rs.{0:N0}'}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right" Foreground="#15803D"/>
                            </Grid>
                        </Border>

                        <!-- Remaining Due (Calculated) -->
                        <Border Style="{StaticResource CardBorder}" Background="#FFF1F2" Padding="12,8" Margin="0,4" BorderBrush="#FECDD3"
                                Visibility="{Binding OriginalBill, Converter={StaticResource NullToVisibilityConverter}}">
                            <Grid>
                                <TextBlock Text="REMAINING DUE" FontSize="12" FontWeight="Bold" Foreground="#BE123C" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding PreviewRemainingDue, StringFormat='Rs.{0:N0}'}" FontSize="15" FontWeight="Bold" HorizontalAlignment="Right" Foreground="#E11D48"/>
                            </Grid>
                        </Border>

                        <!-- ── Return Outcome Summary ── -->

                        <!-- Cash Refund Row (visible only when cash refund > 0) -->
                        <Border CornerRadius="8" Padding="12,8" Margin="0,4"
                                Background="#FEF3C7"
                                Visibility="{Binding ShowLiveCashRefund, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="💵 CASH REFUND" FontSize="11" FontWeight="Bold" Foreground="#92400E"/>
                                <TextBlock FontSize="12" Foreground="#78350F" Margin="0,2,0,0">
                                    <Run Text="Amount to return: Rs. "/>
                                    <Run Text="{Binding LiveCashRefund, StringFormat='{}{0:N0}', Mode=OneWay}" FontWeight="Bold"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Credit Adjustment Row (visible only when credit > 0) -->
                        <Border CornerRadius="8" Padding="12,8" Margin="0,4"
                                Background="#EFF6FF"
                                Visibility="{Binding ShowLiveCreditRecovery, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="🔁 ADJUSTED AGAINST CREDIT" FontSize="11" FontWeight="Bold" Foreground="#1D4ED8"/>
                                <TextBlock FontSize="12" Foreground="#1E40AF" Margin="0,2,0,0">
                                    <Run Text="Amount adjusted: Rs. "/>
                                    <Run Text="{Binding LiveCreditRecovery, StringFormat='{}{0:N0}', Mode=OneWay}" FontWeight="Bold"/>
                                </TextBlock>
                                <TextBlock Text="No cash refund for this portion." FontSize="10" Foreground="#3B82F6" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <TextBlock Text="No items selected for return" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center" FontStyle="Italic" Margin="0,20">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentReturnPreviewItems.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Footer -->
                    <StackPanel Margin="0,30,0,10">
                        <TextBlock Text="Thank you for your business!" FontSize="11" HorizontalAlignment="Center" Foreground="#94A3B8"/>
                        <TextBlock Text="Return Receipt Preview" FontSize="10" HorizontalAlignment="Center" Foreground="#CBD5E1" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>

    <!-- ═══ POPUP ERROR OVERLAY ═══ -->
    <Border Grid.ColumnSpan="2" Panel.ZIndex="3000" IsHitTestVisible="False"
            VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,40,0,0"
            Visibility="{Binding PopupErrorVisible, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
        <Border Background="White" CornerRadius="8" Padding="20,12"
                BorderBrush="#EF4444" BorderThickness="2">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.15" Color="Black"/>
            </Border.Effect>
            <TextBlock Text="{Binding PopupErrorMessage}" 
                       Foreground="#EF4444" FontSize="20" FontWeight="Bold" 
                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Border>
    </Border>
</Grid>
</UserControl>
