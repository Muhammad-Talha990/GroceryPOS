<UserControl x:Class="GroceryPOS.Views.ReturnView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:GroceryPOS.Converters"
             xmlns:helpers="clr-namespace:GroceryPOS.Helpers"
             mc:Ignorable="d" 
             Background="{DynamicResource BgBrush}" FontFamily="{DynamicResource AppFont}">
    <UserControl.Resources>
        <converters:StatusColorConverter x:Key="StatusColorConverter"/>
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    
    <Grid Margin="30,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        
        <!-- Main Content (Column 0) -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="200"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <!-- Header (Row 0) -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="🔄 Bill Item Return" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
            <TextBlock Text="Process product returns from previous bills" FontSize="14" Foreground="{DynamicResource SubTextBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Search Bar (Row 1) -->
        <Border Grid.Row="1" Style="{DynamicResource CardBorder}" Padding="16" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Enter Bill ID:" VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="SemiBold"/>
                <TextBox Grid.Column="1" Style="{DynamicResource ModernTextBox}" Text="{Binding BillIdInput, UpdateSourceTrigger=PropertyChanged}" FontSize="16">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <Button Grid.Column="2" Content="🔍 Search Bill" Style="{DynamicResource PrimaryButton}" Command="{Binding SearchCommand}" Margin="12,0,0,0" Padding="20,0"/>
                
                <Grid Grid.Column="3" Margin="15,0,0,0">
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" 
                               Foreground="{Binding StatusMessage, Converter={StaticResource StatusColorConverter}}" 
                               FontWeight="Medium" TextWrapping="Wrap"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Items Grid (Row 2) -->
        <GroupBox Grid.Row="2" Header="Items available for return" Foreground="{DynamicResource SubTextBrush}" FontWeight="SemiBold" Margin="0,0,0,10" VerticalAlignment="Stretch">
            <Border Style="{DynamicResource CardBorder}" Padding="0">
                <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" CanUserAddRows="False" Style="{DynamicResource ModernDataGrid}"
                          ColumnHeaderStyle="{DynamicResource ModernDataGridColumnHeader}" CellStyle="{DynamicResource ModernDataGridCell}"
                          VerticalAlignment="Top" MaxHeight="350" RowHeight="38">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource ModernDataGridRow}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RemainingQuantity}" Value="0">
                                    <Setter Property="Background" Value="#1AEE4444"/> <!-- Very subtle red tint -->
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Product Description" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Padding="4,2" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Barcode" Binding="{Binding ItemId}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Sold" Binding="{Binding OriginalQuantity}" Width="65" IsReadOnly="True">
                             <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Ret" Binding="{Binding AlreadyReturned}" Width="60" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Rem" Binding="{Binding RemainingQuantity}" Width="60" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RemainingQuantity}" Value="0">
                                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="Return Qty" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding ReturnQuantity, UpdateSourceTrigger=PropertyChanged}" 
                                             helpers:FocusHelper.SelectAllOnFocus="True"
                                             helpers:FocusHelper.DecimalOnly="True"
                                             HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                             FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"
                                             Background="Transparent" BorderThickness="1" 
                                             BorderBrush="{DynamicResource PrimaryBrush}"
                                             Padding="4,2" Margin="4,2"
                                             VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </GroupBox>

        <!-- History Title (Row 3) -->
        <TextBlock Grid.Row="3" Text="📜 Previous Returns for this Bill" FontSize="16" FontWeight="Bold" Margin="0,15,0,8"
                   Visibility="{Binding ReturnHistory.Count, Converter={StaticResource CountToVisibilityConverter}}"
                   xmlns:conv="clr-namespace:GroceryPOS.Converters"/>

        <!-- Return History (Row 4) -->
        <Border Grid.Row="4" Style="{DynamicResource CardBorder}" Padding="0" Margin="0,0,0,10"
                Visibility="{Binding ReturnHistory.Count, Converter={StaticResource CountToVisibilityConverter}}">
            <DataGrid ItemsSource="{Binding ReturnHistory}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                      Style="{DynamicResource ModernDataGrid}" MaxHeight="150"
                      ColumnHeaderStyle="{DynamicResource ModernDataGridColumnHeader}" RowStyle="{DynamicResource ModernDataGridRow}" CellStyle="{DynamicResource ModernDataGridCell}">
                 <DataGrid.Columns>
                    <DataGridTextColumn Header="Return ID" Binding="{Binding ReturnBillId}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Date/Time" Binding="{Binding ReturnDate}" Width="150"/>
                    <DataGridTextColumn Header="Barcode" Binding="{Binding ProductId}" Width="120"/>
                    <DataGridTextColumn Header="Qty" Binding="{Binding ReturnQuantity}" Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Product Description" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ProductDescription}" TextWrapping="Wrap" Padding="4,2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer Actions (Row 5) -->
        <Border Grid.Row="5" Margin="0,20,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="✖ Clear" Style="{DynamicResource SecondaryButton}" Width="110" Margin="0,0,15,0" Command="{Binding ClearFormCommand}"/>
                <Button Content="View Preview" Style="{DynamicResource AccentButton}" Width="150" Margin="0,0,15,0" 
                        Command="{Binding TogglePreviewCommand}"
                        Visibility="{Binding OriginalBill, Converter={StaticResource NullToVisibilityConverter}}"/>
                <Button Content="🔄 Process Return" Style="{DynamicResource PrimaryButton}" Width="190" Height="48" Command="{Binding ProcessReturnCommand}" FontSize="15" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>

    <!-- Right Column: Receipt Preview (Professional Drawer Look) -->
    <Border Grid.Column="1" Width="300" Margin="20,0,0,0" 
            Visibility="{Binding IsPreviewVisible, Converter={StaticResource BoolToVis}}"
            Background="White" CornerRadius="16" UseLayoutRounding="True" SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.12" Color="#000000"/>
        </Border.Effect>
        
        <DockPanel>
            <!-- Preview Header -->
            <Grid DockPanel.Dock="Top" Margin="20,16">
                <TextBlock Text="Receipt Preview" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}"/>
                <Button Content="X" HorizontalAlignment="Right" VerticalAlignment="Center" 
                        Background="Transparent" BorderThickness="0" Foreground="{DynamicResource SubTextBrush}"
                        Command="{Binding TogglePreviewCommand}" Cursor="Hand" FontSize="14">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <Separator DockPanel.Dock="Top" Background="#F1F5F9" Margin="0" Height="1"/>

            <!-- The "Paper" Receipt -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                <StackPanel Background="White">
                    <!-- Store Header -->
                    <TextBlock Text="{Binding StoreName}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#1E293B"/>
                    <TextBlock Text="{Binding StoreAddress}" FontSize="10" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Foreground="#64748B" Margin="0,4"/>
                    <TextBlock Text="{Binding StorePhone, StringFormat='Ph: {0}'}" FontSize="11" HorizontalAlignment="Center" Foreground="#64748B"/>
                    
                    <Border BorderThickness="0,0,0,1" BorderBrush="#E2E8F0" Margin="0,12" SnapsToDevicePixels="True"/>
                    
                    <!-- Invoice Info -->
                    <Grid>
                        <TextBlock Text="{Binding OriginalBill.InvoiceNumber, StringFormat='No: {0}'}" FontSize="11" Foreground="#475569" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding OriginalBill.BillDateTime, StringFormat='{}{0:HH:mm}'}" FontSize="11" HorizontalAlignment="Right" Foreground="#64748B"/>
                    </Grid>
                    <TextBlock Text="{Binding OriginalBill.BillDateTime, StringFormat='{}{0:dd MMM yyyy}'}" FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>

                    <Border BorderThickness="0,0,0,1" BorderBrush="#E2E8F0" Margin="0,12" SnapsToDevicePixels="True"/>
                    
                    <!-- Items Header -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Product Details" FontSize="11" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Grid.Column="1" Text="Total (Rs)" FontSize="11" FontWeight="Bold" Foreground="#1E293B"/>
                    </Grid>
                    
                    <!-- Items List -->
                    <ItemsControl ItemsSource="{Binding OriginalBill.Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Text="{Binding ItemDescription}" FontSize="12" Foreground="#334155" FontWeight="Normal" TextWrapping="Wrap"/>
                                        <TextBlock FontSize="10" Foreground="#94A3B8" Margin="0,2,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Quantity}" Value="1">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0:N0} x {1}">
                                                    <Binding Path="UnitPrice"/>
                                                    <Binding Path="Quantity"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Text="{Binding TotalPrice, StringFormat='{}{0:N2}'}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="#1E293B"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <Rectangle Stroke="#E2E8F0" StrokeDashArray="4 2" StrokeThickness="1" Height="1" Margin="0,15" SnapsToDevicePixels="True"/>
                    
                    <!-- Totals Area -->
                    <Grid Margin="0,4">
                        <TextBlock Text="Sub Total" FontSize="12" Foreground="#64748B"/>
                        <TextBlock Text="{Binding OriginalBill.SubTotal, StringFormat='Rs.{0:N2}'}" FontSize="12" HorizontalAlignment="Right" Foreground="#1E293B" FontWeight="Bold"/>
                    </Grid>
                    <Grid Margin="0,4">
                        <TextBlock Text="Discount" FontSize="12" Foreground="#64748B"/>
                        <TextBlock Text="{Binding OriginalBill.DiscountAmount, StringFormat='-Rs.{0:N2}'}" FontSize="12" HorizontalAlignment="Right" Foreground="#EF4444" FontWeight="Bold"/>
                    </Grid>
                    <Grid Margin="0,4">
                        <TextBlock Text="Tax" FontSize="12" Foreground="#64748B"/>
                        <TextBlock Text="{Binding OriginalBill.TaxAmount, StringFormat='Rs.{0:N2}'}" FontSize="12" HorizontalAlignment="Right" Foreground="#1E293B" FontWeight="Bold"/>
                    </Grid>

                    <Border Background="#F8FAFC" CornerRadius="8" Padding="12,10" Margin="0,10">
                        <Grid>
                            <TextBlock Text="NET TOTAL" FontSize="14" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding OriginalBill.GrandTotal, StringFormat='Rs.{0:N0}'}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right" Foreground="{DynamicResource PrimaryBrush}"/>
                        </Grid>
                    </Border>

                    <Grid Margin="0,2">
                        <TextBlock Text="Cash Paid" FontSize="11" Foreground="#64748B"/>
                        <TextBlock Text="{Binding OriginalBill.CashReceived, StringFormat='Rs.{0}'}" FontSize="11" HorizontalAlignment="Right" Foreground="#1E293B"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <TextBlock Text="Change Due" FontSize="11" Foreground="#64748B"/>
                        <TextBlock Text="{Binding OriginalBill.ChangeAmount, StringFormat='Rs.{0:N2}'}" FontSize="11" HorizontalAlignment="Right" Foreground="#1E293B" FontWeight="Bold"/>
                    </Grid>

                    <!-- Footer -->
                    <StackPanel Margin="0,30,0,10">
                        <TextBlock Text="Thank you for your business!" FontSize="11" HorizontalAlignment="Center" Foreground="#94A3B8"/>
                        <TextBlock Text="Visit us again soon" FontSize="10" HorizontalAlignment="Center" Foreground="#CBD5E1" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Grid>
</UserControl>
