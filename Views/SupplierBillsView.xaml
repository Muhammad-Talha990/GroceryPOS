<UserControl x:Class="GroceryPOS.Views.SupplierBillsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GroceryPOS.Views"
             xmlns:conv="clr-namespace:GroceryPOS.Converters"
             xmlns:helpers="clr-namespace:GroceryPOS.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="{DynamicResource BgBrush}" FontFamily="{DynamicResource AppFont}">
    
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <conv:CountToVisibilityConverter x:Key="CountToVis" />
        <conv:CountToVisibilityConverter x:Key="EmptyToVis" Inverse="True" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:InverseNullToVisibilityConverter x:Key="InverseNullToVis" />
    </UserControl.Resources>

    <Grid Margin="30,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="380" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header Area -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🚛 Stock History" FontSize="26" FontWeight="Bold" 
                           Foreground="{DynamicResource TextBrush}" Margin="0,0,30,0"/>

                <Border Style="{DynamicResource CardBorder}" Padding="12,2" Width="400" Background="White" Height="42" x:Name="MainSearchBorder">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center" Margin="8,0,10,0" Opacity="0.5"/>
                        <TextBox Grid.Column="1" Text="{Binding SearchBarcode, UpdateSourceTrigger=PropertyChanged}" 
                                 Tag="Search by barcode or product name..." BorderThickness="0" Background="Transparent" 
                                 VerticalAlignment="Center" FontSize="14" VerticalContentAlignment="Center" x:Name="MainSearchBox"
                                 GotFocus="SearchBox_GotFocus">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SearchItemCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="2" Content="Clear" Command="{Binding RefreshCommand}" 
                                Background="Transparent" BorderThickness="0" Foreground="{DynamicResource PrimaryBrush}" 
                                FontWeight="SemiBold" Cursor="Hand" Margin="0,0,8,0" FontSize="12"
                                Visibility="{Binding SearchBarcode.Length, Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                </Border>

                <!-- Live Search Results Popup (Main Bar) -->
                <Popup IsOpen="{Binding IsMainResultsOpen}" PlacementTarget="{Binding ElementName=MainSearchBorder}" 
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="2">
                    <Border Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                            CornerRadius="12" Width="400" MaxHeight="300">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.15" Color="#64748B"/>
                        </Border.Effect>
                        <ListBox ItemsSource="{Binding MainProductSearchResults}" 
                                 SelectedItem="{Binding SelectedMainProductResult}"
                                 BorderThickness="0" Background="Transparent" Padding="6">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,6" CornerRadius="6" x:Name="MainItemBorder" Margin="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Description}" FontWeight="Bold" FontSize="13" Foreground="#1E293B"/>
                                                <TextBlock Text="{Binding Barcode, StringFormat='Barcode: {0}'}" FontSize="11" Foreground="#64748B"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" Background="#F1F5F9" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StockQuantity, StringFormat='Stock: {0}'}"
                                                           FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                            <Setter TargetName="MainItemBorder" Property="Background" Value="#F1F5F9"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Popup>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="🔄  Refresh" Command="{Binding RefreshCommand}" 
                        Style="{DynamicResource PrimaryButton}" Padding="18,10" FontSize="13" Margin="0,0,12,0" Background="#64748B"
                        Visibility="{Binding IsAddingNew, Converter={StaticResource InverseBoolToVis}}"/>
                <Button Content="➕  Add New Stock" Command="{Binding ShowAddFormCommand}" 
                        Style="{DynamicResource PrimaryButton}" Background="{DynamicResource SuccessBrush}" 
                        Padding="22,10" FontSize="13" FontWeight="SemiBold"
                        Visibility="{Binding IsAddingNew, Converter={StaticResource InverseBoolToVis}}"
                        ToolTip="Register a new stock entry." Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Item Details Card (Context) -->
            <Border Grid.Row="0" Style="{DynamicResource CardBorder}" Background="{DynamicResource PrimaryBrush}" 
                    Padding="24,18" Margin="0,0,0,20" Visibility="{Binding FoundItem, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel>
                        <TextBlock Text="Selected Product" FontSize="12" Foreground="White" Opacity="0.7" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding FoundItem.Description}" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Barcode: " Foreground="White" Opacity="0.7"/>
                            <TextBlock Text="{Binding FoundItem.Barcode}" Foreground="White" FontWeight="SemiBold" Margin="0,0,24,0"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <Border Grid.Column="1" Background="#26FFFFFF" CornerRadius="12" Padding="20,10" VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Current Stock" FontSize="11" Foreground="White" Opacity="0.9" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding FoundItem.StockQuantity}" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Data Table Section -->
            <Border Grid.Row="1" Style="{DynamicResource CardBorder}" Padding="0">
                <Grid>
                    <DataGrid ItemsSource="{Binding SupplyHistory}" SelectedItem="{Binding SelectedEntry}" 
                              Style="{DynamicResource ModernDataGrid}"
                              ColumnHeaderStyle="{DynamicResource ModernDataGridColumnHeader}"
                              CellStyle="{DynamicResource ModernDataGridCell}"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="2*" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Date &amp; Time" Binding="{Binding SystemDate, StringFormat='dd MMM yyyy, HH:mm'}" Width="160">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="Action" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✏️ Update" Command="{Binding DataContext.UpdateSupplyCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                CommandParameter="{Binding}"
                                                Background="Transparent" Foreground="{DynamicResource AccentBrush}" BorderThickness="0" 
                                                FontWeight="SemiBold" Cursor="Hand" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty State Placeholder -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding SupplyHistory.Count, Converter={StaticResource EmptyToVis}}"
                                Panel.ZIndex="10" IsHitTestVisible="False">
                        <TextBlock Text="📂" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10" Opacity="0.3"/>
                        <TextBlock Text="No stock records found" Foreground="{DynamicResource SubTextBrush}" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="Try searching for a barcode or product name" Foreground="{DynamicResource SubTextBrush}" 
                                   FontSize="13" Margin="0,4,0,0" Opacity="0.6"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Right Side: Bill Preview Panel -->
        <Border Grid.Row="1" Grid.Column="1" Style="{DynamicResource CardBorder}" Padding="20" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="🧾 Stock Bill Preview" FontSize="16" FontWeight="Bold" 
                           Foreground="{DynamicResource TextBrush}" Margin="0,0,0,16"/>

                <Grid Grid.Row="1">
                    <!-- Placeholder when no image -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" 
                                Visibility="{Binding IsImageAvailable, Converter={StaticResource InverseBoolToVis}}">
                        <Border Width="80" Height="80" CornerRadius="40" Background="#F1F5F9" Margin="0,0,0,16">
                            <TextBlock Text="🖼️" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
                        </Border>
                        <TextBlock Text="No Bill Image" Foreground="{DynamicResource TextBrush}" FontSize="15" 
                                   FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Select a record from the list to view its bill" Foreground="{DynamicResource SubTextBrush}" 
                                   FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" TextAlignment="Center" Opacity="0.7"/>
                    </StackPanel>

                    <!-- Image Preview -->
                    <DockPanel LastChildFill="True" Visibility="{Binding IsImageAvailable, Converter={StaticResource BoolToVis}}">
                        <Border DockPanel.Dock="Top" Background="#F8FAFC" BorderBrush="{DynamicResource BorderBrush}" 
                                BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="STOCK DATE" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding SelectedEntry.SystemDate, StringFormat='dd MMMM yyyy, hh:mm tt'}" 
                                               FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" VerticalAlignment="Center" 
                                        Command="{Binding ViewFullBillCommand}"
                                        Style="{StaticResource PrimaryButton}" Padding="12,6" FontSize="11" Background="{DynamicResource AccentBrush}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📂 View Full / PDF" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                        
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Background="#F1F5F9" ClipToBounds="True">
                           <Image Source="{Binding BillImagePreview}" Stretch="Uniform" 
                                  VerticalAlignment="Top" HorizontalAlignment="Center"
                                  RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                    </DockPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- New Supply Modal Overlay (STOCK CART) -->
        <Grid Grid.Row="0" Grid.RowSpan="2" Grid.ColumnSpan="2" Background="#77000000" 
              Visibility="{Binding IsAddingNew, Converter={StaticResource BoolToVis}}" Panel.ZIndex="1000">
            <Border Width="950" MaxHeight="850" VerticalAlignment="Center" HorizontalAlignment="Center" 
                    Background="White" CornerRadius="16" Padding="28">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.3"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="Auto"/> <!-- Separator 1 -->
                        <RowDefinition Height="*"/>    <!-- Scrollable Content -->
                        <RowDefinition Height="Auto"/> <!-- Separator 2 -->
                        <RowDefinition Height="Auto"/> <!-- Footer -->
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Text="🛒 Stock Purchase Cart"/>
                            <TextBlock Text="Add multiple products to restock them in a single transaction" FontSize="13" Foreground="{DynamicResource SubTextBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" VerticalAlignment="Top" Style="{StaticResource PrimaryButton}" 
                                Background="Transparent" Width="32" Height="32" Padding="0"
                                Command="{Binding CancelAddCommand}" Cursor="Hand">
                            <TextBlock Text="✕" FontSize="18" Foreground="{StaticResource SubTextBrush}"/>
                        </Button>
                    </Grid>

                    <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,16"/>

                    <Grid Grid.Row="2" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="320"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Cart Items -->
                        <Grid Grid.Column="0" Margin="0,0,24,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Dropdown Product Selection -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                <TextBlock Text="SELECT PRODUCT FROM LIST" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" ItemsSource="{Binding AllProducts}" 
                                              SelectedItem="{Binding SelectedProductFromList}"
                                              IsEditable="True"
                                              TextSearch.TextPath="Description"
                                              FontSize="14"
                                              Padding="10,8">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Width="Auto">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Description}" FontWeight="Medium"/>
                                                    <Border Grid.Column="1" Background="#F1F5F9" CornerRadius="4" Padding="6,2" Margin="10,0,0,0">
                                                        <TextBlock Text="{Binding StockQuantity, StringFormat='Qty: {0}'}" 
                                                                   FontSize="10" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold"/>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                        <ComboBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding AddSelectedFromListToCartCommand}"/>
                                        </ComboBox.InputBindings>
                                        <ComboBox.Resources>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Tag" Value="Type to filter or select..."/>
                                            </Style>
                                        </ComboBox.Resources>
                                    </ComboBox>
                                    <Button Grid.Column="1" 
                                            Command="{Binding AddSelectedFromListToCartCommand}"
                                            Content="Add to Cart"
                                            Style="{StaticResource PrimaryButton}"
                                            Padding="15,0"
                                            Margin="8,0,0,0"
                                            FontSize="12"
                                            Height="40"/>
                                </Grid>
                            </StackPanel>

                            <!-- Product Search for Cart -->
                            <Border Grid.Row="1" Style="{DynamicResource CardBorder}" Padding="12,2" Background="#F8FAFC" Margin="0,0,0,16" x:Name="CartSearchBorder">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center" Margin="8,0,10,0" Opacity="0.5"/>
                                    <TextBox Grid.Column="1" Text="{Binding CartSearchText, UpdateSourceTrigger=PropertyChanged}" 
                                             Tag="Search products to add to cart..." BorderThickness="0" Background="Transparent" 
                                             VerticalAlignment="Center" FontSize="15" VerticalContentAlignment="Center" Height="40"
                                             GotFocus="SearchBox_GotFocus"/>
                                </Grid>
                            </Border>

                            <!-- Cart Search Popup -->
                            <Popup IsOpen="{Binding IsCartSearchOpen}" PlacementTarget="{Binding ElementName=CartSearchBorder}" 
                                   Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="2">
                                <Border Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                                        CornerRadius="12" Width="500" MaxHeight="300">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.15" Color="#64748B"/>
                                    </Border.Effect>
                                    <ListBox ItemsSource="{Binding CartSearchResults}" 
                                             SelectedItem="{Binding CartSelectedResult}"
                                             BorderThickness="0" Background="Transparent" Padding="6">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Padding" Value="0"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="12,8" CornerRadius="6" x:Name="CartResultBorder" Margin="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Description}" FontWeight="Bold" FontSize="14" Foreground="#1E293B"/>
                                                            <TextBlock Text="{Binding Barcode, StringFormat='Barcode: {0}'}" FontSize="12" Foreground="#64748B"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="1" Background="#F1F5F9" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding StockQuantity, StringFormat='Stock: {0}'}"
                                                                       FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter TargetName="CartResultBorder" Property="Background" Value="#F1F5F9"/>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Popup>

                            <!-- Cart Grid -->
                            <DataGrid Grid.Row="2" ItemsSource="{Binding CartItems}" 
                                      Style="{DynamicResource ModernDataGrid}"
                                      IsReadOnly="False"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Product" Binding="{Binding ItemDescription}" Width="*" IsReadOnly="True"/>
                                    <DataGridTemplateColumn Header="Qty" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" 
                                                         TextAlignment="Center" FontWeight="Bold" BorderThickness="0" Background="Transparent"
                                                         PreviewTextInput="Quantity_PreviewTextInput"
                                                         GotFocus="SearchBox_GotFocus"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Cost Price" Width="110">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding CostPrice, UpdateSourceTrigger=PropertyChanged, StringFormat='N2'}" 
                                                         TextAlignment="Right" BorderThickness="0" Background="Transparent"
                                                         PreviewTextInput="Quantity_PreviewTextInput"
                                                         GotFocus="SearchBox_GotFocus"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Total" Binding="{Binding LineTotal, StringFormat='N2'}" Width="100" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Right"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Margin" Value="0,0,10,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Width="50">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="✕" Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent" Foreground="#EF4444" BorderThickness="0" Cursor="Hand"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>

                        <!-- Right: Summary & Checkout -->
                        <Border Grid.Column="1" Background="#F8FAFC" CornerRadius="12" Padding="0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <Border Padding="20">
                                    <StackPanel>
                                    <TextBlock Text="PURCHASE SUMMARY" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,20"/>
                                    
                                    <Grid Margin="0,0,0,12">
                                        <TextBlock Text="Total Items" Foreground="{DynamicResource SubTextBrush}"/>
                                        <TextBlock Text="{Binding CartItems.Count}" HorizontalAlignment="Right" FontWeight="Bold"/>
                                    </Grid>
                                    
                                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,8,0,12"/>
                                    
                                    <StackPanel Margin="0,0,0,24">
                                        <TextBlock Text="GRAND TOTAL" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,8"/>
                                        <Border Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12,8">
                                            <Grid>
                                                <TextBlock Text="Rs. " VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" FontSize="18"/>
                                                <TextBox Text="{Binding CartTotalText, UpdateSourceTrigger=PropertyChanged}" 
                                                         BorderThickness="0" Background="Transparent" Margin="30,0,0,0"
                                                         FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"
                                                         PreviewTextInput="Quantity_PreviewTextInput"
                                                         DataObject.Pasting="Quantity_Pasting"
                                                         GotFocus="SearchBox_GotFocus"/>
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <TextBlock Text="Note: This amount will be deducted from Today's Cash in Drawer." 
                                               TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,24" Opacity="0.8"/>

                                    <TextBlock Text="{Binding CartStatus}" Foreground="#EF4444" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12" 
                                               Visibility="{Binding CartStatus.Length, Converter={StaticResource BoolToVis}}"/>

                                    <!-- Bill Image Upload Section (MANDATORY) -->
                                    <TextBlock Text="BILL IMAGE (MANDATORY)*" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,10"/>
                                    <Border Background="White" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10">
                                        <Grid>
                                            <!-- Image Preview -->
                                            <Image Source="{Binding CartImagePreview}" Height="120" Stretch="Uniform" Margin="5"
                                                   Visibility="{Binding CartImagePreview, Converter={StaticResource NullToVis}}"/>
                                            
                                            <!-- Placeholder when no image -->
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                        Visibility="{Binding CartImagePreview, Converter={StaticResource InverseNullToVis}}">
                                                <TextBlock Text="📷" FontSize="28" HorizontalAlignment="Center" Opacity="0.4" Margin="10,10,10,0"/>
                                                <TextBlock Text="No image selected" FontSize="10" Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center" Margin="0,4,0,10"/>
                                            </StackPanel>

                                            <!-- Hover selection overlay -->
                                            <Button Command="{Binding SelectCartImageCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" Opacity="0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </Border>
                                    <Button Command="{Binding SelectCartImageCommand}" Content="Choose Bill Image..." 
                                            Style="{StaticResource SecondaryButton}" Padding="0,6" Margin="0,0,0,20" Background="White" FontSize="12"/>

                                    <Button Command="{Binding CheckoutCartCommand}" 
                                            Style="{StaticResource PrimaryButton}" 
                                            Background="{DynamicResource SuccessBrush}" 
                                            Padding="0,15" FontSize="16">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="✅  Complete Purchase"/>
                                        </StackPanel>
                                    </Button>
                                    
                                    <Button Command="{Binding ClearCartCommand}" 
                                            Content="Clear Cart"
                                            Style="{StaticResource SecondaryButton}" 
                                            Margin="0,12,0,0" Padding="0,10" Background="Transparent"/>
                                </StackPanel>
                            </Border>
                        </ScrollViewer>
                    </Border>
                    </Grid>
                    <Border Grid.Row="3" Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,16"/>

                    <!-- Modal Footer Removed as buttons moved to Summary Sidebar -->
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Grid.ColumnSpan="2" Background="Transparent" Margin="0,15,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource SubTextBrush}" FontSize="12" Opacity="0.7"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ═══ POPUP SUCCESS OVERLAY ═══ -->
        <Border Grid.RowSpan="3" Grid.ColumnSpan="2" Panel.ZIndex="3000" IsHitTestVisible="False"
                VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,40,0,0"
                Visibility="{Binding PopupSuccessVisible, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
            <Border Background="White" CornerRadius="8" Padding="20,12"
                    BorderBrush="#22C55E" BorderThickness="2">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.15" Color="Black"/>
                </Border.Effect>
                <TextBlock Text="{Binding PopupSuccessMessage}" 
                           Foreground="#22C55E" FontSize="20" FontWeight="Bold" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
        </Border>

        <!-- ═══ POPUP ERROR OVERLAY ═══ -->
        <Border Grid.RowSpan="3" Grid.ColumnSpan="2" Panel.ZIndex="3000" IsHitTestVisible="False"
                VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,40,0,0"
                Visibility="{Binding PopupErrorVisible, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
            <Border Background="White" CornerRadius="8" Padding="20,12"
                    BorderBrush="#EF4444" BorderThickness="2">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.15" Color="Black"/>
                </Border.Effect>
                <TextBlock Text="{Binding PopupErrorMessage}" 
                           Foreground="#EF4444" FontSize="20" FontWeight="Bold" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
        </Border>
    </Grid>
</UserControl>
