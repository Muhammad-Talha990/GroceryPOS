<UserControl x:Class="GroceryPOS.Views.SupplierBillsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GroceryPOS.Views"
             xmlns:conv="clr-namespace:GroceryPOS.Converters"
             xmlns:helpers="clr-namespace:GroceryPOS.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="{DynamicResource BgBrush}" FontFamily="{DynamicResource AppFont}">
    
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <conv:CountToVisibilityConverter x:Key="CountToVis" />
        <conv:CountToVisibilityConverter x:Key="EmptyToVis" Inverse="True" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:InverseNullToVisibilityConverter x:Key="InverseNullToVis" />
    </UserControl.Resources>

    <Grid Margin="30,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="380" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header Area -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🚛 Stock History" FontSize="26" FontWeight="Bold" 
                           Foreground="{DynamicResource TextBrush}" Margin="0,0,30,0"/>

                <Border Style="{DynamicResource CardBorder}" Padding="12,2" Width="400" Background="White" Height="42" x:Name="MainSearchBorder">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center" Margin="8,0,10,0" Opacity="0.5"/>
                        <TextBox Grid.Column="1" Text="{Binding SearchBarcode, UpdateSourceTrigger=PropertyChanged}" 
                                 Tag="Search by barcode or product name..." BorderThickness="0" Background="Transparent" 
                                 VerticalAlignment="Center" FontSize="14" VerticalContentAlignment="Center" x:Name="MainSearchBox"
                                 GotFocus="SearchBox_GotFocus">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SearchItemCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="2" Content="Clear" Command="{Binding RefreshCommand}" 
                                Background="Transparent" BorderThickness="0" Foreground="{DynamicResource PrimaryBrush}" 
                                FontWeight="SemiBold" Cursor="Hand" Margin="0,0,8,0" FontSize="12"
                                Visibility="{Binding SearchBarcode.Length, Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                </Border>

                <!-- Live Search Results Popup (Main Bar) -->
                <Popup IsOpen="{Binding IsMainResultsOpen}" PlacementTarget="{Binding ElementName=MainSearchBorder}" 
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="2">
                    <Border Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                            CornerRadius="12" Width="400" MaxHeight="300">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.15" Color="#64748B"/>
                        </Border.Effect>
                        <ListBox ItemsSource="{Binding MainProductSearchResults}" 
                                 SelectedItem="{Binding SelectedMainProductResult}"
                                 BorderThickness="0" Background="Transparent" Padding="6">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,6" CornerRadius="6" x:Name="MainItemBorder" Margin="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Description}" FontWeight="Bold" FontSize="13" Foreground="#1E293B"/>
                                                <TextBlock Text="{Binding Barcode, StringFormat='Barcode: {0}'}" FontSize="11" Foreground="#64748B"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" Background="#F1F5F9" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StockQuantity, StringFormat='Stock: {0}'}"
                                                           FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                            <Setter TargetName="MainItemBorder" Property="Background" Value="#F1F5F9"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Popup>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="🔄  Refresh" Command="{Binding RefreshCommand}" 
                        Style="{DynamicResource PrimaryButton}" Padding="18,10" FontSize="13" Margin="0,0,12,0" Background="#64748B"
                        Visibility="{Binding IsAddingNew, Converter={StaticResource InverseBoolToVis}}"/>
                <Button Content="➕  Add New Stock" Command="{Binding ShowAddFormCommand}" 
                        Style="{DynamicResource PrimaryButton}" Background="{DynamicResource SuccessBrush}" 
                        Padding="22,10" FontSize="13" FontWeight="SemiBold"
                        Visibility="{Binding IsAddingNew, Converter={StaticResource InverseBoolToVis}}"
                        ToolTip="Register a new stock entry." Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Item Details Card (Context) -->
            <Border Grid.Row="0" Style="{DynamicResource CardBorder}" Background="{DynamicResource PrimaryBrush}" 
                    Padding="24,18" Margin="0,0,0,20" Visibility="{Binding FoundItem, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel>
                        <TextBlock Text="Selected Product" FontSize="12" Foreground="White" Opacity="0.7" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding FoundItem.Description}" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Barcode: " Foreground="White" Opacity="0.7"/>
                            <TextBlock Text="{Binding FoundItem.Barcode}" Foreground="White" FontWeight="SemiBold" Margin="0,0,24,0"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <Border Grid.Column="1" Background="#26FFFFFF" CornerRadius="12" Padding="20,10" VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Current Stock" FontSize="11" Foreground="White" Opacity="0.9" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding FoundItem.StockQuantity}" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Data Table Section -->
            <Border Grid.Row="1" Style="{DynamicResource CardBorder}" Padding="0">
                <Grid>
                    <DataGrid ItemsSource="{Binding SupplyHistory}" SelectedItem="{Binding SelectedEntry}" 
                              Style="{DynamicResource ModernDataGrid}"
                              ColumnHeaderStyle="{DynamicResource ModernDataGridColumnHeader}"
                              CellStyle="{DynamicResource ModernDataGridCell}"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="2*" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Date &amp; Time" Binding="{Binding SystemDate, StringFormat='dd MMM yyyy, HH:mm'}" Width="160">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="Action" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✏️ Update" Command="{Binding DataContext.UpdateSupplyCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                CommandParameter="{Binding}"
                                                Background="Transparent" Foreground="{DynamicResource AccentBrush}" BorderThickness="0" 
                                                FontWeight="SemiBold" Cursor="Hand" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty State Placeholder -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding SupplyHistory.Count, Converter={StaticResource EmptyToVis}}"
                                Panel.ZIndex="10" IsHitTestVisible="False">
                        <TextBlock Text="📂" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10" Opacity="0.3"/>
                        <TextBlock Text="No stock records found" Foreground="{DynamicResource SubTextBrush}" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="Try searching for a barcode or product name" Foreground="{DynamicResource SubTextBrush}" 
                                   FontSize="13" Margin="0,4,0,0" Opacity="0.6"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Right Side: Bill Preview Panel -->
        <Border Grid.Row="1" Grid.Column="1" Style="{DynamicResource CardBorder}" Padding="20" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="🧾 Stock Bill Preview" FontSize="16" FontWeight="Bold" 
                           Foreground="{DynamicResource TextBrush}" Margin="0,0,0,16"/>

                <Grid Grid.Row="1">
                    <!-- Placeholder when no image -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" 
                                Visibility="{Binding IsImageAvailable, Converter={StaticResource InverseBoolToVis}}">
                        <Border Width="80" Height="80" CornerRadius="40" Background="#F1F5F9" Margin="0,0,0,16">
                            <TextBlock Text="🖼️" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
                        </Border>
                        <TextBlock Text="No Bill Image" Foreground="{DynamicResource TextBrush}" FontSize="15" 
                                   FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Select a record from the list to view its bill" Foreground="{DynamicResource SubTextBrush}" 
                                   FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" TextAlignment="Center" Opacity="0.7"/>
                    </StackPanel>

                    <!-- Image Preview -->
                    <DockPanel LastChildFill="True" Visibility="{Binding IsImageAvailable, Converter={StaticResource BoolToVis}}">
                        <Border DockPanel.Dock="Top" Background="#F8FAFC" BorderBrush="{DynamicResource BorderBrush}" 
                                BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="STOCK DATE" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding SelectedEntry.SystemDate, StringFormat='dd MMMM yyyy, hh:mm tt'}" 
                                               FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" VerticalAlignment="Center" 
                                        Command="{Binding ViewFullBillCommand}"
                                        Style="{StaticResource PrimaryButton}" Padding="12,6" FontSize="11" Background="{DynamicResource AccentBrush}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📂 View Full / PDF" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                        
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Background="#F1F5F9" ClipToBounds="True">
                           <Image Source="{Binding BillImagePreview}" Stretch="Uniform" 
                                  VerticalAlignment="Top" HorizontalAlignment="Center"
                                  RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                    </DockPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- New Supply Modal Overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="2" Grid.ColumnSpan="2" Background="#77000000" 
              Visibility="{Binding IsAddingNew, Converter={StaticResource BoolToVis}}" Panel.ZIndex="1000">
            <Border Width="550" MaxHeight="750" VerticalAlignment="Center" HorizontalAlignment="Center" 
                    Background="White" CornerRadius="16" Padding="24">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.3"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="Auto"/> <!-- Separator 1 -->
                        <RowDefinition Height="*"/>    <!-- Scrollable Content -->
                        <RowDefinition Height="Auto"/> <!-- Separator 2 -->
                        <RowDefinition Height="Auto"/> <!-- Footer -->
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="🚀 Register Stock"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter Property="Text" Value="✏️ Update Stock"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="Enter the details of the incoming stock" FontSize="13" Foreground="{DynamicResource SubTextBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" VerticalAlignment="Top" Style="{StaticResource PrimaryButton}" 
                                Background="Transparent" Width="32" Height="32" Padding="0"
                                Command="{Binding CancelAddCommand}" Cursor="Hand">
                            <TextBlock Text="✕" FontSize="18" Foreground="{StaticResource SubTextBrush}"/>
                        </Button>
                    </Grid>

                    <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,16"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                        <StackPanel>
                            <!-- Product Lookup -->
                            <TextBlock Text="PRODUCT IDENTIFIER" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <TextBox x:Name="ProductSearchBox" Style="{DynamicResource ModernTextBox}" 
                                             Tag="Scan barcode or type name..."
                                             Text="{Binding ManualSearchBarcode, UpdateSourceTrigger=PropertyChanged}" 
                                             FontSize="14" Padding="12,8,40,8" GotFocus="SearchBox_GotFocus">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding FindManualItemCommand}"/>
                                        </TextBox.InputBindings>
                                    </TextBox>
                                    <Button Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" 
                                            VerticalAlignment="Center" Width="30" Height="30" Margin="0,0,8,0"
                                            Command="{Binding ToggleSearchResultsCommand}" Cursor="Hand"
                                            ToolTip="Show search results"
                                            Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}">
                                        <TextBlock Text="▾" FontSize="20" Foreground="{DynamicResource SubTextBrush}" 
                                                   VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-4,0,0"/>
                                    </Button>
                                </Grid>

                                <!-- Live Search Results Popup (Modal) -->
                                <Popup IsOpen="{Binding IsSearchResultsOpen}" PlacementTarget="{Binding ElementName=ProductSearchBox}" 
                                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="4">
                                    <Border Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                                            CornerRadius="10" Width="400" MaxHeight="220">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.15" Color="#64748B"/>
                                        </Border.Effect>
                                        <ListBox ItemsSource="{Binding ProductSearchResults}" 
                                                 SelectedItem="{Binding SelectedProductResult}"
                                                 BorderThickness="0" Background="Transparent" Padding="6">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Setter Property="Padding" Value="0"/>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                            <Border Padding="10,6" CornerRadius="6" x:Name="ItemBorder" Margin="0,0,0,1">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Description}" FontWeight="Bold" FontSize="13" Foreground="#1E293B"/>
                                                                <TextBlock Text="{Binding Barcode, StringFormat='Barcode: {0}'}" FontSize="11" Foreground="#64748B"/>
                                                            </StackPanel>
                                                            <Border Grid.Column="1" Background="#F1F5F9" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding StockQuantity, StringFormat='Qty: {0}'}"
                                                                           FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="#F1F5F9"/>
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>
                                </Popup>

                                <Button Grid.Column="1" Content="Check" Command="{Binding FindManualItemCommand}" 
                                        Style="{DynamicResource PrimaryButton}" Margin="8,0,0,0" Padding="20,0" FontSize="13"/>
                            </Grid>

                            <!-- Product Confirmation (Professional Alert Box) -->
                            <Border Background="#F0FDF4" BorderBrush="#22C55E" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,24"
                                    Visibility="{Binding FoundItem, Converter={StaticResource BoolToVis}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="40" Height="40" Background="#DCFCE7" CornerRadius="20" Margin="0,0,16,0">
                                        <TextBlock Text="✓" FontSize="20" FontWeight="Bold" Foreground="#15803D" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="ITEM IDENTIFIED" FontSize="10" FontWeight="Black" Foreground="#15803D" Opacity="0.7" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding FoundItem.Description}" FontSize="16" FontWeight="Bold" Foreground="#166534"/>
                                        <TextBlock Text="{Binding FoundItem.Barcode, StringFormat='Barcode: {0}'}" FontSize="12" Foreground="#166534" Opacity="0.6"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Quantity -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="QUANTITY" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,8"/>
                                    <TextBox Style="{DynamicResource ModernTextBox}" 
                                             helpers:FocusHelper.SelectAllOnFocus="True"
                                             Text="{Binding FormQuantity, UpdateSourceTrigger=PropertyChanged}" 
                                             FontSize="15" FontWeight="Bold" Padding="12,8" TextAlignment="Center"
                                             PreviewTextInput="Quantity_PreviewTextInput"
                                             GotFocus="SearchBox_GotFocus"
                                             DataObject.Pasting="Quantity_Pasting"/>
                                </StackPanel>

                                <!-- Bill Image -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="BILL IMAGE (MANDATORY) *" FontSize="11" FontWeight="Bold" Margin="0,0,0,8">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#EF4444"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FormImagePreview}" Value="{x:Null}">
                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FormImagePreview, Converter={StaticResource NullToVis}}" Value="Visible">
                                                        <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Placeholder Textbox (Shown when no image) -->
                                        <TextBox Style="{DynamicResource ModernTextBox}" Text="{Binding TempImagePath, Mode=OneWay}" 
                                                 IsReadOnly="True" FontSize="12" Padding="14,11" 
                                                 Tag="Select image to enable save..." Foreground="{DynamicResource SubTextBrush}"
                                                 Visibility="{Binding FormImagePreview, Converter={StaticResource InverseNullToVis}}"/>

                                        <!-- Image Selection Preview (Shown when image is selected) -->
                                        <Border Grid.Column="0" Background="#F0FDF4" BorderBrush="#22C55E" BorderThickness="1" 
                                                CornerRadius="8" Padding="10,0" Height="42"
                                                Visibility="{Binding FormImagePreview, Converter={StaticResource NullToVis}}">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="28" Height="28" CornerRadius="4" ClipToBounds="True" Background="White" Margin="0,0,10,0">
                                                    <Image Source="{Binding FormImagePreview}" Stretch="UniformToFill"/>
                                                </Border>
                                                <TextBlock Text="Bill Selected ✅" FontWeight="SemiBold" Foreground="#15803D" VerticalAlignment="Center" FontSize="13"/>
                                            </StackPanel>
                                        </Border>

                                        <Button Grid.Column="1" Content="📁" Command="{Binding SelectImageCommand}" 
                                                Style="{DynamicResource AccentButton}" Margin="6,0,0,0" Padding="12,0" FontSize="14"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <!-- Modal Image Preview (Enlarged for readability) -->
                            <Border Margin="0,0,0,24" Height="350" Background="#F8FAFC" BorderBrush="{DynamicResource BorderBrush}" 
                                    BorderThickness="1" CornerRadius="12" Visibility="{Binding FormImagePreview, Converter={StaticResource NullToVis}}">
                                <Grid>
                                    <Image Source="{Binding FormImagePreview}" Stretch="Uniform" Margin="8"/>
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="5"
                                            Background="#88000000" CornerRadius="12" Width="24" Height="24">
                                        <Button Command="{Binding SelectImageCommand}" Background="Transparent" BorderThickness="0"
                                                ToolTip="Change Image" Cursor="Hand">
                                            <TextBlock Text="🔄" Foreground="White" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Button>
                                    </Border>
                                </Grid>
                            </Border>

                            <TextBlock Text="⚠️ Please select a bill image to register stock." 
                                       Foreground="#EF4444" FontSize="12" Margin="0,-15,0,15" HorizontalAlignment="Center">
                                 <TextBlock.Style>
                                     <Style TargetType="TextBlock">
                                         <Setter Property="Visibility" Value="Collapsed"/>
                                         <Style.Triggers>
                                             <DataTrigger Binding="{Binding FormImagePreview}" Value="{x:Null}">
                                                 <Setter Property="Visibility" Value="Visible"/>
                                             </DataTrigger>
                                         </Style.Triggers>
                                     </Style>
                                 </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </ScrollViewer>
                    <Border Grid.Row="3" Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,16"/>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Cancel" Command="{Binding CancelAddCommand}" 
                                Style="{StaticResource PrimaryButton}" Margin="0,0,12,0" Padding="0,12" 
                                Background="#F1F5F9" Foreground="#64748B" FontWeight="SemiBold"/>
                        
                        <Button Grid.Column="1" Command="{Binding SaveSupplyCommand}" 
                                Background="{DynamicResource SuccessBrush}" 
                                Padding="0,12" FontSize="15" FontWeight="Bold">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                    <Setter Property="Content" Value="✅ Register Stock"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Content" Value="💾 Update Stock"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Grid.ColumnSpan="2" Background="Transparent" Margin="0,15,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource SubTextBrush}" FontSize="12" Opacity="0.7"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ═══ POPUP ERROR OVERLAY ═══ -->
        <Border Grid.RowSpan="3" Grid.ColumnSpan="2" Panel.ZIndex="3000" IsHitTestVisible="False"
                VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,40,0,0"
                Visibility="{Binding PopupErrorVisible, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
            <Border Background="White" CornerRadius="8" Padding="20,12"
                    BorderBrush="#EF4444" BorderThickness="2">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.15" Color="Black"/>
                </Border.Effect>
                <TextBlock Text="{Binding PopupErrorMessage}" 
                           Foreground="#EF4444" FontSize="20" FontWeight="Bold" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
        </Border>
    </Grid>
</UserControl>
