<UserControl x:Class="GroceryPOS.Views.SupplierManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:GroceryPOS.ViewModels"
             mc:Ignorable="d" 
             Background="{DynamicResource BgBrush}"
             d:DesignHeight="700" d:DesignWidth="1000">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="🏭 Supplier Management" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Supplier List -->
            <Border Grid.Column="0" Style="{DynamicResource CardBorder}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="All Suppliers" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <ListBox ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="{Binding PhoneNumber}" Foreground="{DynamicResource SubTextBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding CompanyName}" Foreground="{DynamicResource PrimaryBrush}" FontSize="11" FontStyle="Italic"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Right: Details & Mapping -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Supplier Form -->
                <Border Grid.Row="0" Style="{DynamicResource CardBorder}" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Supplier Details" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                                <TextBlock Text="Phone Number (11 Digits)" FontSize="12" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditPhoneNumber, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{DynamicResource ModernTextBox}" 
                                         IsEnabled="{Binding IsEditMode, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"
                                         PreviewTextInput="NumericOnly_PreviewTextInput"
                                         MaxLength="11"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,10">
                                <TextBlock Text="Full Name" FontSize="12" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditName}" Style="{DynamicResource ModernTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                                <TextBlock Text="Company Name" FontSize="12" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditCompany}" Style="{DynamicResource ModernTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,10">
                                <TextBlock Text="Email Address" FontSize="12" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditEmail, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource ModernTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Margin="0,0,0,15">
                                <TextBlock Text="Physical Address" FontSize="12" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditAddress}" Style="{DynamicResource ModernTextBox}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}" 
                                   FontSize="11" Margin="0,5,0,10" HorizontalAlignment="Left"
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVis}}"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Reset" Command="{Binding ResetCommand}" Style="{DynamicResource AccentButton}" Margin="0,0,10,0" Padding="20,8"/>
                            <Button Content="Delete" Command="{Binding DeleteCommand}" Style="{DynamicResource DangerButton}" Margin="0,0,10,0" Padding="20,8"/>
                            <Button Content="Save Supplier" Command="{Binding SaveCommand}" Style="{DynamicResource PrimaryButton}" Padding="30,8"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Product Mapping -->
                <Border Grid.Row="2" Style="{DynamicResource CardBorder}" Padding="20">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Supplied Products" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>
                        
                        <!-- Assignment Form -->
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Select Product to Link" FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="2,0,0,4"/>
                                <ComboBox ItemsSource="{Binding AvailableItems}" SelectedItem="{Binding SelectedItemToAssign}" 
                                          DisplayMemberPath="Description" VerticalContentAlignment="Center" 
                                          Tag="Search products..."/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="Supply Price (Rs.)" FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="2,0,0,4"/>
                                <TextBox Text="{Binding NewSupplyPrice}" Style="{DynamicResource ModernTextBox}"/>
                            </StackPanel>

                            <Button Grid.Column="2" Content="Link Product" Command="{Binding AssignProductCommand}" 
                                    Style="{DynamicResource PrimaryButton}" Padding="15,5" VerticalAlignment="Bottom"/>
                        </Grid>

                        <DataGrid ItemsSource="{Binding AssignedProducts}" AutoGenerateColumns="False" CanUserAddRows="False" Style="{DynamicResource ModernDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*"/>
                                <DataGridTextColumn Header="Supply Price" Binding="{Binding SupplyPrice, StringFormat='Rs.{0:N0}'}" Width="120"/>
                                <DataGridTextColumn Header="Date Linked" Binding="{Binding SupplyDate, StringFormat='dd MMM yyyy'}" Width="120"/>
                                <DataGridTemplateColumn Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Remove" Command="{Binding DataContext.UnassignProductCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource DangerBrush}" Cursor="Hand"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
